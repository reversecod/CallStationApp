@page
@model CallStationApp.Pages.Menu.MenuModel
@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
@{
    ViewData["Title"] = "Menu";
    var fotoUsuario = !string.IsNullOrWhiteSpace(Model.UsuarioLogado?.FotoUsuario)
        ? Model.UsuarioLogado!.FotoUsuario
        : "/images/default-user.png";
}

<!DOCTYPE html>
<html lang="pt-br" data-bs-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>CallStation - Menu</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <style>
            body {
                background: linear-gradient(180deg, #f8fafc 0%, #eef2f7 100%);
                min-height: 100vh;
            }

            .navbar-brand img {
                object-fit: contain;
            }

            .hero-box {
                background: #ffffff;
                border: 1px solid #e9ecef;
                border-radius: 1.25rem;
                box-shadow: 0 10px 30px rgba(0,0,0,.05);
            }

            .grupo-card,
            .novo-grupo-card {
                border: 1px solid #e9ecef;
                border-radius: 1.2rem;
                background: #fff;
                transition: .2s ease;
                height: 100%;
                position: relative;
                overflow: hidden;
            }

                .grupo-card:hover,
                .novo-grupo-card:hover {
                    transform: translateY(-4px);
                    box-shadow: 0 12px 28px rgba(0,0,0,.08);
                    border-color: #d0d7de;
                }

            .grupo-link {
                color: inherit;
                text-decoration: none;
                display: block;
                height: 100%;
            }

            .grupo-topbar {
                min-height: 96px;
                width: 100%;
                padding: 1.25rem;
                display: flex;
                align-items: flex-start;
                justify-content: space-between;
                gap: 1rem;
            }

            .grupo-avatar {
                width: 56px;
                height: 56px;
                border-radius: 1rem;
                object-fit: cover;
                background: rgba(255,255,255,.88);
                border: 2px solid rgba(255,255,255,.75);
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 1.25rem;
                font-weight: 700;
                color: #334155;
                box-shadow: 0 8px 18px rgba(15,23,42,.16);
            }

            .grupo-foto-preview {
                width: 5.4rem;
                height: 5.4rem;
                border: 1px solid #dbe3ec;
                border-radius: 1rem;
                background: #f8fafc;
                color: #64748b;
                display: inline-flex;
                align-items: center;
                justify-content: center;
                overflow: hidden;
                font-size: 1.7rem;
                font-weight: 800;
            }

            .grupo-foto-preview img {
                display: block;
                width: 100%;
                height: 100%;
                object-fit: cover;
            }

            .grupo-cor-preview {
                width: 2.4rem;
                height: 2.4rem;
                border-radius: .65rem;
                border: 1px solid rgba(15, 23, 42, .16);
                background: #e5e7eb;
                box-shadow: inset 0 0 0 2px rgba(255,255,255,.65);
                flex-shrink: 0;
            }

            .grupo-permissao {
                background: rgba(255,255,255,.9);
                border: 1px solid rgba(255,255,255,.8);
                color: #111827;
                box-shadow: 0 6px 16px rgba(15,23,42,.12);
            }

            .grupo-stat {
                background: #f8fafc;
                border: 1px solid #eef2f7;
                border-radius: .9rem;
                padding: .75rem;
            }

            .grupo-descricao {
                min-height: 48px;
                color: #6b7280;
            }

            .perfil-img {
                width: 38px;
                height: 38px;
                border-radius: 50%;
                object-fit: cover;
                border: 2px solid rgba(255,255,255,.15);
            }

            .btn-create {
                border-radius: .9rem;
            }

            .empty-state {
                border: 2px dashed #cbd5e1;
                background: rgba(255,255,255,.7);
                border-radius: 1.2rem;
            }

            .novo-grupo-card {
                border-style: dashed;
                display: flex;
                align-items: center;
                justify-content: center;
                min-height: 280px;
                cursor: pointer;
            }

            .plus-circle {
                width: 64px;
                height: 64px;
                border-radius: 50%;
                background: #eff6ff;
                color: #2563eb;
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 1.8rem;
                margin-bottom: 1rem;
            }
            .navbar-actions {
                display: flex;
                align-items: center;
                gap: .75rem;
            }

            .btn-notificacao {
                position: relative;
                width: 40px;
                height: 40px;
                border: 0;
                border-radius: 50%;
                background: transparent;
                color: #fff;
                display: inline-flex;
                align-items: center;
                justify-content: center;
                transition: .2s ease;
            }

            .btn-notificacao:hover {
                background: rgba(255,255,255,.08);
                color: #fff;
            }

            .badge-notificacao {
                position: absolute;
                top: 2px;
                right: 1px;
                min-width: 18px;
                height: 18px;
                padding: 0 5px;
                border-radius: 999px;
                font-size: .7rem;
                display: inline-flex;
                align-items: center;
                justify-content: center;
                background: #dc3545;
                color: #fff;
                border: 2px solid #212529;
            }

            .notificacao-item {
                border: 1px solid #eef2f7;
                border-radius: .9rem;
                padding: .9rem 1rem;
                background: #fff;
            }

            .notificacao-item.nao-lida {
                border-color: #cfe2ff;
                background: #f8fbff;
            }

            .notificacao-titulo {
                font-weight: 600;
            }

            .notificacao-mensagem {
                color: #6b7280;
                font-size: .95rem;
            }

            .notificacao-data {
                font-size: .8rem;
                color: #94a3b8;
            }

            .notificacao-grupo-label {
                display: inline-flex;
                align-items: center;
                max-width: 100%;
                border-radius: 999px;
                padding: .14rem .5rem;
                background: var(--notificacao-grupo-color, #6c757d);
                color: var(--notificacao-grupo-text, #fff);
                font-size: inherit;
                font-weight: 700;
                line-height: 1.15;
                overflow: hidden;
                text-overflow: ellipsis;
                white-space: nowrap;
            }

            .notificacoes-lista {
                display: flex;
                flex-direction: column;
                gap: .75rem;
                max-height: 420px;
                overflow-y: auto;
            }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg bg-dark border-bottom" data-bs-theme="dark">
        <div class="container-fluid px-4">
            <a class="navbar-brand d-flex align-items-center" asp-page="/Menu/Menu">
                <img src="~/images/CallStationLogo.png" alt="CallStation" width="76" height="52" />
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMenu">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarMenu">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                    <li class="nav-item">
                        <a class="nav-link active" asp-page="/Menu/Menu">Meus quadros</a>
                    </li>
                </ul>

                <div class="navbar-actions">
                    <button type="button"
                            class="btn-notificacao"
                            data-bs-toggle="modal"
                            data-bs-target="#modalNotificacoes"
                            id="btnAbrirNotificacoes"
                            aria-label="Notificações">
                        <i class="bi bi-bell fs-5"></i>

                        @if (Model.TotalNotificacoesNaoLidas > 0)
                        {
                            <span class="badge-notificacao" id="badgeNotificacoes">
                                @(Model.TotalNotificacoesNaoLidas > 9 ? "9+" : Model.TotalNotificacoesNaoLidas.ToString())
                            </span>
                        }
                        else
                        {
                            <span class="badge-notificacao d-none" id="badgeNotificacoes">0</span>
                        }
                    </button>

                    <div class="dropdown">
                        <a class="nav-link text-white d-flex align-items-center gap-2" href="#" data-bs-toggle="dropdown">
                            <img src="@fotoUsuario" alt="Perfil" class="perfil-img" />
                            <span>@(Model.UsuarioLogado?.NomeUsuario ?? "Usuário")</span>
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li class="dropdown-header">
                                <strong>@(Model.UsuarioLogado?.NomeCompleto ?? "Usuário")</strong><br />
                                <small class="text-muted">Sua conta</small>
                            </li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item" asp-page="/Account/Profile">Meu perfil</a></li>
                            <li><a class="dropdown-item" href="#">Configurações</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item text-danger" asp-page="/Logout">Sair</a></li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </nav>

    <main class="container py-5">
        <div class="hero-box p-4 p-md-5 mb-4">
            <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
                <div>
                    <h1 class="h3 mb-2">Escolha um quadro para continuar</h1>
                    <p class="text-muted mb-0">
                        Aqui ficam suas equipes, organizações ou quadros de trabalho.
                    </p>
                </div>

                <button class="btn btn-primary btn-create px-4"
                        data-bs-toggle="modal"
                        data-bs-target="#modalCriarGrupo">
                    <i class="bi bi-plus-lg me-2"></i>
                    Novo grupo
                </button>
            </div>
        </div>

        @if (Model.Grupos.Any())
        {
            <div class="row g-4">
                @foreach (var grupo in Model.Grupos)
                {
                    var iniciais = string.IsNullOrWhiteSpace(grupo.Nome)
                        ? "G"
                        : new string(grupo.Nome
                            .Split(' ', StringSplitOptions.RemoveEmptyEntries)
                            .Take(2)
                            .Select(x => char.ToUpperInvariant(x[0]))
                            .ToArray());

                    <div class="col-12 col-sm-6 col-lg-4">
                        <a asp-page="/Menu/Home"
                               asp-route-grupoId="@grupo.GrupoId"
                               class="grupo-link">
                            <div class="grupo-card">
                                <div class="grupo-topbar" style="background-color:@grupo.CorCss;">
                                    @if (!string.IsNullOrWhiteSpace(grupo.FotoGrupo))
                                    {
                                        <img src="@grupo.FotoGrupo" alt="@grupo.Nome" class="grupo-avatar" />
                                    }
                                    else
                                    {
                                        <div class="grupo-avatar">@iniciais</div>
                                    }

                                    <span class="badge grupo-permissao">
                                        <i class="bi @grupo.PermissaoIcone me-1"></i>
                                        @grupo.PermissaoLabel
                                    </span>
                                </div>

                                <div class="p-4">
                                    <h2 class="h5 mb-1">@grupo.Nome</h2>

                                    @if (!string.IsNullOrWhiteSpace(grupo.ApelidoNoGrupo))
                                    {
                                        <div class="small text-primary mb-2">
                                            Você neste grupo: @grupo.ApelidoNoGrupo
                                        </div>
                                    }

                                    <p class="grupo-descricao small mb-3">
                                        @(string.IsNullOrWhiteSpace(grupo.Descricao)
                                            ? "Sem descrição cadastrada."
                                            : grupo.Descricao)
                                    </p>

                                    <div class="row g-2 mb-3">
                                        <div class="col-4">
                                            <div class="grupo-stat text-center">
                                                <div class="fw-semibold">@grupo.TotalChamados</div>
                                                <div class="small text-muted">Chamados</div>
                                            </div>
                                        </div>
                                        <div class="col-4">
                                            <div class="grupo-stat text-center">
                                                <div class="fw-semibold">@grupo.ChamadosAbertos</div>
                                                <div class="small text-muted">Abertos</div>
                                            </div>
                                        </div>
                                        <div class="col-4">
                                            <div class="grupo-stat text-center">
                                                <div class="fw-semibold">@grupo.TotalMembros</div>
                                                <div class="small text-muted">Membros</div>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="d-flex justify-content-between align-items-center small text-muted">
                                        <span>
                                            Entrou em @grupo.DataEntrada.ToString("dd/MM/yyyy")
                                        </span>
                                        <span>
                                            Abrir <i class="bi bi-arrow-right-short"></i>
                                        </span>
                                    </div>
                                </div>
                            </div>
                        </a>
                    </div>
                }

                <div class="col-12 col-sm-6 col-lg-4">
                    <div class="novo-grupo-card p-4 text-center"
                         data-bs-toggle="modal"
                         data-bs-target="#modalCriarGrupo">
                        <div>
                            <div class="plus-circle mx-auto">
                                <i class="bi bi-plus-lg"></i>
                            </div>
                            <h3 class="h5">Criar novo grupo</h3>
                            <p class="text-muted small mb-0">
                                Monte um novo espaço para chamados e tarefas.
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        }
        else
        {
            <div class="empty-state text-center p-5">
                <div class="mb-3">
                    <i class="bi bi-collection fs-1 text-secondary"></i>
                </div>
                <h2 class="h4">Você ainda não participa de nenhum grupo</h2>
                <p class="text-muted mb-4">
                    Crie seu primeiro quadro para começar a organizar seus chamados e tarefas.
                </p>
                <button class="btn btn-primary px-4"
                        data-bs-toggle="modal"
                        data-bs-target="#modalCriarGrupo">
                    <i class="bi bi-plus-lg me-2"></i>
                    Criar primeiro grupo
                </button>
            </div>
        }
    </main>

    <div class="modal fade" id="modalCriarGrupo" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content border-0 shadow">
                <div class="modal-header">
                    <h5 class="modal-title">Novo grupo</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <form id="formCriarGrupo" method="post" asp-page-handler="CriarGrupo">
                    @Html.AntiForgeryToken()

                    <div class="modal-body">
                        <div id="mensagemGrupo" class="alert d-none" role="alert"></div>

                        <div class="mb-3">
                            <label class="form-label">Nome</label>
                            <input type="text" name="nome" class="form-control" maxlength="100" required />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Descrição</label>
                            <textarea name="descricao" class="form-control" rows="3" maxlength="200"></textarea>
                        </div>

                        <div class="mb-3">
                            <label class="form-label" for="fotoGrupoCriacao">Foto do grupo</label>
                            <div class="d-flex align-items-center gap-3">
                                <div class="grupo-foto-preview" id="previewFotoGrupoCriacao" aria-hidden="true">G</div>
                                <div class="flex-grow-1">
                                    <input type="file"
                                           name="fotoGrupo"
                                           id="fotoGrupoCriacao"
                                           class="form-control"
                                           accept=".jpg,.jpeg,.png,.webp,image/jpeg,image/png,image/webp" />
                                    <div class="form-text">JPG, PNG ou WEBP. Limite de 2 MB.</div>
                                </div>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Etiqueta de cor</label>
                            <div class="d-flex align-items-center gap-2">
                                <select name="etiquetaCor" id="corGrupoCriacao" class="form-select">
                                    <option value="">Sem cor</option>
                                    <option value="Branco">Branco</option>
                                    <option value="Vermelho">Vermelho</option>
                                    <option value="Laranja">Laranja</option>
                                    <option value="Amarelo">Amarelo</option>
                                    <option value="Verde">Verde</option>
                                    <option value="Azul">Azul</option>
                                    <option value="Roxo">Roxo</option>
                                    <option value="Rosa">Rosa</option>
                                    <option value="Preto">Preto</option>
                                </select>
                                <span class="grupo-cor-preview" id="previewCorGrupoCriacao" aria-hidden="true"></span>
                            </div>
                        </div>
                    </div>

                    <div class="modal-footer">
                        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">
                            Cancelar
                        </button>
                        <button type="submit" class="btn btn-primary">
                            Criar grupo
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
    <div class="modal fade" id="modalNotificacoes" tabindex="-1" aria-labelledby="modalNotificacoesLabel" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-scrollable modal-dialog-centered">
            <div class="modal-content border-0 shadow">
                <div class="modal-header">
                    <h5 class="modal-title" id="modalNotificacoesLabel">
                        <i class="bi bi-bell me-2"></i>
                        Notificações
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fechar"></button>
                </div>

                <div class="modal-body">
                    <div id="listaNotificacoes" class="notificacoes-lista">
                        <div class="text-center text-muted py-4">
                            <i class="bi bi-bell-slash fs-3 d-block mb-2"></i>
                            Nenhuma notificação no momento.
                        </div>
                    </div>
                </div>

                <div class="modal-footer d-flex justify-content-between">
                <a asp-page="/Menu/Menu"
                   asp-page-handler="AbrirNotificacoes"
                   class="btn btn-primary">
                    <i class="bi bi-clock-history me-2"></i>
                    Histórico
                </a>

                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">
                    Fechar
                </button>
            </div>
            </div>
        </div>
    </div>
    <script>
        const btnAbrirNotificacoes = document.getElementById('btnAbrirNotificacoes');
        const badgeNotificacoes = document.getElementById('badgeNotificacoes');
        const listaNotificacoes = document.getElementById('listaNotificacoes');
        const modalNotificacoes = document.getElementById('modalNotificacoes');

        function formatarDataNotificacao(dataIso) {
            const data = new Date(dataIso);
            return data.toLocaleString('pt-BR');
        }

        function obterCorGrupoNotificacao(value) {
            const normalized = String(value ?? "").trim().toLowerCase();
            const colors = {
                "0": "#e5e7eb",
                "1": "#ef4444",
                "2": "#f97316",
                "3": "#eab308",
                "4": "#22c55e",
                "5": "#3b82f6",
                "6": "#a855f7",
                "7": "#ec4899",
                "8": "#1f2937",
                branco: "#e5e7eb",
                vermelho: "#ef4444",
                laranja: "#f97316",
                amarelo: "#eab308",
                verde: "#22c55e",
                azul: "#3b82f6",
                roxo: "#a855f7",
                rosa: "#ec4899",
                preto: "#1f2937"
            };

            return colors[normalized] || "#6c757d";
        }

        function obterCorTextoGrupoNotificacao(value) {
            const normalized = String(value ?? "").trim().toLowerCase();
            return normalized === "0" || normalized === "branco" ? "#212529" : "#fff";
        }

        function exibirErroNotificacoes(mensagem) {
            listaNotificacoes.innerHTML = "";
            const erro = document.createElement("div");
            erro.className = "text-center text-muted py-4";
            erro.textContent = mensagem || "Não foi possível carregar as notificações.";
            listaNotificacoes.appendChild(erro);
        }

        function renderizarNotificacoes(notificacoes) {
            listaNotificacoes.innerHTML = "";

            if (!notificacoes || notificacoes.length === 0) {
                const vazio = document.createElement("div");
                vazio.className = "text-center text-muted py-4";

                const icone = document.createElement("i");
                icone.className = "bi bi-bell-slash fs-3 d-block mb-2";
                vazio.append(icone, document.createTextNode("Nenhuma notificação no momento."));
                listaNotificacoes.appendChild(vazio);
                return;
            }

            notificacoes.forEach(n => {
                const item = document.createElement("div");
                item.className = `notificacao-item ${n.lida ? "" : "nao-lida"}`.trim();

                const topo = document.createElement("div");
                topo.className = "d-flex justify-content-between align-items-start gap-3 mb-2";

                const titulo = document.createElement("div");
                titulo.className = "notificacao-titulo";
                titulo.textContent = n.titulo || "";

                const data = document.createElement("div");
                data.className = "notificacao-data";
                data.textContent = formatarDataNotificacao(n.dataCriacao);

                const mensagem = document.createElement("div");
                mensagem.className = "notificacao-mensagem mb-2";
                mensagem.textContent = n.mensagem || "";

                const grupo = document.createElement("div");
                grupo.className = "small mb-2";

                if (n.nomeGrupo) {
                    const grupoPrefixo = document.createElement("span");
                    grupoPrefixo.className = "text-muted me-1";
                    grupoPrefixo.textContent = "Grupo:";

                    const grupoLabel = document.createElement("span");
                    grupoLabel.className = "notificacao-grupo-label";
                    grupoLabel.style.setProperty("--notificacao-grupo-color", obterCorGrupoNotificacao(n.etiquetaCor));
                    grupoLabel.style.setProperty("--notificacao-grupo-text", obterCorTextoGrupoNotificacao(n.etiquetaCor));
                    grupoLabel.textContent = n.nomeGrupo;
                    grupo.append(grupoPrefixo, grupoLabel);
                }

                const link = document.createElement("a");
                const urlBase = n.grupoId ? `/Menu/Notifications?grupoId=${encodeURIComponent(n.grupoId)}` : "?handler=AbrirNotificacoes";
                const separador = urlBase.includes("?") ? "&" : "?";
                link.href = n.id ? `${urlBase}${separador}notificacaoId=${encodeURIComponent(n.id)}#notificacao-${encodeURIComponent(n.id)}` : urlBase;
                link.className = "small text-decoration-none";
                link.textContent = "Abrir";

                topo.append(titulo, data);
                item.append(topo, mensagem);
                if (n.nomeGrupo) {
                    item.appendChild(grupo);
                }
                item.appendChild(link);
                listaNotificacoes.appendChild(item);
            });
        }

        async function carregarNotificacoes() {
            try {
                const response = await fetch('?handler=ListarNotificacoes');
                if (!response.ok) throw new Error("Falha ao carregar notificações.");

                const data = await response.json();

                if (!data.success) {
                    exibirErroNotificacoes(data.message || "Não foi possível carregar as notificações.");
                    return false;
                }

                renderizarNotificacoes(data.notificacoes);

                if (data.totalNaoLidas > 0) {
                    badgeNotificacoes.classList.remove('d-none');
                    badgeNotificacoes.textContent = data.totalNaoLidas > 9 ? '9+' : data.totalNaoLidas;
                } else {
                    badgeNotificacoes.classList.add('d-none');
                    badgeNotificacoes.textContent = '0';
                }
            } catch {
                exibirErroNotificacoes("Não foi possível carregar as notificações.");
                return false;
            }
        }

        modalNotificacoes.addEventListener('show.bs.modal', async function () {
            await carregarNotificacoes();
        });

        setInterval(() => {
            if (!document.hidden) {
                carregarNotificacoes();
            }
        }, 15000);
    </script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        const formCriarGrupo = document.getElementById('formCriarGrupo');
        const mensagemGrupo = document.getElementById('mensagemGrupo');
        const fotoGrupoCriacao = document.getElementById('fotoGrupoCriacao');
        const previewFotoGrupoCriacao = document.getElementById('previewFotoGrupoCriacao');
        const corGrupoCriacao = document.getElementById('corGrupoCriacao');
        const previewCorGrupoCriacao = document.getElementById('previewCorGrupoCriacao');

        function obterCorGrupo(value) {
            const normalized = String(value || '').trim().toLowerCase();
            const colors = {
                branco: '#e5e7eb',
                vermelho: '#ef4444',
                laranja: '#f97316',
                amarelo: '#eab308',
                verde: '#22c55e',
                azul: '#3b82f6',
                roxo: '#a855f7',
                rosa: '#ec4899',
                preto: '#1f2937'
            };
            return colors[normalized] || '#e5e7eb';
        }

        function atualizarPreviewCorGrupo() {
            if (previewCorGrupoCriacao) {
                previewCorGrupoCriacao.style.backgroundColor = obterCorGrupo(corGrupoCriacao?.value);
            }
        }

        corGrupoCriacao?.addEventListener('change', atualizarPreviewCorGrupo);
        atualizarPreviewCorGrupo();

        fotoGrupoCriacao?.addEventListener('change', function () {
            const arquivo = this.files?.[0];
            if (!previewFotoGrupoCriacao) return;

            if (!arquivo) {
                previewFotoGrupoCriacao.textContent = 'G';
                return;
            }

            if (!arquivo.type.startsWith('image/')) {
                previewFotoGrupoCriacao.textContent = 'G';
                return;
            }

            const reader = new FileReader();
            reader.onload = event => {
                previewFotoGrupoCriacao.innerHTML = `<img src="${event.target.result}" alt="Prévia da foto do grupo">`;
            };
            reader.readAsDataURL(arquivo);
        });

        formCriarGrupo.addEventListener('submit', async function (e) {
        e.preventDefault();

        mensagemGrupo.className = 'alert d-none';
        mensagemGrupo.textContent = '';

        const formData = new FormData(formCriarGrupo);

        try {
        const response = await fetch('?handler=CriarGrupo', {
        method: 'POST',
        body: formData
        });

        const data = await response.json();

        if (!data.success) {
        mensagemGrupo.className = 'alert alert-danger';
        mensagemGrupo.textContent = data.message ?? 'Não foi possível criar o grupo.';
        return;
        }

        window.location.href = data.redirectUrl;
        } catch {
        mensagemGrupo.className = 'alert alert-danger';
        mensagemGrupo.textContent = 'Ocorreu um erro ao criar o grupo.';
        }
        });
    </script>
    <input type="hidden" id="requestVerificationTokenMenu"
       value="@(Antiforgery.GetAndStoreTokens(HttpContext).RequestToken)" />
</body>
</html>
