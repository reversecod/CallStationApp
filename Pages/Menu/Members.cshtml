@page
@using CallStationApp.Models
@model CallStationApp.Pages.Menu.MembersModel
@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
@{
    ViewData["Title"] = "Membros do Grupo";
    ViewData["ActiveMenu"] = "Members";
}

<html lang="pt-br" data-bs-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Membros do Grupo</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" rel="stylesheet"
          integrity="sha384-LN+7fdVzj6u52u30Kp6M/trliBMCMKTyK833zpbD+pXdCLuTusPj697FH4R/5mcr" crossorigin="anonymous">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.min.css">

    <style>
        body {
            min-height: 100vh;
            min-height: -webkit-fill-available;
            overflow-y: auto;
            background-color: #f8f9fa;
        }

        main {
            position: relative;
            min-height: 100vh;
        }

        .sidebar {
            position: fixed;
            top: 0;
            left: 0;
            width: 17.5rem;
            height: 100vh;
            z-index: 1000;
        }

        .content-wrapper {
            margin-left: 17.5rem;
            padding: 1.5rem;
            min-height: 100vh;
            overflow-y: auto;
        }

        .logo-img {
            width: 100%;
            height: auto;
        }

        .user-img {
            width: 2rem;
            height: 2rem;
        }

        .icon-svg {
            width: 1rem;
            height: 1rem;
            font-size: 1rem;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            line-height: 1;
            flex-shrink: 0;
            color: currentColor;
            fill: currentColor;
        }

        .sidebar .nav-link {
            display: flex;
            align-items: center;
        }

        .sidebar .nav-link.active .icon-svg {
            color: #111;
            fill: #111;
        }

        .page-header-card {
            border: 0;
            border-radius: 1rem;
            box-shadow: 0 0.25rem 1rem rgba(0, 0, 0, 0.06);
        }

        .member-card {
            border: 0;
            border-radius: 1rem;
            box-shadow: 0 0.25rem 1rem rgba(0, 0, 0, 0.06);
            transition: transform 0.15s ease, box-shadow 0.15s ease;
            height: 100%;
        }

        .member-card:hover {
            transform: translateY(-0.125rem);
            box-shadow: 0 0.5rem 1.25rem rgba(0, 0, 0, 0.08);
        }

        .member-avatar {
            width: 4.5rem;
            height: 4.5rem;
            object-fit: cover;
            border-radius: 50%;
            border: 0.1875rem solid #e9ecef;
            background: #fff;
        }

        .member-avatar-placeholder {
            width: 4.5rem;
            height: 4.5rem;
            border-radius: 50%;
            border: 0.1875rem solid #e9ecef;
            display: flex;
            align-items: center;
            justify-content: center;
            background: #ffffff;
            font-size: 1.5rem;
            color: #6c757d;
        }

        .member-info-label {
            font-size: 0.8rem;
            color: #6c757d;
            margin-bottom: 0.15rem;
        }

        .member-info-value {
            font-size: 0.95rem;
            font-weight: 500;
            word-break: break-word;
        }

        .badge-permissao {
            font-size: 0.8rem;
            padding: 0.45rem 0.7rem;
            border-radius: 999px;
        }

        .top-actions {
            gap: 0.75rem;
        }

        .members-grid .col {
            display: flex;
        }

        @@media (max-width: 767.98px) {
            .sidebar {
                position: static;
                width: 100%;
                height: auto;
            }

            .content-wrapper {
                margin-left: 0;
                padding: 1rem;
            }
        }

        .member-card {
            overflow: visible;
        }

        .dropdown-menu {
            z-index: 2000;
        }

        .content-wrapper {
            overflow-y: auto;
            overflow-x: visible;
        }
    </style>
</head>
<body>
    <svg xmlns="http://www.w3.org/2000/svg" class="d-none">
        <symbol id="home" viewBox="0 0 16 16">
            <path d="M8.354 1.146a.5.5 0 0 0-.708 0l-6 6A.5.5 0 0 0 1.5 7.5v7a.5.5 0 0 0 .5.5h4.5a.5.5 0 0 0 .5-.5v-4h2v4a.5.5 0 0 0 .5.5H14a.5.5 0 0 0 .5-.5v-7a.5.5 0 0 0-.146-.354L13 5.793V2.5a.5.5 0 0 0-.5-.5h-1a.5.5 0 0 0-.5.5v1.293L8.354 1.146z"></path>
        </symbol>
        <symbol id="speedometer2" viewBox="0 0 16 16">
            <path d="M8 4a.5.5 0 0 1 .5.5V6a.5.5 0 0 1-1 0V4.5A.5.5 0 0 1 8 4zM3.732 5.732a.5.5 0 0 1 .707 0l.915.914a.5.5 0 1 1-.708.708l-.914-.915a.5.5 0 0 1 0-.707zM2 10a.5.5 0 0 1 .5-.5h1.586a.5.5 0 0 1 0 1H2.5A.5.5 0 0 1 2 10zm9.5 0a.5.5 0 0 1 .5-.5h1.5a.5.5 0 0 1 0 1H12a.5.5 0 0 1-.5-.5zm.754-4.246a.389.389 0 0 0-.527-.02L7.547 9.31a.91.91 0 1 0 1.302 1.258l3.434-4.297a.389.389 0 0 0-.029-.518z"></path>
            <path fill-rule="evenodd" d="M0 10a8 8 0 1 1 15.547 2.661c-.442 1.253-1.845 1.602-2.932 1.25C11.309 13.488 9.475 13 8 13c-1.474 0-3.31.488-4.615.911-1.087.352-2.49.003-2.932-1.25A7.988 7.988 0 0 1 0 10zm8-7a7 7 0 0 0-6.603 9.329c.203.575.923.876 1.68.63C4.397 12.533 6.358 12 8 12s3.604.532 4.923.96c.757.245 1.477-.056 1.68-.631A7 7 0 0 0 8 3z"></path>
        </symbol>
        <symbol id="table" viewBox="0 0 16 16">
            <path d="M0 2a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V2zm15 2h-4v3h4V4zm0 4h-4v3h4V8zm0 4h-4v3h3a1 1 0 0 0 1-1v-2zm-5 3v-3H6v3h4zm-5 0v-3H1v2a1 1 0 0 0 1 1h3zm-4-4h4V8H1v3zm0-4h4V4H1v3zm5-3v3h4V4H6zm4 4H6v3h4V8z"></path>
        </symbol>
        <symbol id="people-circle" viewBox="0 0 16 16">
            <path d="M11 6a3 3 0 1 1-6 0 3 3 0 0 1 6 0z"></path>
            <path fill-rule="evenodd" d="M0 8a8 8 0 1 1 16 0A8 8 0 0 1 0 8zm8-7a7 7 0 0 0-5.468 11.37C3.242 11.226 4.805 10 8 10s4.757 1.225 5.468 2.37A7 7 0 0 0 8 1z"></path>
        </symbol>
        <symbol id="grid" viewBox="0 0 16 16">
            <path d="M1 2.5A1.5 1.5 0 0 1 2.5 1h3A1.5 1.5 0 0 1 7 2.5v3A1.5 1.5 0 0 1 5.5 7h-3A1.5 1.5 0 0 1 1 5.5v-3zM2.5 2a.5.5 0 0 0-.5.5v3a.5.5 0 0 0 .5.5h3a.5.5 0 0 0 .5-.5v-3a.5.5 0 0 0-.5-.5h-3zm6.5.5A1.5 1.5 0 0 1 10.5 1h3A1.5 1.5 0 0 1 15 2.5v3A1.5 1.5 0 0 1 13.5 7h-3A1.5 1.5 0 0 1 9 5.5v-3zm1.5-.5a.5.5 0 0 0-.5.5v3a.5.5 0 0 0 .5.5h3a.5.5 0 0 0 .5-.5v-3a.5.5 0 0 0-.5-.5h-3zM1 10.5A1.5 1.5 0 0 1 2.5 9h3A1.5 1.5 0 0 1 7 10.5v3A1.5 1.5 0 0 1 5.5 15h-3A1.5 1.5 0 0 1 1 13.5v-3zm1.5-.5a.5.5 0 0 0-.5.5v3a.5.5 0 0 0 .5.5h3a.5.5 0 0 0 .5-.5v-3a.5.5 0 0 0-.5-.5h-3zm6.5.5A1.5 1.5 0 0 1 10.5 9h3a1.5 1.5 0 0 1 1.5 1.5v3a1.5 1.5 0 0 1-1.5 1.5h-3A1.5 1.5 0 0 1 9 13.5v-3zm1.5-.5a.5.5 0 0 0-.5.5v3a.5.5 0 0 0 .5.5h3a.5.5 0 0 0 .5-.5v-3a.5.5 0 0 0-.5-.5h-3z"></path>
        </symbol>
    </svg>

    <main>
        @await Html.PartialAsync("_MenuSidebar", Model, ViewData)

        <div class="content-wrapper">
            <div class="card page-header-card mb-4">
                <div class="card-body">
                    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center top-actions">
                        <div>
                            <h2 class="mb-1">Membros do Grupo</h2>
                            <p class="text-muted mb-0">
                                Grupo:
                                <strong>@(Model.GrupoAtual?.Nome ?? "Grupo")</strong>
                            </p>
                        </div>

                        <div class="d-flex flex-wrap gap-2 mt-3 mt-md-0">
                            @if (Model.UsuarioLogadoEhAdministrador)
                            {
                                <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#modalAdicionarMembro">
                                    <i class="bi bi-person-plus me-1"></i>
                                    Adicionar membro
                                </button>
                            }

                            <a asp-page="/Menu/Home" asp-route-grupoId="@Model.GrupoId" class="btn btn-outline-secondary">
                                <i class="bi bi-arrow-left me-1"></i>
                                Voltar
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-4 members-grid">
                @if (Model.Membros != null && Model.Membros.Any())
                {
                    foreach (var membro in Model.Membros)
                    {
                        var foto = !string.IsNullOrWhiteSpace(membro.FotoUsuario)
                            ? Url.Content(membro.FotoUsuario)
                            : null;

                        var permissaoClasse = membro.Permissao switch
                        {
                            PermissaoUsuario.Administracao => "text-bg-danger",
                            PermissaoUsuario.Tecnico => "text-bg-primary",
                            PermissaoUsuario.Colaborador => "text-bg-success",
                            _ => "text-bg-secondary"
                        };

                        <div class="col">
                            <div class="card member-card w-100">
                                <div class="card-body">
                                    <div class="d-flex align-items-center gap-3 mb-4">
                                        @if (!string.IsNullOrWhiteSpace(foto))
                                        {
                                            <img src="@foto" alt="Foto do usuário" class="member-avatar" loading="lazy" />
                                        }
                                        else
                                        {
                                            <div class="member-avatar-placeholder">
                                                <i class="bi bi-person-fill"></i>
                                            </div>
                                        }

                                        <div class="flex-grow-1">
                                            <h5 class="card-title mb-1">@membro.NomeCompleto</h5>
                                            <div class="text-muted small">@@@membro.NomeUsuario</div>
                                        </div>
                                    </div>

                                    <div class="mb-3">
                                        <div class="member-info-label">E-mail</div>
                                        <div class="member-info-value">@(string.IsNullOrWhiteSpace(membro.Email) ? "Não informado" : membro.Email)</div>
                                    </div>

                                    <div class="mb-3">
                                        <div class="member-info-label">Apelido no grupo</div>
                                        <div class="member-info-value">@(string.IsNullOrWhiteSpace(membro.Apelido) ? "Não definido" : membro.Apelido)</div>
                                    </div>

                                    <div class="mb-3">
                                        <div class="member-info-label">Permissão</div>
                                        <span class="badge badge-permissao @permissaoClasse">
                                            @membro.Permissao.ToString()
                                        </span>
                                    </div>

                                    <div class="mb-3">
                                        <div class="member-info-label">Identificador interno</div>
                                        <div class="member-info-value">@(string.IsNullOrWhiteSpace(membro.IdentificadorInterno) ? "Não definido" : membro.IdentificadorInterno)</div>
                                    </div>

                                    <div class="mb-3">
                                        <div class="member-info-label">Observação</div>
                                        <div class="member-info-value">@(string.IsNullOrWhiteSpace(membro.Observacao) ? "Sem observações" : membro.Observacao)</div>
                                    </div>

                                    <div class="d-flex justify-content-between align-items-center pt-2 border-top">
                                        <small class="text-muted">
                                            Desde @membro.DataAdicao.ToString("dd/MM/yyyy")
                                        </small>

                                        @if (Model.UsuarioLogadoEhAdministrador)
                                        {
                                            <div class="dropdown">
                                                <button class="btn btn-sm btn-outline-secondary dropdown-toggle" type="button"
                                                        data-bs-toggle="dropdown" aria-expanded="false">
                                                    Ações
                                                </button>
                                                <ul class="dropdown-menu dropdown-menu-end">
                                                    <li>
                                                        <button type="button"
                                                                class="dropdown-item btn-editar-apelido"
                                                                data-usuario-id="@membro.UsuarioId"
                                                                data-nome="@membro.NomeCompleto"
                                                                data-apelido="@membro.Apelido">
                                                            Editar apelido
                                                        </button>
                                                    </li>
                                                    <li>
                                                        <button type="button"
                                                                class="dropdown-item btn-alterar-permissao"
                                                                data-usuario-id="@membro.UsuarioId"
                                                                data-nome="@membro.NomeCompleto"
                                                                data-permissao="@membro.Permissao">
                                                            Alterar permissão
                                                        </button>
                                                    </li>
                                                    <li><hr class="dropdown-divider"></li>
                                                    <li>
                                                        <button type="button"
                                                                class="dropdown-item text-danger btn-remover-membro"
                                                                data-usuario-id="@membro.UsuarioId"
                                                                data-nome="@membro.NomeCompleto">
                                                            Remover do grupo
                                                        </button>
                                                    </li>
                                                </ul>
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="col-12">
                        <div class="card page-header-card">
                            <div class="card-body text-center py-5">
                                <i class="bi bi-people fs-1 text-muted"></i>
                                <h4 class="mt-3">Nenhum membro encontrado</h4>
                                <p class="text-muted mb-0">
                                    Ainda não há membros cadastrados neste grupo.
                                </p>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
        <div class="modal fade" id="modalAdicionarMembro" tabindex="-1" aria-labelledby="modalAdicionarMembroLabel" aria-hidden="true">
            <div class="modal-dialog modal-lg modal-dialog-centered">
                <div class="modal-content border-0 shadow">
                    <div class="modal-header">
                        <h5 class="modal-title" id="modalAdicionarMembroLabel">
                            Adicionar membro
                        </h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fechar"></button>
                    </div>

                    <div class="modal-body">
                        <input type="hidden" id="grupoIdAtual" value="@Model.GrupoId" />
                        <input type="hidden" id="requestVerificationToken"
                               value="@(Antiforgery.GetAndStoreTokens(HttpContext).RequestToken)" />

                        <div class="mb-3">
                            <label for="inputBuscarUsuario" class="form-label">
                                Procurar por nome completo, nome de usuário ou e-mail
                            </label>
                            <input type="text" class="form-control" id="inputBuscarUsuario"
                                   placeholder="Digite pelo menos 2 caracteres..." autocomplete="off" />
                        </div>

                        <div class="mb-3">
                            <label for="inputMensagemConvite" class="form-label">Mensagem do convite (opcional)</label>
                            <textarea class="form-control" id="inputMensagemConvite" rows="3"
                                      placeholder="Ex.: Gostaria de te adicionar ao grupo."></textarea>
                        </div>

                        <div id="resultadoBuscaUsuarios" class="list-group"></div>

                        <div id="usuarioSelecionadoBox" class="alert alert-light border mt-3 d-none">
                            <div class="fw-semibold mb-1">Usuário selecionado</div>
                            <div id="usuarioSelecionadoTexto" class="small text-muted"></div>
                        </div>

                        <div id="mensagemConviteFeedback" class="mt-3 d-none"></div>
                    </div>

                    <div class="modal-footer">
                        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">
                            Cancelar
                        </button>
                        <button type="button" class="btn btn-primary" id="btnEnviarConvite" disabled>
                            Enviar solicitação
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <div class="modal fade" id="modalEditarApelido" tabindex="-1" aria-labelledby="modalEditarApelidoLabel" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content border-0 shadow">
                    <div class="modal-header">
                        <h5 class="modal-title" id="modalEditarApelidoLabel">Editar apelido</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fechar"></button>
                    </div>

                    <div class="modal-body">
                        <input type="hidden" id="editarApelidoUsuarioId" />

                        <div class="mb-3">
                            <label class="form-label">Membro</label>
                            <div id="editarApelidoNome" class="form-control-plaintext"></div>
                        </div>

                        <div class="mb-3">
                            <label for="inputNovoApelido" class="form-label">Apelido no grupo</label>
                            <input type="text" class="form-control" id="inputNovoApelido" maxlength="35" placeholder="Digite um apelido ou deixe em branco" />
                        </div>

                        <div id="feedbackEditarApelido" class="d-none"></div>
                    </div>

                    <div class="modal-footer">
                        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
                        <button type="button" class="btn btn-primary" id="btnSalvarApelido">Salvar</button>
                    </div>
                </div>
            </div>
        </div>

        <div class="modal fade" id="modalAlterarPermissao" tabindex="-1" aria-labelledby="modalAlterarPermissaoLabel" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content border-0 shadow">
                    <div class="modal-header">
                        <h5 class="modal-title" id="modalAlterarPermissaoLabel">Alterar permissão</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fechar"></button>
                    </div>

                    <div class="modal-body">
                        <input type="hidden" id="alterarPermissaoUsuarioId" />

                        <div class="mb-3">
                            <label class="form-label">Membro</label>
                            <div id="alterarPermissaoNome" class="form-control-plaintext"></div>
                        </div>

                        <div class="mb-3">
                            <label for="selectNovaPermissao" class="form-label">Nova permissão</label>
                            <select id="selectNovaPermissao" class="form-select">
                                <option value="Nenhuma">Nenhuma</option>
                                <option value="Colaborador">Colaborador</option>
                                <option value="Tecnico">Técnico</option>
                                <option value="Administracao">Administração</option>
                            </select>
                        </div>

                        <div id="feedbackAlterarPermissao" class="d-none"></div>
                    </div>

                    <div class="modal-footer">
                        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
                        <button type="button" class="btn btn-primary" id="btnSalvarPermissao">Salvar</button>
                    </div>
                </div>
            </div>
        </div>

        <div class="modal fade" id="modalRemoverMembro" tabindex="-1" aria-labelledby="modalRemoverMembroLabel" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content border-0 shadow">
                    <div class="modal-header">
                        <h5 class="modal-title" id="modalRemoverMembroLabel">Remover membro</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fechar"></button>
                    </div>

                    <div class="modal-body">
                        <input type="hidden" id="removerMembroUsuarioId" />

                        <p class="mb-2">Tem certeza que deseja remover este membro do grupo?</p>
                        <div class="fw-semibold" id="removerMembroNome"></div>

                        <div id="feedbackRemoverMembro" class="d-none mt-3"></div>
                    </div>

                    <div class="modal-footer">
                        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
                        <button type="button" class="btn btn-danger" id="btnConfirmarRemoverMembro">Remover</button>
                    </div>
                </div>
            </div>
        </div>
    </main>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/js/bootstrap.bundle.min.js"
            integrity="sha384-ndDqU0Gzau9qJ1lfW4pNLlhNTkCfHzAVBReH9diLvGRem5+R9g2FzA8ZGN954O5Q"
            crossorigin="anonymous">
   </script>
    <script>
        let timeoutBuscaUsuario = null;
        let usuarioSelecionadoId = null;

        const inputBuscarUsuario = document.getElementById("inputBuscarUsuario");
        const inputMensagemConvite = document.getElementById("inputMensagemConvite");
        const resultadoBuscaUsuarios = document.getElementById("resultadoBuscaUsuarios");
        const usuarioSelecionadoBox = document.getElementById("usuarioSelecionadoBox");
        const usuarioSelecionadoTexto = document.getElementById("usuarioSelecionadoTexto");
        const btnEnviarConvite = document.getElementById("btnEnviarConvite");
        const mensagemConviteFeedback = document.getElementById("mensagemConviteFeedback");
        const grupoIdAtual = document.getElementById("grupoIdAtual")?.value;
        const requestVerificationToken = document.getElementById("requestVerificationToken")?.value;
        const modalAdicionarMembroElement = document.getElementById("modalAdicionarMembro");

        const modalEditarApelidoElement = document.getElementById("modalEditarApelido");
        const modalAlterarPermissaoElement = document.getElementById("modalAlterarPermissao");
        const modalRemoverMembroElement = document.getElementById("modalRemoverMembro");

        const modalAdicionarMembro = modalAdicionarMembroElement ? bootstrap.Modal.getOrCreateInstance(modalAdicionarMembroElement) : null;
        const modalEditarApelido = modalEditarApelidoElement ? bootstrap.Modal.getOrCreateInstance(modalEditarApelidoElement) : null;
        const modalAlterarPermissao = modalAlterarPermissaoElement ? bootstrap.Modal.getOrCreateInstance(modalAlterarPermissaoElement) : null;
        const modalRemoverMembro = modalRemoverMembroElement ? bootstrap.Modal.getOrCreateInstance(modalRemoverMembroElement) : null;

        const editarApelidoUsuarioId = document.getElementById("editarApelidoUsuarioId");
        const editarApelidoNome = document.getElementById("editarApelidoNome");
        const inputNovoApelido = document.getElementById("inputNovoApelido");
        const btnSalvarApelido = document.getElementById("btnSalvarApelido");
        const feedbackEditarApelido = document.getElementById("feedbackEditarApelido");

        const alterarPermissaoUsuarioId = document.getElementById("alterarPermissaoUsuarioId");
        const alterarPermissaoNome = document.getElementById("alterarPermissaoNome");
        const selectNovaPermissao = document.getElementById("selectNovaPermissao");
        const btnSalvarPermissao = document.getElementById("btnSalvarPermissao");
        const feedbackAlterarPermissao = document.getElementById("feedbackAlterarPermissao");

        const removerMembroUsuarioId = document.getElementById("removerMembroUsuarioId");
        const removerMembroNome = document.getElementById("removerMembroNome");
        const btnConfirmarRemoverMembro = document.getElementById("btnConfirmarRemoverMembro");
        const feedbackRemoverMembro = document.getElementById("feedbackRemoverMembro");

        function limparFeedbackConvite() {
            mensagemConviteFeedback.className = "mt-3 d-none";
            mensagemConviteFeedback.textContent = "";
        }

        function exibirFeedbackConvite(tipo, mensagem) {
            mensagemConviteFeedback.className = `alert alert-${tipo} mt-3`;
            mensagemConviteFeedback.textContent = mensagem;
        }

        function limparSelecaoUsuario() {
            usuarioSelecionadoId = null;
            usuarioSelecionadoBox.classList.add("d-none");
            usuarioSelecionadoTexto.textContent = "";
            btnEnviarConvite.disabled = true;
        }

        function renderizarResultados(usuarios) {
            resultadoBuscaUsuarios.innerHTML = "";

            if (!usuarios || usuarios.length === 0) {
                const vazio = document.createElement("div");
                vazio.className = "list-group-item text-muted";
                vazio.textContent = "Nenhum usuário encontrado.";
                resultadoBuscaUsuarios.appendChild(vazio);
                return;
            }

            usuarios.forEach(usuario => {
                const item = document.createElement("button");
                item.type = "button";
                item.className = "list-group-item list-group-item-action";

                const nome = document.createElement("div");
                nome.className = "fw-semibold";
                nome.textContent = usuario.nomeCompleto || "";

                const detalhe = document.createElement("div");
                detalhe.className = "small text-muted";
                detalhe.textContent = "@@" + (usuario.nomeUsuario || "") + (usuario.email ? " - " + usuario.email : "");

                item.append(nome, detalhe);

                item.addEventListener("click", () => {
                    usuarioSelecionadoId = usuario.id;
                    usuarioSelecionadoBox.classList.remove("d-none");
                    usuarioSelecionadoTexto.textContent =
                        (usuario.nomeCompleto || "") + " (@@" + (usuario.nomeUsuario || "") + (usuario.email ? " - " + usuario.email : "") + ")";
                    btnEnviarConvite.disabled = false;
                });

                resultadoBuscaUsuarios.appendChild(item);
            });
        }

        function limparFeedbackElemento(elemento) {
            if (!elemento) return;
            elemento.className = "d-none";
            elemento.textContent = "";
            elemento.innerHTML = "";
        }

        function exibirFeedbackElemento(elemento, tipo, mensagem) {
            if (!elemento) return;
            elemento.className = `alert alert-${tipo}`;
            elemento.textContent = mensagem;
        }

        inputBuscarUsuario?.addEventListener("input", function () {
            const termo = this.value.trim();
            limparFeedbackConvite();
            limparSelecaoUsuario();
            resultadoBuscaUsuarios.innerHTML = "";

            clearTimeout(timeoutBuscaUsuario);

            if (termo.length < 2) {
                return;
            }

            timeoutBuscaUsuario = setTimeout(async () => {
                try {
                    const response = await fetch(`/Menu/Members?handler=BuscarUsuarios&grupoId=${grupoIdAtual}&termo=${encodeURIComponent(termo)}`);
                    const data = await response.json();

                    if (!data.success) {
                        exibirFeedbackConvite("danger", data.message || "Erro ao buscar usuários.");
                        return;
                    }

                    renderizarResultados(data.usuarios);
                } catch {
                    exibirFeedbackConvite("danger", "Erro ao buscar usuários.");
                }
            }, 300);
        });

        btnEnviarConvite?.addEventListener("click", async function () {
            limparFeedbackConvite();

            if (!usuarioSelecionadoId) {
                exibirFeedbackConvite("warning", "Selecione um usuário antes de enviar a solicitação.");
                return;
            }

            btnEnviarConvite.disabled = true;

            try {
                const response = await fetch(`/Menu/Members?handler=EnviarConvite&grupoId=${grupoIdAtual}`, {
                    method: "POST",
                    headers: {
                        "Content-Type": "application/json",
                        "RequestVerificationToken": requestVerificationToken
                    },
                    body: JSON.stringify({
                        destinatarioUsuarioId: usuarioSelecionadoId,
                        mensagem: inputMensagemConvite.value.trim()
                    })
                });

                const data = await response.json();

                if (!data.success) {
                    exibirFeedbackConvite("danger", data.message || "Erro ao enviar solicitação.");
                    btnEnviarConvite.disabled = false;
                    return;
                }

                exibirFeedbackConvite("success", data.message || "Solicitação enviada com sucesso.");
                inputBuscarUsuario.value = "";
                inputMensagemConvite.value = "";
                resultadoBuscaUsuarios.innerHTML = "";
                limparSelecaoUsuario();
            } catch {
                exibirFeedbackConvite("danger", "Erro ao enviar solicitação.");
                btnEnviarConvite.disabled = false;
            }
        });

        modalAdicionarMembroElement?.addEventListener("hidden.bs.modal", function () {
            inputBuscarUsuario.value = "";
            inputMensagemConvite.value = "";
            resultadoBuscaUsuarios.innerHTML = "";
            limparSelecaoUsuario();
            limparFeedbackConvite();
        });

        document.querySelectorAll(".btn-editar-apelido").forEach(btn => {
            btn.addEventListener("click", () => {
                editarApelidoUsuarioId.value = btn.dataset.usuarioId || "";
                editarApelidoNome.textContent = btn.dataset.nome || "";
                inputNovoApelido.value = btn.dataset.apelido || "";
                limparFeedbackElemento(feedbackEditarApelido);
                modalEditarApelido?.show();
            });
        });

        document.querySelectorAll(".btn-alterar-permissao").forEach(btn => {
            btn.addEventListener("click", () => {
                alterarPermissaoUsuarioId.value = btn.dataset.usuarioId || "";
                alterarPermissaoNome.textContent = btn.dataset.nome || "";
                selectNovaPermissao.value = btn.dataset.permissao || "Nenhuma";
                limparFeedbackElemento(feedbackAlterarPermissao);
                modalAlterarPermissao?.show();
            });
        });

        document.querySelectorAll(".btn-remover-membro").forEach(btn => {
            btn.addEventListener("click", () => {
                removerMembroUsuarioId.value = btn.dataset.usuarioId || "";
                removerMembroNome.textContent = btn.dataset.nome || "";
                limparFeedbackElemento(feedbackRemoverMembro);
                modalRemoverMembro?.show();
            });
        });

        btnSalvarApelido?.addEventListener("click", async () => {
            limparFeedbackElemento(feedbackEditarApelido);
            btnSalvarApelido.disabled = true;

            try {
                const response = await fetch(`/Menu/Members?handler=EditarApelido&grupoId=${grupoIdAtual}`, {
                    method: "POST",
                    headers: {
                        "Content-Type": "application/json",
                        "RequestVerificationToken": requestVerificationToken
                    },
                    body: JSON.stringify({
                        usuarioId: parseInt(editarApelidoUsuarioId.value, 10),
                        apelido: inputNovoApelido.value.trim()
                    })
                });

                const data = await response.json();

                if (!data.success) {
                    exibirFeedbackElemento(feedbackEditarApelido, "danger", data.message || "Erro ao editar apelido.");
                    btnSalvarApelido.disabled = false;
                    return;
                }

                exibirFeedbackElemento(feedbackEditarApelido, "success", data.message || "Apelido atualizado com sucesso.");
                setTimeout(() => window.location.reload(), 700);
            } catch {
                exibirFeedbackElemento(feedbackEditarApelido, "danger", "Erro ao editar apelido.");
                btnSalvarApelido.disabled = false;
            }
        });

        btnSalvarPermissao?.addEventListener("click", async () => {
            limparFeedbackElemento(feedbackAlterarPermissao);
            btnSalvarPermissao.disabled = true;

            try {
                const response = await fetch(`/Menu/Members?handler=AlterarPermissao&grupoId=${grupoIdAtual}`, {
                    method: "POST",
                    headers: {
                        "Content-Type": "application/json",
                        "RequestVerificationToken": requestVerificationToken
                    },
                    body: JSON.stringify({
                        usuarioId: parseInt(alterarPermissaoUsuarioId.value, 10),
                        novaPermissao: selectNovaPermissao.value
                    })
                });

                const data = await response.json();

                if (!data.success) {
                    exibirFeedbackElemento(feedbackAlterarPermissao, "danger", data.message || "Erro ao alterar permissão.");
                    btnSalvarPermissao.disabled = false;
                    return;
                }

                exibirFeedbackElemento(feedbackAlterarPermissao, "success", data.message || "Permissão alterada com sucesso.");
                setTimeout(() => window.location.reload(), 700);
            } catch {
                exibirFeedbackElemento(feedbackAlterarPermissao, "danger", "Erro ao alterar permissão.");
                btnSalvarPermissao.disabled = false;
            }
        });

        btnConfirmarRemoverMembro?.addEventListener("click", async () => {
            limparFeedbackElemento(feedbackRemoverMembro);
            btnConfirmarRemoverMembro.disabled = true;

            try {
                const response = await fetch(`/Menu/Members?handler=RemoverMembro&grupoId=${grupoIdAtual}`, {
                    method: "POST",
                    headers: {
                        "Content-Type": "application/json",
                        "RequestVerificationToken": requestVerificationToken
                    },
                    body: JSON.stringify({
                        usuarioId: parseInt(removerMembroUsuarioId.value, 10)
                    })
                });

                const data = await response.json();

                if (!data.success) {
                    exibirFeedbackElemento(feedbackRemoverMembro, "danger", data.message || "Erro ao remover membro.");
                    btnConfirmarRemoverMembro.disabled = false;
                    return;
                }

                exibirFeedbackElemento(feedbackRemoverMembro, "success", data.message || "Membro removido com sucesso.");
                setTimeout(() => window.location.reload(), 700);
            } catch {
                exibirFeedbackElemento(feedbackRemoverMembro, "danger", "Erro ao remover membro.");
                btnConfirmarRemoverMembro.disabled = false;
            }
        });

        modalEditarApelidoElement?.addEventListener("hidden.bs.modal", () => {
            editarApelidoUsuarioId.value = "";
            editarApelidoNome.textContent = "";
            inputNovoApelido.value = "";
            limparFeedbackElemento(feedbackEditarApelido);
            btnSalvarApelido.disabled = false;
        });

        modalAlterarPermissaoElement?.addEventListener("hidden.bs.modal", () => {
            alterarPermissaoUsuarioId.value = "";
            alterarPermissaoNome.textContent = "";
            selectNovaPermissao.value = "Nenhuma";
            limparFeedbackElemento(feedbackAlterarPermissao);
            btnSalvarPermissao.disabled = false;
        });

        modalRemoverMembroElement?.addEventListener("hidden.bs.modal", () => {
            removerMembroUsuarioId.value = "";
            removerMembroNome.textContent = "";
            limparFeedbackElemento(feedbackRemoverMembro);
            btnConfirmarRemoverMembro.disabled = false;
        });
    </script>
</body>
</html>
