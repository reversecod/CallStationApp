@page
@model CallStationApp.Pages.Menu.HistoryModel
@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
@using CallStationApp.Models
@{
    ViewData["Title"] = "Historico";
}

<!DOCTYPE html>
<html lang="pt-br" data-bs-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Historico</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        :root {
            --history-col-criado: minmax(8.5rem, 1fr);
            --history-col-finalizado: minmax(8.5rem, 1fr);
            --history-col-abertura: minmax(10rem, 1.15fr);
            --history-col-encerramento: minmax(10rem, 1.15fr);
            --history-col-tempo: minmax(8rem, .9fr);
            --history-col-status: minmax(8rem, .9fr);
            --history-columns:
                var(--history-col-criado)
                var(--history-col-finalizado)
                var(--history-col-abertura)
                var(--history-col-encerramento)
                var(--history-col-tempo)
                var(--history-col-status);
        }

        body { min-height: 100vh; background:#f8fafc; }
        main { position: relative; min-height: 100vh; }
        .sidebar { position: fixed; top: 0; left: 0; width: 17.5rem; height: 100vh; z-index: 1000; }
        .content-wrapper { margin-left: 17.5rem; padding: 1.5rem; min-height: 100vh; }
        .logo-img { width: 100%; height: auto; }
        .user-img { width: 2rem; height: 2rem; }
        .icon-svg { width: 1rem; height: 1rem; font-size: 1rem; display: inline-flex; align-items: center; justify-content: center; line-height: 1; flex-shrink: 0; color: currentColor; fill: currentColor; }
        .sidebar .nav-link { display: flex; align-items: center; }
        .sidebar .nav-link.active .icon-svg { color: #111; fill: #111; }
        .history-list { display:flex; flex-direction:column; gap:1.15rem; }
        #historyCardsContainer { display:flex; flex-direction:column; gap:1rem; }

        .filter-bar {
            display:flex;
            align-items:center;
            gap:1rem;
            padding:.6rem .95rem;
            margin-bottom:.95rem;
            background:#ececec;
            border:1px solid #d8dde3;
            border-radius:1.6rem;
            box-shadow:0 10px 30px rgba(0,0,0,.04);
        }

        .history-columns-grid {
            display:grid;
            grid-template-columns:var(--history-columns);
            gap:.45rem;
            align-items:center;
            min-width:0;
            flex:1;
        }

        .filter-cell { min-width:0; }

        .filter-button {
            width:100%;
            border:0;
            background:transparent;
            padding:.3rem .45rem;
            border-radius:.9rem;
            display:flex;
            align-items:center;
            justify-content:flex-start;
            gap:.35rem;
            color:#111827;
            font-size:.72rem;
            font-weight:700;
            text-transform:uppercase;
            letter-spacing:.03em;
            transition:background-color .15s ease;
        }

        .filter-button:hover,
        .filter-button:focus-visible {
            background:rgba(17, 24, 39, .06);
            outline:none;
        }

        .filter-button.is-active {
            background:rgba(17, 24, 39, .08);
        }

        .sort-indicator {
            display:inline-flex;
            align-items:center;
            justify-content:center;
            min-width:1rem;
            color:#4b5563;
        }

        .ticket-card {
            position:relative;
            display:flex;
            gap:.9rem;
            align-items:center;
            width:100%;
            padding:.82rem 4.35rem .82rem .9rem;
            border-radius:1.85rem;
            color:#fff;
            box-shadow:0 .5rem 1rem rgba(0,0,0,.14);
        }

        .ticket-status-concluido { background:linear-gradient(135deg, #1fba88, #70dd72); }
        .ticket-status-fechado { background:linear-gradient(135deg, #667285, #aeb9c8); }
        .ticket-status-cancelado { background:linear-gradient(135deg, #ea4335, #ff7c7c); }

        .ticket-icon {
            width:3.25rem;
            height:3.25rem;
            border-radius:50%;
            flex-shrink:0;
        }

        .ticket-content {
            flex:1;
            min-width:0;
            display:flex;
            flex-direction:column;
            gap:.24rem;
        }

        .ticket-header {
            display:flex;
            align-items:center;
            justify-content:space-between;
            gap:.75rem;
            min-width:0;
        }

        .ticket-title-wrap {
            min-width:0;
            display:flex;
            align-items:center;
            gap:.5rem;
        }

        .ticket-title {
            margin:0;
            font-size:clamp(1rem, .45vw + .95rem, 1.3rem);
            font-weight:700;
            line-height:1.05;
            word-break:break-word;
        }

        .ticket-subinfo {
            color:rgba(255,255,255,.86);
            font-size:.68rem;
            font-weight:600;
            white-space:nowrap;
        }

        .ticket-number {
            width:2.15rem;
            height:2.15rem;
            border-radius:999px;
            background:rgba(255,255,255,.92);
            color:#0f172a;
            border:1px solid rgba(255,255,255,.55);
            display:flex;
            align-items:center;
            justify-content:center;
            font-size:.8rem;
            font-weight:800;
            flex-shrink:0;
            box-shadow:0 .2rem .55rem rgba(15, 23, 42, .12);
        }

        .ticket-meta-grid { min-width:0; }
        .history-cell { min-width:0; display:flex; justify-content:flex-start; }

        .history-block {
            border:1px solid rgba(255,255,255,.24);
            border-radius:999px;
            background:rgba(255,255,255,.24);
            padding:.26rem .62rem;
            display:inline-flex;
            flex-direction:column;
            align-items:center;
            justify-content:center;
            width:max-content;
            max-width:100%;
            min-width:0;
            line-height:1;
        }

        .history-block-action {
            border:0;
            cursor:pointer;
            transition:transform .12s ease, background-color .12s ease;
        }

        .history-block-action:hover,
        .history-block-action:focus-visible {
            background:rgba(255,255,255,.34);
            outline:none;
            transform:translateY(-1px);
        }

        .history-label {
            font-size:.56rem;
            color:rgba(255,255,255,.93);
            text-transform:uppercase;
            letter-spacing:.04em;
            line-height:1;
            white-space:nowrap;
        }

        .history-value {
            margin-top:.12rem;
            font-weight:700;
            color:#fff;
            font-size:.77rem;
            line-height:1.05;
            white-space:nowrap;
        }

        .ticket-side-actions {
            position:absolute;
            top:.75rem;
            right:.7rem;
            display:flex;
            flex-direction:column;
            align-items:center;
            gap:.35rem;
        }

        .ticket-comment-button {
            width:1.7rem;
            height:1.7rem;
            border:0;
            border-radius:999px;
            background:rgba(255,255,255,.22);
            color:#fff;
            display:inline-flex;
            align-items:center;
            justify-content:center;
            box-shadow:0 .25rem .7rem rgba(15, 23, 42, .12);
            transition:background-color .15s ease, transform .12s ease;
        }

        .ticket-comment-button .bi {
            font-size:.88rem;
            line-height:1;
        }

        .ticket-comment-button:hover,
        .ticket-comment-button:focus-visible {
            background:rgba(255,255,255,.28);
            outline:none;
            transform:translateY(-1px);
        }

        .ticket-comment-badge {
            position:absolute;
            top:-.12rem;
            right:-.08rem;
            width:.62rem;
            height:.62rem;
            border-radius:999px;
            background:#dc3545;
            border:2px solid rgba(255,255,255,.9);
        }

        .comment-list {
            display:flex;
            flex-direction:column;
            gap:.75rem;
            max-height:24rem;
            overflow-y:auto;
        }

        .comment-item {
            border:1px solid #e5e7eb;
            border-radius:1rem;
            padding:.85rem .95rem;
            background:#fff;
        }

        .comment-meta {
            display:flex;
            justify-content:space-between;
            gap:1rem;
            margin-bottom:.35rem;
            font-size:.8rem;
            color:#6b7280;
        }

        .comment-author {
            font-weight:700;
            color:#111827;
        }

        .comment-text {
            white-space:pre-wrap;
            word-break:break-word;
            color:#111827;
            font-size:.95rem;
        }

        .history-empty {
            display:flex;
            align-items:center;
            justify-content:center;
            gap:1rem;
            padding:2.2rem 1rem;
            background:#ececec;
            border:1px solid #d8dde3;
            border-radius:1.6rem;
            text-align:center;
        }

        @@media (max-width: 1200px) {
            :root {
                --history-col-criado: minmax(7.5rem, 1fr);
                --history-col-finalizado: minmax(7.5rem, 1fr);
                --history-col-abertura: minmax(9rem, 1fr);
                --history-col-encerramento: minmax(9rem, 1fr);
                --history-col-tempo: minmax(7rem, .85fr);
                --history-col-status: minmax(7rem, .85fr);
            }
        }

        @@media (max-width: 767.98px) {
            .sidebar { position: static; width: 100%; height: auto; }
            .content-wrapper { margin-left: 0; padding: 1rem; }
            .filter-bar { padding:.7rem; overflow-x:auto; border-radius:1.35rem; }
            .history-columns-grid { min-width:58rem; }
            .ticket-card { padding:.68rem 3.75rem .82rem .82rem; border-radius:1.5rem; align-items:flex-start; overflow-x:auto; }
            .ticket-icon { width:3rem; height:3rem; }
            .ticket-content { min-width:58rem; }
            .ticket-number { width:1.95rem; height:1.95rem; font-size:.74rem; }
            .ticket-side-actions { top:.65rem; right:.6rem; gap:.3rem; }
            .ticket-comment-button { width:1.55rem; height:1.55rem; }
            .ticket-comment-button .bi { font-size:.8rem; }
        }
    </style>
</head>
<body>
<main>
    <div class="d-flex flex-column flex-shrink-0 p-3 bg-body-tertiary sidebar">
        <a asp-page="/Menu/Menu" class="d-flex align-items-center mb-3 mb-md-0 me-md-auto link-body-emphasis text-decoration-none">
            <img src="~/images/logocompletopreto.png" alt="Logo" class="logo-img me-2" loading="lazy">
        </a>
        <hr />
        <ul class="nav nav-pills flex-column mb-auto">
            <li class="nav-item"><a asp-page="/Menu/Home" asp-route-grupoId="@Model.GrupoId" class="nav-link link-body-emphasis"><i class="bi bi-house-door me-2 icon-svg"></i>Chamados</a></li>
            <li><a asp-page="/Menu/Tasks" asp-route-grupoId="@Model.GrupoId" class="nav-link link-body-emphasis"><i class="bi bi-table me-2 icon-svg"></i>Tarefas</a></li>
            <li><a href="#" class="nav-link link-body-emphasis"><i class="bi bi-speedometer2 me-2 icon-svg"></i>Dashboard</a></li>
            <li><a asp-page="/Menu/History" asp-route-grupoId="@Model.GrupoId" class="nav-link active" aria-current="page"><i class="bi bi-grid me-2 icon-svg"></i>Historico</a></li>
            <li><a asp-page="/Menu/Members" asp-route-grupoId="@Model.GrupoId" class="nav-link link-body-emphasis"><i class="bi bi-people me-2 icon-svg"></i>Membros</a></li>
            @if (Model.UsuarioLogadoEhAdministrador)
            {
                <li><a asp-page="/Menu/Group" asp-route-grupoId="@Model.GrupoId" class="nav-link link-body-emphasis"><i class="bi bi-sliders2-vertical me-2 icon-svg"></i>Grupo</a></li>
            }
        </ul>
        <hr />
        <div class="dropdown">
            <a href="#" class="d-flex align-items-center link-body-emphasis text-decoration-none dropdown-toggle" data-bs-toggle="dropdown">
                <img src="@(Model.FotoUsuarioLogado ?? "/images/default-user.png")" alt="" class="user-img rounded-circle me-2" loading="lazy">
                <strong>@(Model.NomeUsuarioLogado ?? "Usuario")</strong>
            </a>
            <ul class="dropdown-menu text-small shadow">
                <li><a class="dropdown-item" asp-page="/Logout">Sair</a></li>
            </ul>
        </div>
    </div>

    <div class="content-wrapper">
        <input type="hidden" id="requestVerificationToken" value="@Antiforgery.GetAndStoreTokens(HttpContext).RequestToken" />
        <div class="filter-bar" id="historySortBar">
            <div class="history-columns-grid">
                <div class="filter-cell">
                    <button type="button" class="filter-button" data-sort-field="criado-por" data-sort-type="text" data-default-dir="asc">
                        <span>Criado por</span>
                        <span class="sort-indicator">-</span>
                    </button>
                </div>
                <div class="filter-cell">
                    <button type="button" class="filter-button" data-sort-field="finalizado-por" data-sort-type="text" data-default-dir="asc">
                        <span>Finalizado por</span>
                        <span class="sort-indicator">-</span>
                    </button>
                </div>
                <div class="filter-cell">
                    <button type="button" class="filter-button" data-sort-field="data-abertura" data-sort-type="date" data-default-dir="desc">
                        <span>Data de abertura</span>
                        <span class="sort-indicator">-</span>
                    </button>
                </div>
                <div class="filter-cell">
                    <button type="button" class="filter-button" data-sort-field="data-encerramento" data-sort-type="date" data-default-dir="desc">
                        <span>Data de encerramento</span>
                        <span class="sort-indicator">-</span>
                    </button>
                </div>
                <div class="filter-cell">
                    <button type="button" class="filter-button" data-sort-field="tempo-total" data-sort-type="number" data-default-dir="asc">
                        <span>Tempo total</span>
                        <span class="sort-indicator">-</span>
                    </button>
                </div>
                <div class="filter-cell">
                    <button type="button" class="filter-button" data-sort-field="status-atual" data-sort-type="text" data-default-dir="asc">
                        <span>Status atual</span>
                        <span class="sort-indicator">-</span>
                    </button>
                </div>
            </div>
        </div>

        <div class="history-list" id="historyList">
            @if (Model.Chamados.Any())
            {
                var indiceOriginal = 0;
                <div id="historyCardsContainer">
                @foreach (var chamado in Model.Chamados)
                {
                    var titulo = !string.IsNullOrWhiteSpace(chamado.Titulo) ? chamado.Titulo : $"Chamado {chamado.NumeroChamadoGrupo}";
                    var statusTexto = FormatarStatus(chamado.Status);
                    var classeStatus = ObterClasseStatus(statusTexto);

                    <article class="ticket-card @classeStatus"
                             data-chamado-id="@chamado.Id"
                             data-original-index="@indiceOriginal"
                             data-sort-criado-por="@chamado.CriadoPor"
                             data-sort-finalizado-por="@chamado.FinalizadoPor"
                             data-sort-data-abertura="@ParaUnixMilliseconds(chamado.DataCriacao)"
                             data-sort-data-encerramento="@ParaUnixMilliseconds(chamado.DataFinal)"
                             data-sort-tempo-total="@ParaDuracaoSegundos(chamado.TempoResolucao)"
                             data-sort-status-atual="@statusTexto"
                             data-sort-chamado="@chamado.Id">
                        <img src="~/images/logoticket.png" class="ticket-icon" alt="Ticket" loading="lazy" />
                        <div class="ticket-content">
                            <div class="ticket-header">
                                <div class="ticket-title-wrap">
                                    <h2 class="ticket-title">@titulo</h2>
                                    <span class="ticket-subinfo">Chamado #@chamado.Id</span>
                                </div>
                            </div>

                            <div class="history-columns-grid ticket-meta-grid">
                                <div class="history-cell">
                                    <div class="history-block">
                                        <div class="history-label">Criado por</div>
                                        <div class="history-value">@chamado.CriadoPor</div>
                                    </div>
                                </div>
                                <div class="history-cell">
                                    <div class="history-block">
                                        <div class="history-label">Finalizado por</div>
                                        <div class="history-value">@chamado.FinalizadoPor</div>
                                    </div>
                                </div>
                                <div class="history-cell">
                                    <div class="history-block">
                                        <div class="history-label">Data de abertura</div>
                                        <div class="history-value">@chamado.DataCriacao.ToString("dd/MM/yyyy HH:mm")</div>
                                    </div>
                                </div>
                                <div class="history-cell">
                                    <div class="history-block">
                                        <div class="history-label">Data de encerramento</div>
                                        <div class="history-value">@(chamado.DataFinal?.ToString("dd/MM/yyyy HH:mm") ?? "Nao registrado")</div>
                                    </div>
                                </div>
                                <div class="history-cell">
                                    <div class="history-block">
                                        <div class="history-label">Tempo total</div>
                                        <div class="history-value">@FormatarTempo(chamado.TempoResolucao)</div>
                                    </div>
                                </div>
                                <div class="history-cell">
                                    @if (Model.UsuarioLogadoPodeAlterarStatusHistorico)
                                    {
                                        <button type="button"
                                                class="history-block history-block-action btn-abrir-status"
                                                data-chamado-id="@chamado.Id"
                                                data-status-atual="@chamado.Status">
                                            <span class="history-label">Status atual</span>
                                            <span class="history-value" data-status-texto>@statusTexto</span>
                                        </button>
                                    }
                                    else
                                    {
                                        <div class="history-block">
                                            <div class="history-label">Status atual</div>
                                            <div class="history-value" data-status-texto>@statusTexto</div>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>

                        <div class="ticket-side-actions">
                            <span class="ticket-number">#@chamado.NumeroChamadoGrupo</span>
                            <button type="button"
                                class="ticket-comment-button btn-abrir-comentarios"
                                data-chamado-id="@chamado.Id"
                                aria-label="Abrir comentários">
                            <i class="bi bi-chat-dots"></i>
                            @if (chamado.TemComentariosNaoLidos)
                            {
                                <span class="ticket-comment-badge" data-comment-badge></span>
                            }
                            </button>
                        </div>
                    </article>

                    indiceOriginal++;
                }
                </div>

                @if (Model.TemPaginaAnterior || Model.TemProximaPagina)
                {
                    <div class="d-flex justify-content-between align-items-center pt-2">
                        @if (Model.TemPaginaAnterior)
                        {
                            <a asp-page="/Menu/History" asp-route-grupoId="@Model.GrupoId" asp-route-page="@(Model.PaginaAtual - 1)" class="btn btn-outline-secondary btn-sm">Anterior</a>
                        }
                        else
                        {
                            <span></span>
                        }

                        <span class="text-muted small">Pagina @Model.PaginaAtual</span>

                        @if (Model.TemProximaPagina)
                        {
                            <a asp-page="/Menu/History" asp-route-grupoId="@Model.GrupoId" asp-route-page="@(Model.PaginaAtual + 1)" class="btn btn-outline-secondary btn-sm">Proxima</a>
                        }
                        else
                        {
                            <span></span>
                        }
                    </div>
                }
            }
            else
            {
                <div class="history-empty">
                    <i class="bi bi-grid fs-1 text-secondary"></i>
                    <div>
                        <h2 class="h4 mt-3">Nenhum chamado finalizado</h2>
                        <p class="text-muted mb-0">Quando chamados forem concluidos, fechados ou cancelados, eles aparecerao aqui.</p>
                    </div>
                </div>
            }
        </div>
    </div>
</main>

<div class="modal fade" id="modalComentariosHistorico" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Comentarios do chamado</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="comentariosChamadoId" />
                <div id="listaComentariosHistorico" class="comment-list">
                    <div class="text-muted small">Carregando comentarios...</div>
                </div>
                <div class="mt-3 @(Model.UsuarioLogadoPodeComentarHistorico ? string.Empty : "d-none")" id="secaoNovoComentarioHistorico">
                    <label for="textoNovoComentarioHistorico" class="form-label">Novo comentario</label>
                    <textarea id="textoNovoComentarioHistorico" class="form-control" rows="3" maxlength="500" placeholder="Escreva um comentario..."></textarea>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Fechar</button>
                @if (Model.UsuarioLogadoPodeComentarHistorico)
                {
                    <button type="button" class="btn btn-primary" id="btnEnviarComentarioHistorico">Enviar comentario</button>
                }
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="modalStatusHistorico" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Alterar status do chamado</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="statusHistoricoChamadoId" />
                <label class="form-label" for="selectNovoStatusHistorico">Novo status</label>
                <select id="selectNovoStatusHistorico" class="form-select">
                    <option value="Aberto">Aberto</option>
                    <option value="EmAndamento">Em andamento</option>
                    <option value="Pendente">Pendente</option>
                    <option value="Concluido">Concluido</option>
                    <option value="Fechado">Fechado</option>
                    <option value="Reaberto">Reaberto</option>
                    <option value="Cancelado">Cancelado</option>
                </select>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-primary" id="btnSalvarStatusHistorico">Salvar</button>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/js/bootstrap.bundle.min.js"></script>
<script>
    document.addEventListener("DOMContentLoaded", () => {
        const historyList = document.getElementById("historyList");
        const historyCardsContainer = document.getElementById("historyCardsContainer");
        const sortButtons = Array.from(document.querySelectorAll("#historySortBar .filter-button"));
        const comentariosModalElement = document.getElementById("modalComentariosHistorico");
        const statusModalElement = document.getElementById("modalStatusHistorico");
        const comentariosModal = comentariosModalElement ? bootstrap.Modal.getOrCreateInstance(comentariosModalElement) : null;
        const statusModal = statusModalElement ? bootstrap.Modal.getOrCreateInstance(statusModalElement) : null;
        const listaComentarios = document.getElementById("listaComentariosHistorico");
        const comentariosChamadoIdInput = document.getElementById("comentariosChamadoId");
        const textoNovoComentario = document.getElementById("textoNovoComentarioHistorico");
        const btnEnviarComentario = document.getElementById("btnEnviarComentarioHistorico");
        const statusChamadoIdInput = document.getElementById("statusHistoricoChamadoId");
        const selectNovoStatus = document.getElementById("selectNovoStatusHistorico");
        const btnSalvarStatus = document.getElementById("btnSalvarStatusHistorico");
        const collator = new Intl.Collator("pt-BR", { sensitivity: "base", numeric: true });

        let activeField = null;
        let activeDirection = null;

        sortButtons.forEach(button => {
            button.addEventListener("click", () => {
                const field = button.dataset.sortField;
                const defaultDirection = button.dataset.defaultDir || "asc";

                if (!field) return;

                if (activeField === field) {
                    if (activeDirection === defaultDirection) {
                        activeDirection = defaultDirection === "asc" ? "desc" : "asc";
                    } else {
                        activeField = null;
                        activeDirection = null;
                    }
                } else {
                    activeField = field;
                    activeDirection = defaultDirection;
                }

                atualizarIndicadores();
                aplicarOrdenacaoAtual();
            });
        });

        historyList?.addEventListener("click", event => {
            const btnComentarios = event.target.closest(".btn-abrir-comentarios");
            if (btnComentarios) {
                abrirComentarios(Number(btnComentarios.dataset.chamadoId));
                return;
            }

            const btnStatus = event.target.closest(".btn-abrir-status");
            if (btnStatus) {
                abrirStatus(Number(btnStatus.dataset.chamadoId), btnStatus.dataset.statusAtual || "");
            }
        });

        btnEnviarComentario?.addEventListener("click", async () => {
            const chamadoId = Number(comentariosChamadoIdInput?.value);
            const mensagem = (textoNovoComentario?.value || "").trim();
            if (!chamadoId || !mensagem) {
                mostrarToast("Informe um comentario antes de enviar.");
                return;
            }

            try {
                const data = await fetchJson("?handler=AdicionarComentario", {
                    chamadoId,
                    mensagem
                });

                if (!data.success) {
                    mostrarToast(data.message || "Nao foi possivel adicionar o comentario.");
                    return;
                }

                if (textoNovoComentario) textoNovoComentario.value = "";
                mostrarToast(data.dados?.message || "Comentario adicionado com sucesso.", "success");
                await carregarComentarios(chamadoId, true);
            } catch (error) {
                mostrarToast(error.message || "Nao foi possivel adicionar o comentario.");
            }
        });

        btnSalvarStatus?.addEventListener("click", async () => {
            const chamadoId = Number(statusChamadoIdInput?.value);
            const status = selectNovoStatus?.value || "";
            if (!chamadoId || !status) {
                mostrarToast("Selecione um status valido.");
                return;
            }

            try {
                const data = await fetchJson("?handler=AlterarStatusHistorico", {
                    chamadoId,
                    status
                });

                if (!data.success) {
                    mostrarToast(data.message || "Nao foi possivel alterar o status.");
                    return;
                }

                atualizarCardAposStatus(data.dados);
                statusModal?.hide();
                mostrarToast(data.dados?.message || "Status atualizado com sucesso.", "success");
            } catch (error) {
                mostrarToast(error.message || "Nao foi possivel alterar o status.");
            }
        });

        function atualizarIndicadores() {
            sortButtons.forEach(button => {
                const indicator = button.querySelector(".sort-indicator");
                const isActive = button.dataset.sortField === activeField && !!activeDirection;
                button.classList.toggle("is-active", isActive);

                if (!indicator) return;
                indicator.textContent = !isActive ? "-" : activeDirection === "asc" ? "↑" : "↓";
            });
        }

        function aplicarOrdenacaoAtual() {
            const cards = Array.from(historyCardsContainer?.querySelectorAll(".ticket-card") || []);
            if (cards.length <= 1) return;

            const visiveis = cards.filter(card => !card.hidden && window.getComputedStyle(card).display !== "none");
            const ocultos = cards.filter(card => !visiveis.includes(card));

            if (!activeField || !activeDirection) {
                visiveis.sort((a, b) => Number(a.dataset.originalIndex || 0) - Number(b.dataset.originalIndex || 0));
            } else {
                visiveis.sort((a, b) => compararCards(a, b, activeField, activeDirection));
            }

            visiveis.forEach(card => historyCardsContainer?.appendChild(card));
            ocultos.forEach(card => historyCardsContainer?.appendChild(card));
        }

        function compararCards(a, b, field, direction) {
            const type = document.querySelector(`.filter-button[data-sort-field="${field}"]`)?.dataset.sortType || "text";
            const valorA = a.dataset[`sort${toPascalCase(field)}`] ?? "";
            const valorB = b.dataset[`sort${toPascalCase(field)}`] ?? "";

            let resultado = 0;
            if (type === "number" || type === "date") {
                const numeroA = Number(valorA || 0);
                const numeroB = Number(valorB || 0);
                resultado = numeroA === numeroB ? 0 : numeroA > numeroB ? 1 : -1;
            } else {
                resultado = collator.compare(valorA || "", valorB || "");
            }

            if (resultado === 0) {
                resultado = Number(a.dataset.originalIndex || 0) - Number(b.dataset.originalIndex || 0);
            }

            return direction === "desc" ? resultado * -1 : resultado;
        }

        function toPascalCase(value) {
            return String(value)
                .split("-")
                .filter(Boolean)
                .map(parte => parte.charAt(0).toUpperCase() + parte.slice(1))
                .join("");
        }

        async function abrirComentarios(chamadoId) {
            if (!chamadoId || !comentariosModal) return;
            comentariosChamadoIdInput.value = chamadoId;
            comentariosModal.show();
            await carregarComentarios(chamadoId, true);
        }

        async function carregarComentarios(chamadoId, marcarVisualizacao) {
            if (!listaComentarios) return;
            listaComentarios.innerHTML = '<div class="text-muted small">Carregando comentarios...</div>';

            try {
                const response = await fetch(`?handler=Comentarios&grupoId=@Model.GrupoId&chamadoId=${encodeURIComponent(chamadoId)}`);
                const data = await response.json();

                if (!response.ok || !data.success) {
                    throw new Error(data.message || "Nao foi possivel carregar os comentarios.");
                }

                renderizarComentarios(data.dados?.comentarios || []);

                if (marcarVisualizacao) {
                    await fetchJson("?handler=MarcarComentariosVisualizados", { chamadoId });
                    removerIndicadorComentario(chamadoId);
                }
            } catch (error) {
                listaComentarios.innerHTML = `<div class="text-danger small">${escapeHtml(error.message || "Nao foi possivel carregar os comentarios.")}</div>`;
            }
        }

        function renderizarComentarios(comentarios) {
            if (!listaComentarios) return;

            if (!comentarios || comentarios.length === 0) {
                listaComentarios.innerHTML = '<div class="text-muted small">Nenhum comentario registrado para este chamado.</div>';
                return;
            }

            listaComentarios.innerHTML = comentarios.map(comentario => `
                <div class="comment-item">
                    <div class="comment-meta">
                        <span class="comment-author">${escapeHtml(comentario.autor || "Nao registrado")}</span>
                        <span>${escapeHtml(formatDateTimeLocal(comentario.dataComentario))}</span>
                    </div>
                    <div class="comment-text">${escapeHtml(comentario.texto || "")}</div>
                </div>
            `).join("");
        }

        function removerIndicadorComentario(chamadoId) {
            const card = document.querySelector(`.ticket-card[data-chamado-id="${chamadoId}"]`);
            card?.querySelector("[data-comment-badge]")?.remove();
        }

        function abrirStatus(chamadoId, statusAtual) {
            if (!chamadoId || !statusModal) return;
            statusChamadoIdInput.value = chamadoId;
            if (selectNovoStatus) selectNovoStatus.value = statusAtual || "Concluido";
            statusModal.show();
        }

        function atualizarCardAposStatus(dados) {
            const chamadoId = Number(dados?.chamadoId);
            if (!chamadoId) return;

            const card = document.querySelector(`.ticket-card[data-chamado-id="${chamadoId}"]`);
            if (!card) return;

            if (dados.removeFromHistory) {
                card.remove();
                return;
            }

            const statusTexto = dados.statusFormatado || dados.status || "";
            card.classList.remove("ticket-status-concluido", "ticket-status-fechado", "ticket-status-cancelado");
            card.classList.add(obterClasseStatusCard(statusTexto));
            card.dataset.sortStatusAtual = statusTexto;
            card.dataset.sortDataEncerramento = dados.dataFinalizacao ? Date.parse(dados.dataFinalizacao) : "0";

            const statusTextoElement = card.querySelector("[data-status-texto]");
            if (statusTextoElement) {
                statusTextoElement.textContent = statusTexto;
            }

            const btnStatus = card.querySelector(".btn-abrir-status");
            if (btnStatus) {
                btnStatus.dataset.statusAtual = dados.status || "";
            }

            aplicarOrdenacaoAtual();
        }

        function obterClasseStatusCard(status) {
            const normalizado = String(status || "")
                .trim()
                .toLowerCase()
                .normalize("NFD")
                .replace(/[\u0300-\u036f]/g, "")
                .replace(/\s+/g, "");

            if (normalizado === "concluido") return "ticket-status-concluido";
            if (normalizado === "cancelado") return "ticket-status-cancelado";
            return "ticket-status-fechado";
        }

        async function fetchJson(url, payload) {
            const response = await fetch(url, {
                method: "POST",
                headers: {
                    "Content-Type": "application/json",
                    "RequestVerificationToken": getToken()
                },
                body: JSON.stringify(payload)
            });

            let data = null;
            try {
                data = await response.json();
            } catch {
            }

            if (!response.ok || !data) {
                throw new Error(data?.message || `Erro HTTP: ${response.status}`);
            }

            return data;
        }

        function getToken() {
            return document.querySelector('#requestVerificationToken')?.value
                || document.querySelector('input[name="__RequestVerificationToken"]')?.value
                || document.querySelector('#requestVerificationTokenMenu')?.value
                || "";
        }

        function mostrarToast(mensagem, tipo = "danger") {
            let container = document.getElementById("toastContainerHistorico");
            if (!container) {
                container = document.createElement("div");
                container.id = "toastContainerHistorico";
                container.className = "toast-container position-fixed top-0 end-0 p-3";
                container.style.zIndex = "2000";
                document.body.appendChild(container);
            }

            const toast = document.createElement("div");
            toast.className = `toast align-items-center text-bg-${tipo} border-0`;
            toast.role = "alert";
            toast.ariaLive = "assertive";
            toast.ariaAtomic = "true";
            toast.innerHTML = `
                <div class="d-flex">
                    <div class="toast-body">${escapeHtml(String(mensagem || "Ocorreu um erro."))}</div>
                    <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Fechar"></button>
                </div>
            `;

            container.appendChild(toast);
            const instance = bootstrap.Toast.getOrCreateInstance(toast, { delay: 4500 });
            toast.addEventListener("hidden.bs.toast", () => toast.remove());
            instance.show();
        }

        function escapeHtml(value) {
            return String(value)
                .replaceAll("&", "&amp;")
                .replaceAll("<", "&lt;")
                .replaceAll(">", "&gt;")
                .replaceAll('"', "&quot;")
                .replaceAll("'", "&#039;");
        }

        function formatDateTimeLocal(value) {
            if (!value) return "-";
            const data = new Date(value);
            if (Number.isNaN(data.getTime())) return "-";
            return data.toLocaleString("pt-BR");
        }
    });
</script>
</body>
</html>

@functions {
    private static string FormatarStatus(StatusChamado status) => status switch
    {
        StatusChamado.Concluido => "Concluido",
        StatusChamado.Fechado => "Fechado",
        StatusChamado.Cancelado => "Cancelado",
        StatusChamado.EmAndamento => "Em andamento",
        StatusChamado.Reaberto => "Reaberto",
        _ => status.ToString()
    };

    private static string ObterClasseStatus(string? status)
    {
        var normalizado = NormalizarStatus(status);
        return normalizado switch
        {
            "concluido" => "ticket-status-concluido",
            "fechado" => "ticket-status-fechado",
            "cancelado" => "ticket-status-cancelado",
            _ => "ticket-status-fechado"
        };
    }

    private static string NormalizarStatus(string? valor) =>
        (valor ?? string.Empty)
            .Trim()
            .ToLowerInvariant()
            .Normalize(System.Text.NormalizationForm.FormD)
            .Where(c => System.Globalization.CharUnicodeInfo.GetUnicodeCategory(c) != System.Globalization.UnicodeCategory.NonSpacingMark)
            .Aggregate(new System.Text.StringBuilder(), (builder, caractere) => builder.Append(caractere))
            .ToString()
            .Replace(" ", string.Empty, StringComparison.Ordinal);

    private static long ParaUnixMilliseconds(DateTime data) =>
        new DateTimeOffset(DateTime.SpecifyKind(data, DateTimeKind.Utc)).ToUnixTimeMilliseconds();

    private static long ParaUnixMilliseconds(DateTime? data) =>
        data.HasValue
            ? new DateTimeOffset(DateTime.SpecifyKind(data.Value, DateTimeKind.Utc)).ToUnixTimeMilliseconds()
            : 0L;

    private static long ParaDuracaoSegundos(TimeSpan? tempo) =>
        tempo.HasValue && tempo.Value.TotalSeconds > 0
            ? (long)tempo.Value.TotalSeconds
            : 0L;

    private static string FormatarTempo(TimeSpan? tempo)
    {
        if (!tempo.HasValue)
            return "Nao registrado";

        var valor = tempo.Value;
        if (valor.TotalDays >= 1)
            return $"{(int)valor.TotalDays}d {valor.Hours:D2}h {valor.Minutes:D2}min";

        if (valor.TotalHours >= 1)
            return $"{(int)valor.TotalHours}h {valor.Minutes:D2}min";

        return $"{Math.Max(0, (int)valor.TotalMinutes)}min";
    }
}
