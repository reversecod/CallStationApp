@page
@model CallStationApp.Pages.Menu.HomeModel
@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
@using CallStationApp.Models
@{
  ViewData["Title"] = "Home";
    ViewData["ActiveMenu"] = "Home";
}

<html lang="pt-br" data-bs-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="" />
    <meta
      name="author"
      content="Mark Otto, Jacob Thornton, and Bootstrap contributors"
    />
    <title>Home</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-LN+7fdVzj6u52u30Kp6M/trliBMCMKTyK833zpbD+pXdCLuTusPj697FH4R/5mcr" crossorigin="anonymous">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.min.css">
   <style>
       body {
        min-height: 100vh;
        min-height: -webkit-fill-available;
        background:
          radial-gradient(circle at 16% 12%, rgba(59, 130, 246, .08), transparent 28rem),
          linear-gradient(180deg, #f8fbff 0%, #f3f6fb 100%);
        overflow-y: auto; /* Permite scroll no body se necessário, mas isolado no conteúdo */
      }

      main {
        position: relative; /* Para posicionar a sidebar fixa dentro */
        min-height: 100vh;
      }

      .sidebar {
        position: fixed; /* Fixa a sidebar na tela */
        top: 0;
        left: 0;
        width: 17.5rem; /* 280px / 16 = 17.5rem */
        height: 100vh; /* Altura total da viewport */ /* Se a sidebar for longa, ela rola internamente */
        z-index: 1000; /* Garante que fique acima do conteúdo */
      }

      .content-wrapper {
        margin-left: 17.5rem; /* Espaço para a sidebar fixa */
        padding: 1rem 1.35rem; /* Espaço interno no conteúdo */
        min-height: 100vh; /* Garante que o conteúdo ocupe a altura total */
        overflow-y: auto; /* Ativa scroll vertical apenas no conteúdo */
      }

      /* Resto do CSS permanece igual, já usa rem na maioria */
      .bd-placeholder-img {
        font-size: 1.125rem;
        text-anchor: middle;
        -webkit-user-select: none;
        -moz-user-select: none;
        user-select: none;
      }

      @@media (min-width:768px) {
        .bd-placeholder-img-lg {
          font-size: 3.5rem;
        }
      }

      .b-example-divider {
        width: 100%;
        height: 3rem;
        background-color: #0000001a;
        border: solid rgba(0, 0, 0, 0.15);
        border-width: 0.0625rem 0;
        box-shadow: inset 0 0.5em 1.5em #0000001a, inset 0 0.125em 0.5em #00000026;
      }

      .b-example-vr {
        flex-shrink: 0;
        width: 1.5rem;
        height: 100vh;
      }

      .bi {
        vertical-align: -0.125em;
        fill: currentColor;
      }

      .nav-scroller {
        position: relative;
        z-index: 2;
        height: 2.75rem;
        overflow-y: hidden;
      }

      .nav-scroller .nav {
        display: flex;
        flex-wrap: nowrap;
        padding-bottom: 1rem;
        margin-top: -0.0625rem;
        overflow-x: auto;
        text-align: center;
        white-space: nowrap;
        -webkit-overflow-scrolling: touch;
      }

      .btn-bd-primary {
        --bd-violet-bg: #712cf9;
        --bd-violet-rgb: 112.520718, 44.062154, 249.437846;
        --bs-btn-font-weight: 600;
        --bs-btn-color: var(--bs-white);
        --bs-btn-bg: var(--bd-violet-bg);
        --bs-btn-border-color: var(--bd-violet-bg);
        --bs-btn-hover-color: var(--bs-white);
        --bs-btn-hover-bg: #6528e0;
        --bs-btn-hover-border-color: #6528e0;
        --bs-btn-focus-shadow-rgb: var(--bd-violet-rgb);
        --bs-btn-active-color: var(--bs-btn-hover-color);
        --bs-btn-active-bg: #5a23c8;
        --bs-btn-active-border-color: #5a23c8;
      }

      .bd-mode-toggle {
        z-index: 1500;
      }

      .bd-mode-toggle .bi {
        width: 1em;
        height: 1em;
      }

      .bd-mode-toggle .dropdown-menu .active .bi {
        display: block !important;
      }

      .dropdown-toggle {
        outline: 0;
      }

      .btn-toggle {
        padding: 0.25rem 0.5rem;
        font-weight: 600;
        color: var(--bs-emphasis-color);
        background-color: transparent;
      }

      .btn-toggle:hover,
      .btn-toggle:focus {
        color: rgba(var(--bs-emphasis-color-rgb), 0.85);
        background-color: var(--bs-tertiary-bg);
      }

      .btn-toggle::before {
        width: 1.25em;
        line-height: 0;
        content: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' width='16' height='16' viewBox='0 0 16 16'%3e%3cpath fill='none' stroke='rgba%280,0,0,.5%29' stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M5 14l6-6-6-6'/%3e%3c/svg%3e");
        transition: transform 0.35s ease;
        transform-origin: 0.5em 50%;
      }

      [data-bs-theme="dark"] .btn-toggle::before {
        content: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' width='16' height='16' viewBox='0 0 16 16'%3e%3cpath fill='none' stroke='rgba%28255,255,255,.5%29' stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M5 14l6-6-6-6'/%3e%3c/svg%3e");
      }

      .btn-toggle[aria-expanded="true"] {
        color: rgba(var(--bs-emphasis-color-rgb), 0.85);
      }

      .btn-toggle[aria-expanded="true"]::before {
        transform: rotate(90deg);
      }

      .btn-toggle-nav a {
        padding: 0.1875rem 0.5rem;
        margin-top: 0.125rem;
        margin-left: 1.25rem;
      }

      .btn-toggle-nav a:hover,
      .btn-toggle-nav a:focus {
        background-color: var(--bs-tertiary-bg);
      }

      .scrollarea {
        overflow-y: auto;
      }

      .ticket-card {
      position: relative;
      display: flex;
      align-items: center;
      padding: 0.9rem 1.55rem;
      border-radius: 5rem;
      width: 100%;
      max-width: 100%;
      min-height: 6.75rem;
      font-weight: bold;
      font-size: clamp(1.05rem, 1.2vw + 0.7rem, 2rem);
      color: white;
      gap: 1.15rem;
      border: 1px solid rgba(255, 255, 255, .42);
      box-shadow: 0 1.05rem 2.1rem rgba(15, 23, 42, .16);
      animation: aparecer 0.3s ease-out;
      cursor: pointer;
      overflow: hidden;
      transition: transform .16s ease, box-shadow .16s ease, filter .16s ease;
    }

    .ticket-card:hover {
      transform: translateY(-0.12rem);
      box-shadow: 0 1.35rem 2.6rem rgba(15, 23, 42, .2);
      filter: saturate(1.05);
    }

    .ticket-aberto {
      background: linear-gradient(135deg, #0f9f7a, #2fd37e 55%, #9be15d);
    }

    .ticket-pendente {
      background: linear-gradient(135deg, #b7791f, #f1b82d 55%, #ffe066);
    }

    .ticket-em-andamento {
      background: linear-gradient(135deg, #1557b0, #2686df 55%, #63c7ff);
    }

    .ticket-reaberto {
      background: linear-gradient(135deg, #116149, #16a06d 55%, #58d08a);
    }

      @@keyframes aparecer {
        0% {
          opacity: 0;
          transform: scale(0.2) translateY(-1.25rem);
        }
        100% {
          opacity: 1;
          transform: scale(1) translateY(0);
        }
      }

      .ticket-icon {
        width: 5.35rem;
        height: 5.35rem;
        border-radius: 50%;
        flex-shrink: 0;
        filter: drop-shadow(0 .35rem .55rem rgba(15, 23, 42, .18));
      }

      .ticket-text {
        flex: 1;
        min-width: 0;
        line-height: 1.25;
        white-space: normal;
        overflow-wrap: anywhere;
        word-break: break-word;
      }

      .ticket-comment-alert {
        position: absolute;
        top: 1.28rem;
        right: 1.82rem;
        width: .72rem;
        height: .72rem;
        border-radius: 999px;
        background: #dc3545;
        border: 2px solid rgba(255,255,255,.95);
        box-shadow: 0 .2rem .6rem rgba(15, 23, 42, .25);
        z-index: 2;
      }

      .ticket-number {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 2.15rem;
        height: 2.15rem;
        margin-left: auto;
        padding: 0 .7rem;
        border-radius: 999px;
        background: rgba(255, 255, 255, .94);
        color: #0f172a;
        font-size: .9rem;
        font-weight: 900;
        box-shadow: 0 .25rem .65rem rgba(15, 23, 42, .15);
        flex-shrink: 0;
      }

      #chamados-container {
        display: flex;
        flex-direction: column;
        gap: 1.35rem;
        padding: 1.2rem .85rem 1.5rem 1.2rem;
      }

      #chamados-container > .d-flex.align-items-center {
        width: 100%;
        max-width: 100%;
        padding: 0 1.55rem;
      }

      .logo-img {
        width: 100%; /* Relativo ao container */
        height: auto;
      }

      .user-img {
        width: 2rem; /* 32px / 16 = 2rem */
        height: 2rem;
      }

      .icon-svg {
        width: 1rem; /* 16px / 16 = 1rem */
        height: 1rem;
      }

      .sidebar .nav-link.active .icon-svg {
        color: #111;
        fill: #111;
      }

      .btn-novo-chamado {
        width: 5.35rem;
        height: 5.35rem;
      }

      .btn-novo-chamado img {
        max-width: 100%;
        height: auto;
      }

      .chamado-editor-card {
        border: 1px solid rgba(148, 163, 184, .28);
        border-radius: 1.5rem;
        background: rgba(255, 255, 255, .88);
        box-shadow: 0 1.15rem 2.8rem rgba(15, 23, 42, .12);
        backdrop-filter: blur(10px);
        overflow: hidden;
      }

      .chamado-editor-card .card-body {
        padding: 1rem 1.05rem 1.1rem;
      }

      #formEdicaoChamado {
        margin-top: .65rem !important;
      }

      #formEdicaoChamado .mb-2 {
        margin-bottom: .55rem !important;
      }

      #formEdicaoChamado .row {
        --bs-gutter-x: .65rem;
        --bs-gutter-y: .15rem;
      }

      #formEdicaoChamado .form-label {
        margin-bottom: .22rem;
        color: #475569;
        font-size: .72rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: .02em;
      }

      #formEdicaoChamado .form-control,
      #formEdicaoChamado .form-select {
        border-radius: .95rem;
        border-color: #d8e0ea;
        background-color: rgba(248, 250, 252, .92);
        box-shadow: inset 0 .08rem .16rem rgba(15, 23, 42, .03);
      }

      #formEdicaoChamado .form-control:focus,
      #formEdicaoChamado .form-select:focus {
        border-color: #60a5fa;
        box-shadow: 0 0 0 .18rem rgba(96, 165, 250, .18);
      }

      #formEdicaoChamado textarea.form-control {
        min-height: 4.8rem;
        resize: vertical;
      }

      #formEdicaoChamado .form-text,
      #textoDataCriacao {
        font-size: .78rem;
      }

      #wrapEditPublico {
        display: flex;
        align-items: center;
        gap: .55rem;
        border-radius: 1rem;
        background: rgba(37, 99, 235, .07);
        padding: .65rem .85rem .65rem 3rem;
        min-height: 3.25rem;
        overflow: visible;
      }

      #wrapEditPublico .form-check-input {
        margin-top: 0;
        margin-left: -2.25rem;
        flex-shrink: 0;
      }

      #wrapEditPublico .form-check-label {
        margin: 0;
        line-height: 1.2;
      }

      .comment-list {
        display: flex;
        flex-direction: column;
        gap: 0;
        max-height: 30rem;
        overflow-y: auto;
        padding-left: .45rem;
      }

      .comment-modal-grid {
        display: grid;
        grid-template-columns: minmax(16rem, .9fr) minmax(18rem, 1.1fr);
        gap: 1.25rem;
        align-items: stretch;
      }

      .comment-compose-panel {
        border: 1px solid #e5e7eb;
        border-radius: .8rem;
        background: #f8fafc;
        padding: 1rem;
      }

      .comment-compose-panel textarea {
        min-height: 14rem;
        resize: vertical;
      }

      .comment-timeline-panel {
        border-left: 1px solid #e5e7eb;
        padding-left: 1.25rem;
      }

      .comment-item {
        position: relative;
        padding: 0 0 1rem 1.2rem;
      }

      .comment-item::before {
        content: "";
        position: absolute;
        left: .18rem;
        top: .4rem;
        width: .55rem;
        height: .55rem;
        border-radius: 999px;
        background: #2563eb;
        border: 2px solid #fff;
        box-shadow: 0 0 0 1px #bfdbfe;
      }

      .comment-item::after {
        content: "";
        position: absolute;
        left: .43rem;
        top: 1.05rem;
        bottom: 0;
        width: 1px;
        background: #e5e7eb;
      }

      .comment-item:last-child::after {
        display: none;
      }

      .comment-card {
        border: 1px solid #e2e8f0;
        border-radius: 1rem;
        background: #fff;
        padding: .8rem;
        box-shadow: 0 .45rem 1rem rgba(15, 23, 42, .06);
      }

      .comment-meta {
        display: flex;
        justify-content: space-between;
        gap: .75rem;
        color: #64748b;
        font-size: .78rem;
        margin-bottom: .35rem;
      }

      .comment-author {
        color: #0f172a;
        font-weight: 800;
      }

      .comment-text {
        color: #1f2937;
        white-space: pre-wrap;
        overflow-wrap: anywhere;
      }

      .comment-attachment {
        display: inline-flex;
        margin-top: .65rem;
        border-radius: .85rem;
        overflow: hidden;
        border: 1px solid #dbeafe;
        background: #eff6ff;
      }

      .comment-attachment img {
        display: block;
        max-width: min(100%, 28rem);
        max-height: 16rem;
        object-fit: contain;
      }

      @@media (max-width: 991.98px) {
        .comment-modal-grid {
          grid-template-columns: 1fr;
        }

        .comment-timeline-panel {
          border-left: 0;
          padding-left: 0;
        }
      }

      .chamado-topo {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        grid-template-areas:
          "titulo chamado"
          "meta status";
        column-gap: 1rem;
        row-gap: 0.55rem;
        align-items: center;
        margin-bottom: 0.85rem;
      }

      .chamado-topo-titulos {
        grid-area: titulo;
        min-width: 0;
      }

      .chamado-topo-badges {
        grid-area: chamado;
        display: flex;
        align-items: flex-end;
        flex-shrink: 0;
      }

      .chamado-meta {
        grid-area: meta;
        display: flex;
        flex-wrap: nowrap;
        gap: 0.75rem;
        align-items: center;
        min-height: 2.5rem;
      }

      .chamado-status-topo {
        grid-area: status;
        display: flex;
        justify-content: flex-end;
        align-items: center;
        min-height: 2.5rem;
      }

      .card-title {
        font-size: 1.55rem;
        line-height: 1.1;
        color: #0f172a;
      }

      .meta-inline {
        display: flex;
        align-items: center;
        gap: 0.4rem;
        color: #6c757d;
        font-size: 0.95rem;
      }

      .badge {
        color: #111 !important;
      }

      .badge-chamado-selecionado {
        background: #dbeafe;
        color: #1e3a8a !important;
        border: 1px solid #bfdbfe;
        font-size: .98rem;
        font-weight: 700;
        padding: 0.38rem 0.8rem;
      }

      .meta-badge {
        display: inline-flex;
        align-items: center;
        padding: 0.22rem 0.65rem;
        border-radius: 999px;
        font-size: 0.82rem;
        font-weight: 700;
        line-height: 1.2;
      }

      .badge-status-aberto,
      .badge-status-concluido,
      .badge-status-fechado {
        background: #dcfce7;
        color: #166534;
      }

      .badge-status-emandamento,
      .badge-status-reaberto {
        background: #dbeafe;
        color: #1d4ed8;
      }

      .badge-status-pendente {
        background: #fef3c7;
        color: #92400e;
      }

      .badge-status-cancelado,
      .badge-status-excluido {
        background: #fee2e2;
        color: #b91c1c;
      }

      .badge-permissao-administracao {
        background: #ef4444;
        color: #fff;
      }

      .badge-permissao-tecnico {
        background: #3b82f6;
        color: #fff;
      }

      .badge-permissao-colaborador {
        background: #22c55e;
        color: #fff;
      }

      .badge-permissao-nenhuma {
        background: #6b7280;
        color: #fff;
      }

      @@media (max-width: 1200px) {
        .ticket-card {
          border-radius: 2rem;
        }
      }

      @@media (max-width: 768px) {
        .chamado-topo {
          grid-template-columns: 1fr;
          grid-template-areas:
            "titulo"
            "chamado"
            "meta"
            "status";
        }

        .chamado-topo-badges,
        .chamado-status-topo {
          justify-content: flex-start;
          align-items: flex-start;
        }

        .chamado-meta {
          flex-wrap: wrap;
        }

        .card-title {
          font-size: 1.7rem;
        }
      }

      @@media (max-width: 992px) {
        .ticket-card {
          min-height: 5.5rem;
          padding: 0.75rem 1rem;
          gap: 0.75rem;
        }

        .ticket-icon {
          width: 4rem;
          height: 4rem;
        }

        #chamados-container > .d-flex.align-items-center {
          padding: 0 1rem;
        }

        .btn-novo-chamado {
          width: 4rem;
          height: 4rem;
        }
      }

      @@media (max-width: 768px) {
        .ticket-card {
          min-height: 5rem;
          border-radius: 1.5rem;
        }

        .ticket-icon {
          width: 3.5rem;
          height: 3.5rem;
        }

        .btn-novo-chamado {
          width: 3.5rem;
          height: 3.5rem;
        }
      }
    </style>
  </head>
  <body>
    <svg xmlns="http://www.w3.org/2000/svg" class="d-none">
      <symbol id="check2" viewBox="0 0 16 16">
        <path d="M13.854 3.646a.5.5 0 0 1 0 .708l-7 7a.5.5 0 0 1-.708 0l-3.5-3.5a.5.5 0 1 1 .708-.708L6.5 10.293l6.646-6.647a.5.5 0 0 1 .708 0z"></path>
      </symbol>
      <symbol id="circle-half" viewBox="0 0 16 16">
        <path d="M8 15A7 7 0 1 0 8 1v14zm0 1A8 8 0 1 1 8 0a8 8 0 0 1 0 16z"></path>
      </symbol>
