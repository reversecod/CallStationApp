      <symbol id="sun-fill" viewBox="0 0 16 16">
        <path d="M8 12a4 4 0 1 0 0-8 4 4 0 0 0 0 8zM8 0a.5.5 0 0 1 .5.5v2a.5.5 0 0 1-1 0v-2A.5.5 0 0 1 8 0zm0 13a.5.5 0 0 1 .5.5v2a.5.5 0 0 1-1 0v-2A.5.5 0 0 1 8 13zm8-5a.5.5 0 0 1-.5.5h-2a.5.5 0 0 1 0-1h2a.5.5 0 0 1 .5.5zM3 8a.5.5 0 0 1-.5.5h-2a.5.5 0 0 1 0-1h2A.5.5 0 0 1 3 8zm10.657-5.657a.5.5 0 0 1 0 .707l-1.414 1.415a.5.5 0 1 1-.707-.708l1.414-1.414a.5.5 0 0 1 .707 0zm-9.193 9.193a.5.5 0 0 1 0 .707L3.05 13.657a.5.5 0 0 1-.707-.707l1.414-1.414a.5.5 0 0 1 .707 0zm9.193 2.121a.5.5 0 0 1-.707 0l-1.414-1.414a.5.5 0 0 1 .707-.707l1.414 1.414a.5.5 0 0 1 0 .707zM4.464 4.465a.5.5 0 0 1-.707 0L2.343 3.05a.5.5 0 1 1 .707-.707l1.414 1.414a.5.5 0 0 1 0 .708z"></path>
      </symbol>
    </svg>
    <svg xmlns="http://www.w3.org/2000/svg" class="d-none">
      <symbol id="home" viewBox="0 0 16 16">
        <path d="M8.354 1.146a.5.5 0 0 0-.708 0l-6 6A.5.5 0 0 0 1.5 7.5v7a.5.5 0 0 0 .5.5h4.5a.5.5 0 0 0 .5-.5v-4h2v4a.5.5 0 0 0 .5.5H14a.5.5 0 0 0 .5-.5v-7a.5.5 0 0 0-.146-.354L13 5.793V2.5a.5.5 0 0 0-.5-.5h-1a.5.5 0 0 0-.5.5v1.293L8.354 1.146zM2.5 14V7.707l5.5-5.5 5.5 5.5V14H10v-4a.5.5 0 0 0-.5-.5h-3a.5.5 0 0 0-.5.5v4H2.5z"></path>
      </symbol>
      <symbol id="speedometer2" viewBox="0 0 16 16">
        <path d="M8 4a.5.5 0 0 1 .5.5V6a.5.5 0 0 1-1 0V4.5A.5.5 0 0 1 8 4zM3.732 5.732a.5.5 0 0 1 .707 0l.915.914a.5.5 0 1 1-.708.708l-.914-.915a.5.5 0 0 1 0-.707zM2 10a.5.5 0 0 1 .5-.5h1.586a.5.5 0 0 1 0 1H2.5A.5.5 0 0 1 2 10zm9.5 0a.5.5 0 0 1 .5-.5h1.5a.5.5 0 0 1 0 1H12a.5.5 0 0 1-.5-.5zm.754-4.246a.389.389 0 0 0-.527-.02L7.547 9.31a.91.91 0 1 0 1.302 1.258l3.434-4.297a.389.389 0 0 0-.029-.518z"></path>
        <path fill-rule="evenodd" d="M0 10a8 8 0 1 1 15.547 2.661c-.442 1.253-1.845 1.602-2.932 1.25C11.309 13.488 9.475 13 8 13c-1.474 0-3.31.488-4.615.911-1.087.352-2.49.003-2.932-1.25A7.988 7.988 0 0 1 0 10zm8-7a7 7 0 0 0-6.603 9.329c.203.575.923.876 1.68.63C4.397 12.533 6.358 12 8 12s3.604.532 4.923.96c.757.245 1.477-.056 1.68-.631A7 7 0 0 0 8 3z"></path>
      </symbol>
      <symbol id="table" viewBox="0 0 16 16">
        <path d="M0 2a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V2zm15 2h-4v3h4V4zm0 4h-4v3h4V8zm0 4h-4v3h3a1 1 0 0 0 1-1v-2zm-5 3v-3H6v3h4zm-5 0v-3H1v2a1 1 0 0 0 1 1h3zm-4-4h4V8H1v3zm0-4h4V4H1v3zm5-3v3h4V4H6zm4 4H6v3h4V8z"></path>
      </symbol>
      <symbol id="people-circle" viewBox="0 0 16 16">
        <path d="M11 6a3 3 0 1 1-6 0 3 3 0 0 1 6 0z"></path>
        <path fill-rule="evenodd" d="M0 8a8 8 0 1 1 16 0A8 8 0 0 1 0 8zm8-7a7 7 0 0 0-5.468 11.37C3.242 11.226 4.805 10 8 10s4.757 1.225 5.468 2.37A7 7 0 0 0 8 1z"></path>
      </symbol>
      <symbol id="grid" viewBox="0 0 16 16">
        <path d="M1 2.5A1.5 1.5 0 0 1 2.5 1h3A1.5 1.5 0 0 1 7 2.5v3A1.5 1.5 0 0 1 5.5 7h-3A1.5 1.5 0 0 1 1 5.5v-3zM2.5 2a.5.5 0 0 0-.5.5v3a.5.5 0 0 0 .5.5h3a.5.5 0 0 0 .5-.5v-3a.5.5 0 0 0-.5-.5h-3zm6.5.5A1.5 1.5 0 0 1 10.5 1h3A1.5 1.5 0 0 1 15 2.5v3A1.5 1.5 0 0 1 13.5 7h-3A1.5 1.5 0 0 1 9 5.5v-3zm1.5-.5a.5.5 0 0 0-.5.5v3a.5.5 0 0 0 .5.5h3a.5.5 0 0 0 .5-.5v-3a.5.5 0 0 0-.5-.5h-3zM1 10.5A1.5 1.5 0 0 1 2.5 9h3A1.5 1.5 0 0 1 7 10.5v3A1.5 1.5 0 0 1 5.5 15h-3A1.5 1.5 0 0 1 1 13.5v-3zm1.5-.5a.5.5 0 0 0-.5.5v3a.5.5 0 0 0 .5.5h3a.5.5 0 0 0 .5-.5v-3a.5.5 0 0 0-.5-.5h-3zm6.5.5A1.5 1.5 0 0 1 10.5 9h3a1.5 1.5 0 0 1 1.5 1.5v3a1.5 1.5 0 0 1-1.5 1.5h-3A1.5 1.5 0 0 1 9 13.5v-3zm1.5-.5a.5.5 0 0 0-.5.5v3a.5.5 0 0 0 .5.5h3a.5.5 0 0 0 .5-.5v-3a.5.5 0 0 0-.5-.5h-3z"></path>
      </symbol>
    </svg>
    <main>
        @await Html.PartialAsync("_MenuSidebar", Model, ViewData)

        <div class="content-wrapper">
            <div class="row mt-3">
                <div class="col-12 col-xl-7 mb-3">
                    <div id="chamados-container">
                        @foreach (var chamado in Model.Chamados)
                        {
                            var possuiTitulo = !string.IsNullOrWhiteSpace(chamado.Titulo) &&
                                !string.Equals(chamado.Titulo, "Novo chamado", StringComparison.OrdinalIgnoreCase);
                            var textoTicket = possuiTitulo
                                ? chamado.Titulo
                                : $"Chamado {chamado.NumeroChamadoGrupo}";

                            var classeStatus = chamado.Status switch
                            {
                                StatusChamado.Aberto => "ticket-aberto",
                                StatusChamado.Pendente => "ticket-pendente",
                                StatusChamado.EmAndamento => "ticket-em-andamento",
                                StatusChamado.Reaberto => "ticket-reaberto",
                                _ => "ticket-aberto"
                            };

                            <div class="ticket-card @classeStatus" data-id="@chamado.Id" role="button" draggable="true">
                                @if (chamado.TemComentariosNaoLidos)
                                {
                                    <span class="ticket-comment-alert" data-comment-badge title="Novo comentário"></span>
                                }
                                <img src="~/images/logoticket.png" class="ticket-icon" alt="Ticket" loading="eager" />
                                <span class="ticket-text">
                                    @textoTicket -
                                    <span class="cronometro" data-criado-em="@DateTime.SpecifyKind(chamado.DataCriacao, DateTimeKind.Utc).ToString("yyyy-MM-ddTHH:mm:ss.fffZ")"></span>
                                </span>
                                <span class="ticket-number">#@chamado.NumeroChamadoGrupo</span>
                            </div>
                        }

                        <div class="d-flex align-items-center mt-3">
                            @if (Model.PodeCriarChamado)
                            {
                                <button type="button" id="btnNovoChamado"
                                        class="btn p-0 border-0 rounded-circle shadow-sm btn-novo-chamado">
                                    <img src="~/images/logoticket.png" alt="Novo Ticket"
                                         class="img-fluid rounded-circle" loading="lazy">
                                </button>
                            }

                            <input type="hidden" id="grupoIdAtual" value="@Model.GrupoId" />
                            <input type="hidden" id="serverNowUnixMs" value="@Model.ServerNowUnixMs" />
                            <input type="hidden" id="requestVerificationToken"
                                   value="@Antiforgery.GetAndStoreTokens(HttpContext).RequestToken" />
                        </div>

                        @if (Model.TemPaginaAnterior || Model.TemProximaPagina)
                        {
                            <div class="d-flex justify-content-between align-items-center px-3 pt-2">
                                @if (Model.TemPaginaAnterior)
                                {
                                    <a asp-page="/Menu/Home"
                                       asp-route-grupoId="@Model.GrupoId"
                                       asp-route-page="@(Model.PaginaAtual - 1)"
                                       class="btn btn-outline-secondary btn-sm">
                                        Anterior
                                    </a>
                                }
                                else
                                {
                                    <span></span>
                                }

                                <span class="text-muted small">Página @Model.PaginaAtual</span>

                                @if (Model.TemProximaPagina)
                                {
                                    <a asp-page="/Menu/Home"
                                       asp-route-grupoId="@Model.GrupoId"
                                       asp-route-page="@(Model.PaginaAtual + 1)"
                                       class="btn btn-outline-secondary btn-sm">
                                        Próxima
                                    </a>
                                }
                                else
                                {
                                    <span></span>
                                }
                            </div>
                        }
                    </div>
                </div>

                <div class="col-12 col-xl-5 mb-3">
                    <div class="card chamado-editor-card">
                        <div class="card-body">
                            <div class="chamado-topo">
                                <div class="chamado-topo-titulos">
                                    <h5 class="card-title mb-0">Detalhes do chamado</h5>
                                </div>
                                <div class="chamado-topo-badges">
                                    <span id="chamadoSelecionadoLabel" class="badge badge-chamado-selecionado d-none">
                                        Chamado -
                                    </span>
                                </div>
                                <div id="chamadoMetaInfo" class="chamado-meta d-none">
                                    <div id="chamadoCriadoPorWrap" class="meta-inline d-none">
                                        <span>Criado por</span>
                                        <span id="chamadoCriadoPor" class="meta-badge badge-permissao-nenhuma">-</span>
                                    </div>
                                </div>
                                <div id="chamadoStatusWrap" class="chamado-status-topo d-none">
                                    <span id="chamadoStatusInfo" class="meta-badge badge-status-aberto">-</span>
                                </div>
                            </div>

                            <div id="mensagemSelecioneChamado" class="text-muted">
                                Selecione um chamado na lista ao lado para visualizar e editar.
                            </div>

                            <form id="formEdicaoChamado" class="mt-3 d-none">
                                <input type="hidden" id="editId" />
                                <input type="hidden" id="editGrupoId" />

                                <div class="mb-2" id="wrapEditTitulo">
                                    <label for="editTitulo" class="form-label">Título</label>
                                    <input type="text" class="form-control" id="editTitulo" maxlength="35">
                                </div>

                                <div class="mb-2" id="wrapEditDescricao">
                                    <label for="editDescricao" class="form-label">Descrição</label>
                                    <textarea class="form-control" id="editDescricao" rows="2" maxlength="500"></textarea>
                                </div>

                                <div class="mb-2" id="wrapEditSolucao">
                                    <label for="editSolucao" class="form-label">Solução</label>
                                    <textarea class="form-control" id="editSolucao" rows="2" maxlength="500"></textarea>
                                </div>

                                <div class="mb-2">
                                    <button type="button" class="btn btn-outline-primary" id="btnAbrirComentariosChamado">
                                        Comentarios
                                    </button>
                                </div>

                                <div class="mb-2" id="wrapEditSetorId">
                                    <label for="editSetorId" class="form-label">Setor</label>
                                    <select id="editSetorId" class="form-select">
                                        <option value="">Selecione</option>
                                        @foreach (var setor in Model.SetoresDisponiveis)
                                        {
                                            <option value="@setor.Id">@setor.NomeSetor</option>
                                        }
                                    </select>
                                </div>

                                <div class="row">
                                    <div class="col-md-6 mb-2" id="wrapEditOcorrenciaTipoId">
                                        <label for="editOcorrenciaTipoId" class="form-label">Tipo de Ocorrência</label>
                                        <select id="editOcorrenciaTipoId" class="form-select">
                                            <option value="">Selecione</option>
                                            @foreach (var t in Model.TiposOcorrenciaDisponiveis)
                                            {
                                                <option value="@t.Id">@t.TipoOcorrencia</option>
                                            }
                                        </select>
                                    </div>

                                    <div class="col-md-6 mb-2" id="wrapEditOcorrenciaCategoriaId">
                                        <label for="editOcorrenciaCategoriaId" class="form-label">Categoria</label>
                                        <select id="editOcorrenciaCategoriaId" class="form-select">
                                            <option value="">Selecione o tipo primeiro</option>
                                        </select>
                                    </div>

                                    <div class="col-md-6 mb-2" id="wrapEditOcorrenciaSubcategoriaId">
                                        <label for="editOcorrenciaSubcategoriaId" class="form-label">Subcategoria</label>
                                        <select id="editOcorrenciaSubcategoriaId" class="form-select">
                                            <option value="">Selecione a categoria primeiro</option>
                                        </select>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-6 mb-2" id="wrapEditPrioridade">
                                        <label for="editPrioridade" class="form-label">Prioridade</label>
                                        <select id="editPrioridade" class="form-select">
                                            <option value="">(vazio)</option>
                                            <option value="Baixa">Baixa</option>
                                            <option value="Media">Média</option>
                                            <option value="Alta">Alta</option>
                                            <option value="Critica">Crítica</option>
                                        </select>
                                    </div>

                                    <div class="col-6 mb-2" id="wrapEditCriticidade">
                                        <label for="editCriticidade" class="form-label">Criticidade</label>
                                        <select id="editCriticidade" class="form-select">
                                            <option value="">(vazio)</option>
                                            <option value="Baixa">Baixa</option>
                                            <option value="Media">Média</option>
                                            <option value="Alta">Alta</option>
                                            <option value="Critico">Crítico</option>
                                        </select>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-6 mb-2" id="wrapEditUrgencia">
                                        <label for="editUrgencia" class="form-label">Urgência</label>
                                        <select id="editUrgencia" class="form-select">
                                            <option value="">(vazio)</option>
                                            <option value="NaoUrgente">Não urgente</option>
                                            <option value="PoucaUrgencia">Pouca urgência</option>
                                            <option value="Urgente">Urgente</option>
                                            <option value="Emergencia">Emergência</option>
                                        </select>
                                    </div>

                                    <div class="col-6 mb-2" id="wrapEditStatus">
                                        <label for="editStatus" class="form-label">Status</label>
                                        <select id="editStatus" class="form-select">
                                            <option value="Aberto">Aberto</option>
                                            <option value="EmAndamento">Em andamento</option>
                                            <option value="Pendente">Pendente</option>
                                            <option value="Concluido">Concluído</option>
                                            <option value="Fechado">Fechado</option>
                                            <option value="Reaberto">Reaberto</option>
                                            <option value="Cancelado">Cancelado</option>
                                        </select>
                                    </div>
                                </div>

                                <div class="mb-2">
                                    <label class="form-label">Criado em</label>
                                    <div id="textoDataCriacao" class="form-control-plaintext text-muted">-</div>
                                </div>

                                <div class="row">
                                    <div class="col-6 mb-2" id="wrapEditDataFinalizacao">
                                        <label for="editDataFinalizacao" class="form-label">Finalização</label>
                                        <input type="datetime-local" class="form-control" id="editDataFinalizacao">
                                    </div>

                                    <div class="col-6 mb-2" id="wrapEditPrazoResposta">
                                        <label for="editPrazoResposta" class="form-label">Prazo resposta</label>
                                        <input type="datetime-local" class="form-control" id="editPrazoResposta">
                                    </div>
                                </div>

                                <div class="mb-2" id="wrapEditPrazoConclusao">
                                    <label for="editPrazoConclusao" class="form-label">Prazo conclusão</label>
                                    <input type="datetime-local" class="form-control" id="editPrazoConclusao">
                                </div>

                                <div class="form-check form-switch mb-3" id="wrapEditPublico">
                                    <input class="form-check-input" type="checkbox" id="editPublico">
                                    <label class="form-check-label" for="editPublico">Chamado público</label>
                                </div>

                                <div class="d-flex justify-content-between gap-2">
                                    <button type="button" class="btn btn-outline-danger" id="btnExcluirChamado">
                                        Cancelar chamado
                                    </button>

                                    <div class="d-flex gap-2">
                                        <button type="button" class="btn btn-outline-secondary" id="btnCancelarEdicao">Cancelar</button>
                                        <button type="button" class="btn btn-success" id="btnSalvarEdicao">Salvar</button>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <div class="modal fade" id="modalComentariosChamado" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
            <div class="modal-content chamado-editor-card">
                <div class="modal-header">
                    <h5 class="modal-title">Comentarios do chamado</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" id="comentariosChamadoId" />
                    <div class="comment-modal-grid">
                        <div class="comment-compose-panel">
                            <label for="textoNovoComentarioChamado" class="form-label">Novo comentário</label>
                            <textarea id="textoNovoComentarioChamado" class="form-control mb-2" rows="8" maxlength="500" placeholder="Escreva um comentário..."></textarea>
                            <label for="anexoNovoComentarioChamado" class="form-label">Anexo de imagem</label>
                            <input type="file" class="form-control form-control-sm" id="anexoNovoComentarioChamado" accept="image/*">
                            <div class="form-text">O comentário pode ser somente texto. Formatos permitidos: jpg, png, gif ou webp. Limite de 5 MB.</div>
                            <div class="d-flex justify-content-end mt-3">
                                <button type="button" class="btn btn-primary" id="btnEnviarComentarioChamado">Enviar comentário</button>
                            </div>
                        </div>
                        <div class="comment-timeline-panel">
                            <div id="listaComentariosChamado" class="comment-list">
                                <div class="text-muted small">Carregando comentários...</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="modal fade" id="modalSelecionarListaTarefa" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Escolher lista</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" id="chamadoPendenteTarefaId" />
                    <label class="form-label" for="selectListaTarefaDestino">Lista de destino</label>
                    <select id="selectListaTarefaDestino" class="form-select"></select>
                    <div class="form-text">A tarefa será criada como privada e vinculada ao chamado arrastado.</div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="button" class="btn btn-primary" id="btnConfirmarListaTarefa">Criar tarefa</button>
                </div>
            </div>
        </div>
    </div>

    <script src="~/js/home.js" asp-append-version="true" defer></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/js/bootstrap.bundle.min.js"
            integrity="sha384-ndDqU0Gzau9qJ1lfW4pNLlhNTkCfHzAVBReH9diLvGRem5+R9g2FzA8ZGN954O5Q"
            crossorigin="anonymous"
            defer></script>
</body>
</html>



