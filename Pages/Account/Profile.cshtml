@page
@model CallStationApp.Pages.Account.ProfileModel
@{
    ViewData["Title"] = "Perfil";
    var foto = string.IsNullOrWhiteSpace(Model.FotoUsuario)
        ? Url.Content("~/images/default-user.png")
        : Url.Content(Model.FotoUsuario);
}

<!DOCTYPE html>
<html lang="pt-br" data-bs-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Perfil - CallStation</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <style>
        html {
            min-height: 100vh;
        }

        body {
            min-height: 100vh;
            background: url('@Url.Content("~/images/backgroundloginCS.png")') center/cover no-repeat fixed;
        }

        body::before {
            content: "";
            position: fixed;
            inset: 0;
            background: rgba(0, 0, 0, .55);
            backdrop-filter: blur(2px);
            z-index: 1;
        }

        .profile-wrap {
            position: relative;
            z-index: 3;
            min-height: 100vh;
            padding: 2rem;
        }

        .profile-shell {
            width: 100%;
            max-width: 980px;
            margin: 0 auto;
        }

        .profile-card {
            background: rgba(25, 25, 28, .92);
            border: 1px solid rgba(255, 255, 255, .08);
            border-radius: 16px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, .35);
            backdrop-filter: blur(6px);
        }

        .profile-avatar {
            width: 7rem;
            height: 7rem;
            object-fit: cover;
            border: 3px solid rgba(255, 255, 255, .18);
        }

        .form-label {
            font-weight: 600;
        }

        .form-text {
            color: #9aa0a6;
        }

        .btn {
            border-radius: 12px;
        }

        @@media (max-width: 767.98px) {
            .profile-wrap {
                padding: 1rem;
            }
        }
    </style>
</head>
<body>
<main class="profile-wrap d-flex align-items-center">
    <div class="profile-shell">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <a href="/Menu/Menu" class="link-light text-decoration-none d-inline-flex align-items-center gap-2">
                <i class="bi bi-arrow-left"></i>
                Voltar
            </a>
            <img src="~/images/logocompletobranco.png" alt="CallStation" height="34" />
        </div>

        <form method="post" enctype="multipart/form-data" class="profile-card p-4 p-md-5">
            @Html.AntiForgeryToken()

            <div class="row g-4">
                <div class="col-lg-4">
                    <div class="text-center text-lg-start">
                        <img src="@foto" alt="Foto do perfil" class="profile-avatar rounded-circle mb-3" />
                        <h1 class="h3 mb-1">@Model.NomeCompleto</h1>
                        <div class="text-secondary mb-3">@@@Model.NomeUsuario</div>
                        <div class="small text-secondary">
                            Conta criada em @Model.DataCriacao.ToString("dd/MM/yyyy")
                        </div>
                    </div>
                </div>

                <div class="col-lg-8">
                    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
                    {
                        <div class="alert alert-danger" role="alert">@Model.ErrorMessage</div>
                    }
                    @if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
                    {
                        <div class="alert alert-success" role="alert">@Model.SuccessMessage</div>
                    }

                    <h2 class="h5 mb-3">Informações da conta</h2>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="NomeCompleto" class="form-label">Nome completo</label>
                            <input asp-for="NomeCompleto" class="form-control form-control-lg" maxlength="100" required />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="NomeUsuario" class="form-label">Nome de usuário</label>
                            <input asp-for="NomeUsuario" class="form-control form-control-lg" maxlength="20" required />
                            <div class="form-text">Deve ser único no sistema.</div>
                        </div>
                        <div class="col-md-7">
                            <label asp-for="Email" class="form-label">E-mail</label>
                            <input asp-for="Email" type="email" class="form-control form-control-lg" maxlength="100" />
                        </div>
                        <div class="col-md-5">
                            <label asp-for="FotoPerfil" class="form-label">Foto</label>
                            <input asp-for="FotoPerfil" type="file" class="form-control form-control-lg" accept=".jpg,.jpeg,.png,.webp,image/jpeg,image/png,image/webp" />
                            <div class="form-text">JPG, PNG ou WEBP ate 2 MB.</div>
                        </div>
                    </div>

                    <hr class="my-4" />

                    <h2 class="h5 mb-3">Alterar senha</h2>
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label asp-for="SenhaAtual" class="form-label">Senha atual</label>
                            <input asp-for="SenhaAtual" type="password" class="form-control form-control-lg" autocomplete="current-password" />
                        </div>
                        <div class="col-md-4">
                            <label asp-for="NovaSenha" class="form-label">Nova senha</label>
                            <input asp-for="NovaSenha" type="password" class="form-control form-control-lg" minlength="8" autocomplete="new-password" />
                        </div>
                        <div class="col-md-4">
                            <label asp-for="ConfirmarNovaSenha" class="form-label">Confirmar nova senha</label>
                            <input asp-for="ConfirmarNovaSenha" type="password" class="form-control form-control-lg" minlength="8" autocomplete="new-password" />
                        </div>
                    </div>

                    <div class="d-flex justify-content-end gap-2 mt-4">
                        <a href="/Menu/Menu" class="btn btn-outline-light px-4">Cancelar</a>
                        <button type="submit" class="btn btn-primary px-4">
                            <i class="bi bi-check2 me-1"></i>
                            Salvar perfil
                        </button>
                    </div>
                </div>
            </div>
        </form>
    </div>
</main>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
