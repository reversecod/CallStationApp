@page
@{
    ViewData["Title"] = "Acesso negado";
    var returnUrl = Request.Query["ReturnUrl"].ToString();
}

<!DOCTYPE html>
<html lang="pt-br" data-bs-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>CallStation - Acesso negado</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        body {
            min-height: 100vh;
            background: #f8f9fa;
        }

        .access-box {
            max-width: 560px;
            width: 100%;
        }
    </style>
</head>
<body>
    <main class="min-vh-100 d-flex align-items-center justify-content-center p-3">
        <section class="access-box bg-white border rounded-3 p-4 shadow-sm">
            <div class="alert alert-danger d-flex align-items-start gap-3 mb-4" role="alert">
                <i class="bi bi-exclamation-triangle-fill fs-4" aria-hidden="true"></i>
                <div>
                    <h1 class="h5 mb-1">Você não tem permissão para acessar esta tela.</h1>
                    <p class="mb-0">Caso precise desse acesso, solicite a alteração da sua permissão a um administrador do grupo.</p>
                </div>
            </div>

            @if (!string.IsNullOrWhiteSpace(returnUrl))
            {
                <p class="text-muted small mb-4">Tela solicitada: @returnUrl</p>
            }

            <a asp-page="/Menu/Menu" class="btn btn-danger">
                <i class="bi bi-arrow-left me-2" aria-hidden="true"></i>
                Voltar ao menu
            </a>
        </section>
    </main>
</body>
</html>
