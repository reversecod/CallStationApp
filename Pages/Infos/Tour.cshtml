@page
@model CallStationApp.Pages.Infos.Tour

@{
    Layout = null;
    ViewData["Title"] = "Tour";
}

<!DOCTYPE html>
<html lang="pt-br" data-bs-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Tour</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/tutorial.css" asp-append-version="true">
</head>
<body class="tour-public">
<main>
    <nav class="tour-nav" aria-label="Navegacao principal">
        <a class="tour-brand" asp-page="/Index">CallStation</a>
        <div class="tour-nav-actions">
            <a class="btn btn-sm btn-outline-secondary" asp-page="/Infos/Suporte">Suporte</a>
            <a class="btn btn-sm btn-primary" asp-page="/Auth/Login">Entrar</a>
        </div>
    </nav>

    <div class="tutorial-content">
        <header class="tutorial-header">
            <div>
                <div class="tutorial-kicker">Tour</div>
                <h1>Conheca o CallStation sem alterar seus dados</h1>
                <p>
                    O CallStation centraliza chamados, tarefas, historico e indicadores do grupo. Esta pagina mostra
                    os principais fluxos em exemplos interativos que rodam apenas no navegador.
                </p>
            </div>
            <div class="tutorial-summary" aria-label="Resumo do tour">
                <span><strong>0</strong> gravacoes no banco</span>
                <span><strong>4</strong> demonstracoes</span>
                <span><strong>100%</strong> local</span>
            </div>
        </header>

        <section class="tutorial-section">
            <div class="tutorial-copy">
                <span class="tutorial-step">01</span>
                <h2>Criar e acompanhar chamados</h2>
                <p>
                    Chamados registram uma demanda de atendimento, mostram seu status e ajudam a acompanhar prioridade,
                    comentarios e evolucao. No exemplo, voce cria um mini chamado que aparece como ticket visual.
                </p>
            </div>
            <div class="tutorial-demo" aria-labelledby="demoChamadoTitulo">
                <div class="demo-toolbar">
                    <h3 id="demoChamadoTitulo">Mini chamado</h3>
                    <button type="button" class="btn btn-sm btn-outline-secondary" id="tutorialResetChamado">
                        <i class="bi bi-arrow-counterclockwise" aria-hidden="true"></i>
                        Limpar
                    </button>
                </div>
                <form class="demo-ticket-form" id="tutorialTicketForm" autocomplete="off">
                    <label class="form-label" for="tutorialTicketTitle">Titulo</label>
                    <div class="input-group">
                        <input type="text" class="form-control" id="tutorialTicketTitle" maxlength="70" placeholder="Ex.: Impressora sem papel">
                        <button type="submit" class="btn btn-primary">Criar</button>
                    </div>
                </form>
                <div class="demo-ticket-stage" id="tutorialTicketStage" aria-live="polite">
                    <div class="demo-empty-state">Crie um chamado de exemplo.</div>
                </div>
            </div>
        </section>

        <section class="tutorial-section tutorial-section-alt">
            <div class="tutorial-copy">
                <span class="tutorial-step">02</span>
                <h2>Organizar atividades em tarefas</h2>
                <p>
                    O quadro de tarefas ajuda a transformar chamados em trabalho operacional. As listas indicam o
                    andamento e deixam claro o que esta pendente, em execucao ou concluido.
                </p>
            </div>
            <div class="tutorial-demo">
                <div class="demo-toolbar">
                    <h3>Quadro leve</h3>
                    <button type="button" class="btn btn-sm btn-outline-secondary" id="tutorialMoveTask">
                        <i class="bi bi-arrow-right" aria-hidden="true"></i>
                        Avancar
                    </button>
                </div>
                <div class="demo-board" id="tutorialBoard">
                    <div class="demo-column" data-column="0">
                        <div class="demo-column-title">Pendente</div>
                        <div class="demo-task-card" data-demo-task="true">Conferir dados do chamado</div>
                    </div>
                    <div class="demo-column" data-column="1">
                        <div class="demo-column-title">Em andamento</div>
                    </div>
                    <div class="demo-column" data-column="2">
                        <div class="demo-column-title">Concluido</div>
                    </div>
                </div>
            </div>
        </section>

        <section class="tutorial-section">
            <div class="tutorial-copy">
                <span class="tutorial-step">03</span>
                <h2>Receber sinais importantes</h2>
                <p>
                    Notificacoes e historico reduzem perda de contexto. Voce acompanha eventos relevantes, identifica
                    novas mensagens e consegue voltar ao ponto certo do atendimento.
                </p>
            </div>
            <div class="tutorial-demo">
                <div class="demo-toolbar">
                    <h3>Notificacoes</h3>
                    <button type="button" class="btn btn-sm btn-outline-secondary" id="tutorialAddNotification">
                        <i class="bi bi-bell" aria-hidden="true"></i>
                        Simular
                    </button>
                </div>
                <div class="demo-notification-head">
                    <span class="demo-bell">
                        <i class="bi bi-bell-fill" aria-hidden="true"></i>
                        <span id="tutorialNotificationBadge">0</span>
                    </span>
                    <span>Eventos recentes do chamado</span>
                </div>
                <div class="demo-notification-list" id="tutorialNotificationList" aria-live="polite">
                    <div class="demo-empty-state">Nenhuma notificacao na demo.</div>
                </div>
            </div>
        </section>

        <section class="tutorial-section tutorial-section-alt">
            <div class="tutorial-copy">
                <span class="tutorial-step">04</span>
                <h2>Ajustar a experiencia visual</h2>
                <p>
                    O sistema permite adaptar a leitura da interface. Nesta amostra, os controles afetam apenas o bloco
                    de demonstracao e voltam ao padrao quando a pagina e recarregada.
                </p>
            </div>
            <div class="tutorial-demo">
                <div class="demo-toolbar">
                    <h3>Aparencia local</h3>
                </div>
                <div class="demo-appearance-grid">
                    <label>
                        Fundo da barra
                        <input type="range" class="form-range" id="tutorialSidebarOpacity" min="30" max="100" value="100">
                    </label>
                    <label>
                        Fundo do modal
                        <input type="range" class="form-range" id="tutorialModalOpacity" min="30" max="100" value="100">
                    </label>
                </div>
                <div class="demo-shell" id="tutorialAppearanceShell">
                    <aside>Menu<br><span>Chamados</span><span>Tarefas</span></aside>
                    <div class="demo-modal-preview">
                        <strong>Editar chamado</strong>
                        <input class="form-control form-control-sm" value="Exemplo visual" readonly>
                        <button type="button" class="btn btn-sm btn-success">Salvar</button>
                    </div>
                </div>
            </div>
        </section>
    </div>
</main>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/js/bootstrap.bundle.min.js" defer></script>
<script src="~/js/tutorial.js" asp-append-version="true" defer></script>
</body>
</html>
