        color: var(--grupo-sidebar-active-text) !important;
    }

    .sidebar .icon-svg {
        width: 1.12rem;
        height: 1.12rem;
        font-size: 1.12rem;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        line-height: 1;
        flex-shrink: 0;
        color: currentColor;
        fill: currentColor;
    }

    .sidebar .nav-link.active .icon-svg {
        color: var(--grupo-sidebar-active-text);
        fill: var(--grupo-sidebar-active-text);
    }

    .sidebar .user-img {
        width: 2.25rem;
        height: 2.25rem;
        object-fit: cover;
        flex-shrink: 0;
    }

    .sidebar-profile-toggle {
        position: relative;
        min-width: 0;
        font-size: .98rem;
    }

    .sidebar-profile-row {
        display: flex;
        align-items: center;
        gap: .55rem;
        min-width: 0;
    }

    .sidebar-profile-row .sidebar-profile-toggle {
        flex: 1 1 auto;
    }

    .sidebar .notification-badge {
        min-width: 1.25rem;
        height: 1.25rem;
        padding: 0 .35rem;
        border-radius: 999px;
        font-size: .72rem;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }

    .sidebar-notification-list {
        display: grid;
        gap: .75rem;
        max-height: min(62vh, 32rem);
        overflow-y: auto;
        padding-right: .25rem;
    }

    .sidebar-notification-item {
        border: 1px solid #e5e7eb;
        border-radius: .75rem;
        padding: .85rem;
        background: #f8fafc;
    }

    .sidebar-notification-meta {
        display: flex;
        flex-wrap: wrap;
        gap: .4rem;
        align-items: center;
        color: #64748b;
        font-size: .78rem;
    }

    .sidebar-notification-group-label {
        display: inline-flex;
        align-items: center;
        max-width: 100%;
        border-radius: 999px;
        padding: .12rem .5rem;
        background: var(--sidebar-notification-group-color, #6c757d);
        color: var(--sidebar-notification-group-text, #fff);
        font-size: inherit;
        font-weight: 700;
        line-height: 1.15;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .sidebar-notification-title {
        color: #0f172a;
        font-weight: 700;
        line-height: 1.25;
    }

    .sidebar-notification-message {
        color: #475569;
        font-size: .88rem;
        line-height: 1.35;
        overflow-wrap: anywhere;
    }

    .sidebar-notification-action {
        border-radius: 999px;
        padding: .35rem .75rem;
        font-size: .78rem;
        font-weight: 700;
        line-height: 1;
    }

    .sidebar-notification-unread {
        border: 0;
        background: #dc3545;
        color: #fff;
    }

    .recent-group-button {
        --recent-group-color: #6c757d;
        --recent-group-text: #fff;

        position: relative;
        border: none;
        background: linear-gradient(
            135deg,
            color-mix(in srgb, var(--recent-group-color) 78%, #fff 22%) 0%,
            var(--recent-group-color) 50%,
            color-mix(in srgb, var(--recent-group-color) 82%, #000 18%) 100%
        );
        border-radius: 999px;
        padding: .5rem .95rem;
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: .85rem;
        color: var(--recent-group-text);
        text-align: left;
    }

    .recent-group-open-count {
        position: absolute;
        right: -.32rem;
        top: -.42rem;
        min-width: 1.18rem;
        height: 1.18rem;
        padding: 0 .28rem;
        border-radius: 999px;
        background: #22c55e;
        color: #fff;
        border: 2px solid var(--bs-body-bg);
        box-shadow: 0 .2rem .55rem rgba(15, 23, 42, .22);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: .66rem;
        font-weight: 800;
        line-height: 1;
        font-variant-numeric: tabular-nums;
    }

    .recent-group-main {
        min-width: 0;
        display: inline-flex;
        align-items: center;
        gap: .38rem;
    }

    .recent-group-actions {
        flex-shrink: 0;
        display: inline-flex;
        align-items: center;
        gap: .18rem;
    }

    .recent-group-icon-button {
        border: 0;
        background: transparent;
        color: var(--recent-group-text);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0;
        line-height: 1;
        opacity: .9;
    }

    .recent-group-icon-button:hover,
    .recent-group-icon-button:focus-visible {
        opacity: 1;
        outline: none;
    }

    .recent-group-icon-button.is-pinned {
        color: var(--recent-group-text);
    }

    .recent-group-button:hover {
        filter: brightness(.96);
    }

    .recent-group-button-name {
        min-width: 0;
        overflow: hidden;
        font-size: .86rem;
        font-weight: 700;
        line-height: 1.1;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .recent-group-button-access {
        flex-shrink: 0;
        font-size: .72rem;
        line-height: 1.1;
        opacity: .82;
        white-space: nowrap;
    }

    .sidebar-group-label {
        --sidebar-group-color: #6c757d;
        --sidebar-group-text: #fff;

        display: flex;
        align-items: center;
        justify-content: center;
        width: 100%;
        min-width: 0;
        min-height: 2.75rem;
        padding: .58rem 1.05rem;
        margin: 0 0 1rem;

        border: none;
        border-radius: 999px;
        cursor: pointer;

        background: linear-gradient(
            135deg,
            color-mix(in srgb, var(--sidebar-group-color) 78%, #fff 22%) 0%,
            var(--sidebar-group-color) 48%,
            color-mix(in srgb, var(--sidebar-group-color) 82%, #000 18%) 100%
        );

        box-shadow: none;
    }

    .sidebar-group-label:hover {
        filter: brightness(.96);
    }

    .sidebar-group-label-dot {
        display: none;
    }

    .sidebar-group-label-content {
        min-width: 0;
        line-height: 1.15;
    }

    .sidebar-group-label-caption {
        display: none;
    }

    .sidebar-group-label-name {
        display: block;
        max-width: 100%;
        overflow: hidden;

        color: var(--sidebar-group-text);
        font-size: .94rem;
        font-weight: 700;
        line-height: 1.1;
        letter-spacing: .045em;
        text-align: center;
        text-overflow: ellipsis;
        text-transform: uppercase;
        white-space: nowrap;
    }

    .sidebar-group-label-initial {
        display: none;
        width: 2.45rem;
        height: 2.45rem;
        border-radius: .7rem;
        align-items: center;
        justify-content: center;
        color: var(--sidebar-group-text);
        font-size: 1.02rem;
        font-weight: 800;
        line-height: 1;
        text-transform: uppercase;
    }

    body.sidebar-collapsed .sidebar-brand-row {
        justify-content: center;
    }

    body.sidebar-collapsed .sidebar-brand-link {
        flex: 0 0 auto;
    }

    body.sidebar-collapsed .sidebar-logo-full,
    body.sidebar-collapsed .sidebar-collapse-button,
    body.sidebar-collapsed .sidebar-options-button,
    body.sidebar-collapsed .sidebar-group-label-content,
    body.sidebar-collapsed .sidebar-profile-toggle strong {
        display: none !important;
    }

    body.sidebar-collapsed .sidebar-logo-compact,
    body.sidebar-collapsed .sidebar-group-label-initial,
    body.sidebar-collapsed .sidebar-expand-button {
        display: inline-flex;
    }

    body.sidebar-collapsed .sidebar hr {
        margin: .75rem 0;
    }

    body.sidebar-collapsed .sidebar .nav-link {
        justify-content: center;
        padding-left: .65rem;
        padding-right: .65rem;
        font-size: 0;
    }

    body.sidebar-collapsed .sidebar .icon-svg {
        margin-right: 0 !important;
        font-size: 1.22rem;
    }

    body.sidebar-collapsed .sidebar-group-label {
        min-height: 2.9rem;
        padding: .25rem;
        margin-bottom: .55rem;
    }

    body.sidebar-collapsed .sidebar-profile-area {
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    body.sidebar-collapsed .sidebar-profile-row {
        justify-content: center;
        position: relative;
    }

    body.sidebar-collapsed .sidebar-profile-row .dropdown-menu {
        left: calc(100% + .55rem) !important;
        right: auto !important;
        bottom: 0 !important;
        top: auto !important;
        transform: none !important;
        z-index: 2400;
    }

    body.sidebar-collapsed .sidebar-profile-toggle {
        justify-content: center;
        padding: 0;
    }

    body.sidebar-collapsed .sidebar-profile-toggle::after {
        display: none;
    }

    body.sidebar-collapsed .sidebar-profile-toggle .user-img {
        width: 2.45rem;
        height: 2.45rem;
        margin-right: 0 !important;
    }

    body.sidebar-collapsed #sidebarPerfilNotificacaoIcone {
        position: absolute;
        top: -.1rem;
        right: -.05rem;
        width: .62rem;
        height: .62rem;
        border-radius: 999px;
        border: 2px solid var(--bs-body-bg);
        background: #dc3545;
        color: transparent !important;
        font-size: 0;
        line-height: 1;
        padding: 0;
        margin: 0 !important;
    }

    @@media (max-width: 991.98px) {
        .sidebar {
            position: relative;
            width: 100% !important;
            height: auto;
        }

        .content-wrapper,
        .tasks-content {
            margin-left: 0 !important;
        }

        body.sidebar-collapsed .sidebar {
            position: relative;
        }
    }

    @@media (prefers-reduced-motion: reduce) {
        .sidebar,
        .content-wrapper,
        .sidebar .nav-link,
        .sidebar-collapse-button,
        .sidebar-expand-button {
            transition: none;
        }

        .sidebar-group-label {
            transition: none;
        }

        .sidebar-group-label:hover {
            transform: none;
        }
    }
</style>

<div class="d-flex flex-column flex-shrink-0 p-3 bg-body-tertiary sidebar"
     data-sidebar-grupo-id="@grupoId"
     data-sidebar-contador-url="@Url.Page("/Menu/Notifications", "ContarNaoLidas", new { grupoId })"
     data-sidebar-notificacoes-url="@Url.Page("/Menu/Notifications", "NaoLidas", new { grupoId })"
     data-sidebar-abrir-notificacao-url="@Url.Page("/Menu/Notifications", "AbrirNotificacao", new { grupoId })"
     data-sidebar-marcar-lida-url="@Url.Page("/Menu/Notifications", "MarcarComoLida", new { grupoId })"
     data-sidebar-notificacoes-page-url="@Url.Page("/Menu/Notifications", new { grupoId })"
     data-sidebar-grupos-url="@Url.Page("/Menu/Menu", "ListarGruposRecentes")"
     data-sidebar-acessar-grupo-url="@Url.Page("/Menu/Menu", "AcessarGrupo")"
     data-sidebar-fixar-grupo-url="@Url.Page("/Menu/Menu", "AlternarGrupoFixado")">
    <div class="sidebar-brand-row">
        <a asp-page="/Menu/Menu" class="sidebar-brand-link d-flex align-items-center link-body-emphasis text-decoration-none" aria-label="CallStation">
            <img src="~/images/logocompletopreto.png" alt="Logo CallStation" class="logo-img sidebar-logo-full" loading="lazy">
            <img src="~/images/CallStationLogo.png" alt="CallStation" class="sidebar-logo-compact" loading="lazy">
        </a>
    </div>

    <hr />

    <ul class="nav nav-pills flex-column mb-auto">
        <li class="nav-item">
            <button type="button"
                    class="sidebar-group-label"
                    style="--sidebar-group-color: @corGrupoAtual; --sidebar-group-text: @corTextoGrupoAtual"
                    title="@nomeGrupoAtual"
                    aria-label="Selecionar organização. Grupo atual: @nomeGrupoAtual"
                    data-bs-toggle="modal"
                    data-bs-target="#modalOrganizacoesRecentes">
                <span class="sidebar-group-label-dot" aria-hidden="true"></span>
                <span class="sidebar-group-label-content">
                    <span class="sidebar-group-label-caption">Grupo atual</span>
                    <span class="sidebar-group-label-name">@nomeGrupoAtual</span>
                </span>
                <span class="sidebar-group-label-initial" aria-hidden="true">@inicialGrupoAtual</span>
            </button>
        </li>
        <li class="nav-item">
            <a asp-page="/Menu/Home" asp-route-grupoId="@grupoId" class="@ActiveClass("Home")" aria-current="@(activeMenu == "Home" ? "page" : null)">
                <i class="bi bi-house-door me-2 icon-svg" aria-hidden="true"></i>
                Chamados
            </a>
        </li>
        @if (usuarioLogadoTemPermissaoOperacional)
        {
            <li>
                <a asp-page="/Menu/Tasks"
                   asp-route-grupoId="@grupoId"
                   class="@ActiveClass("Tasks")"
                   aria-current="@(activeMenu == "Tasks" ? "page" : null)"
                   id="navTarefasDrop"
                   data-tasks-url="@Url.Page("/Menu/Tasks", new { grupoId })">
                    <i class="bi bi-table me-2 icon-svg" aria-hidden="true"></i>
                    Tarefas
                </a>
            </li>
            <li>
                <a asp-page="/Menu/Dashboard" asp-route-grupoId="@grupoId" class="@ActiveClass("Dashboard")" aria-current="@(activeMenu == "Dashboard" ? "page" : null)">
                    <i class="bi bi-speedometer2 me-2 icon-svg" aria-hidden="true"></i>
                    Dashboard
                </a>
            </li>
            <li>
                <a asp-page="/Menu/History" asp-route-grupoId="@grupoId" class="@ActiveClass("History")" aria-current="@(activeMenu == "History" ? "page" : null)">
                    <i class="bi bi-grid me-2 icon-svg" aria-hidden="true"></i>
                    Histórico
                </a>
            </li>
        }
        <li>
            <a asp-page="/Menu/Members" asp-route-grupoId="@grupoId" class="@ActiveClass("Members")" aria-current="@(activeMenu == "Members" ? "page" : null)">
                <i class="bi bi-people me-2 icon-svg" aria-hidden="true"></i>
                Membros
            </a>
        </li>
        @if (usuarioLogadoEhAdministrador)
        {
            <li>
                <a asp-page="/Menu/Group" asp-route-grupoId="@grupoId" class="@ActiveClass("Group")" aria-current="@(activeMenu == "Group" ? "page" : null)">
                    <i class="bi bi-sliders2-vertical me-2 icon-svg" aria-hidden="true"></i>
                    Grupo
                </a>
            </li>
        }
    </ul>

    <hr />

    <div class="sidebar-profile-area">
        <button type="button" class="sidebar-expand-button" id="sidebarExpandButton" aria-label="Expandir barra lateral">
            <i class="bi bi-chevron-right" aria-hidden="true"></i>
        </button>
        <div class="sidebar-profile-row dropdown">
            <a href="#" class="sidebar-profile-toggle d-flex align-items-center link-body-emphasis text-decoration-none dropdown-toggle"
               data-bs-toggle="dropdown" aria-expanded="false">
                <img src="@fotoSrc" alt="" class="user-img rounded-circle me-2" loading="lazy">
                <strong>@nomeUsuarioLogado</strong>
                <i class="bi bi-bell-fill text-danger ms-2 d-none" id="sidebarPerfilNotificacaoIcone" aria-label="Nova notificação"></i>
            </a>
            <ul class="dropdown-menu text-small shadow">
            <li>
                <a asp-page="/Menu/Notifications"
                   asp-route-grupoId="@grupoId"
                   id="sidebarAbrirNotificacoes"
                   class="dropdown-item d-flex align-items-center gap-2">
                    <i class="bi bi-bell" aria-hidden="true"></i>
                    <span>Notificações</span>
                    <span class="badge text-bg-danger notification-badge d-none ms-auto" id="sidebarNotificacoesBadge">0</span>
                </a>
            </li>
            <li><hr class="dropdown-divider" /></li>
            <li><a class="dropdown-item" href="#">Configurações</a></li>
            <li><a class="dropdown-item" asp-page="/Account/Profile">Perfil</a></li>
            <li><hr class="dropdown-divider" /></li>
            <li><a class="dropdown-item text-danger" asp-page="/Logout">Sair</a></li>
            </ul>
            <button type="button" class="sidebar-collapse-button" id="sidebarToggleButton" aria-label="Recolher barra lateral" aria-expanded="true">
                <i class="bi bi-layout-sidebar-inset" aria-hidden="true"></i>
            </button>
            <button type="button"
                    class="sidebar-options-button"
                    id="sidebarOptionsButton"
                    data-bs-toggle="modal"
                    data-bs-target="#modalSidebarOpcoes"
                    aria-label="Ajustar transparência">
                <i class="bi bi-three-dots-vertical" aria-hidden="true"></i>
            </button>
        </div>
    </div>
</div>

