@using CallStationApp.Models
@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
@model dynamic
@{
    var activeMenu = ViewData["ActiveMenu"] as string ?? string.Empty;
    var grupoId = Model.GrupoId;
    var nomeUsuarioLogado = Model.NomeUsuarioLogado as string ?? "Usuario";
    var fotoUsuarioLogado = Model.FotoUsuarioLogado as string;
    var fotoSrc = string.IsNullOrWhiteSpace(fotoUsuarioLogado)
        ? Url.Content("~/images/default-user.png")
        : Url.Content(fotoUsuarioLogado);
    var usuarioLogadoEhAdministrador = Model.UsuarioLogadoEhAdministrador;
    var modelObject = (object)Model;
    var permissaoUsuarioLogadoObj = modelObject.GetType().GetProperty("UsuarioLogadoPermissao")?.GetValue(modelObject);
    var permissaoUsuarioLogado = permissaoUsuarioLogadoObj is PermissaoUsuario permissao
        ? permissao
        : usuarioLogadoEhAdministrador
            ? PermissaoUsuario.Administracao
            : PermissaoUsuario.Colaborador;
    var usuarioLogadoTemPermissaoOperacional = permissaoUsuarioLogado != PermissaoUsuario.Nenhuma;
    var grupoAtualObj = modelObject.GetType().GetProperty("GrupoAtual")?.GetValue(modelObject) as Grupo;
    var grupoConfiguracaoObj = modelObject.GetType().GetProperty("Configuracao")?.GetValue(modelObject) as GrupoConfiguracao;
    var nomeGrupoAtual = grupoAtualObj?.Nome ?? "Grupo";
    var inicialGrupoAtual = string.IsNullOrWhiteSpace(nomeGrupoAtual)
        ? "G"
        : nomeGrupoAtual.Trim()[0].ToString().ToUpperInvariant();
    var corGrupoAtual = grupoAtualObj is not null ? CorCss(grupoAtualObj.EtiquetaCor) : "#6c757d";
    var corTextoGrupoAtual = grupoAtualObj?.EtiquetaCor == EtiquetaCor.branco || grupoAtualObj is null ? "#212529" : "#fff";
    var fundoTelaCss = AparenciaBackgroundCss(grupoConfiguracaoObj?.AparenciaTelaTipo, grupoConfiguracaoObj?.AparenciaTelaValor);
    var fundoSidebarCss = AparenciaBackgroundCss(grupoConfiguracaoObj?.AparenciaSidebarTipo, grupoConfiguracaoObj?.AparenciaSidebarValor);
    var corMenuAtivo = EhCorHex(grupoConfiguracaoObj?.AparenciaMenuAtivoCor ?? string.Empty)
        ? grupoConfiguracaoObj!.AparenciaMenuAtivoCor!
        : "#0d6efd";
    var corTextoMenuAtivo = CorTextoContraste(corMenuAtivo);
    var corFundoTextoSidebar = EhCorHex(grupoConfiguracaoObj?.AparenciaSidebarTextoFundoCor ?? string.Empty)
        ? grupoConfiguracaoObj!.AparenciaSidebarTextoFundoCor!
        : null;
    var temFundoTela = !string.IsNullOrWhiteSpace(fundoTelaCss);
    var temFundoSidebar = !string.IsNullOrWhiteSpace(fundoSidebarCss);
    var temFundoTextoSidebar = !string.IsNullOrWhiteSpace(corFundoTextoSidebar);

    string ActiveClass(string menu) =>
        string.Equals(activeMenu, menu, StringComparison.OrdinalIgnoreCase)
            ? "nav-link active"
            : "nav-link link-body-emphasis";

    string CorCss(EtiquetaCor cor) => cor switch
    {
        EtiquetaCor.vermelho => "#ef4444",
        EtiquetaCor.laranja => "#f97316",
        EtiquetaCor.amarelo => "#eab308",
        EtiquetaCor.verde => "#22c55e",
        EtiquetaCor.azul => "#3b82f6",
        EtiquetaCor.roxo => "#a855f7",
        EtiquetaCor.rosa => "#ec4899",
        EtiquetaCor.preto => "#1f2937",
        _ => "#f8f9fa"
    };

    string? AparenciaBackgroundCss(string? tipo, string? valor)
    {
        var tipoNormalizado = (tipo ?? "padrao").Trim().ToLowerInvariant();
        var valorNormalizado = (valor ?? string.Empty).Trim();
        if (tipoNormalizado == "cor" && EhCorHex(valorNormalizado))
            return valorNormalizado;

        if (tipoNormalizado == "upload" &&
            valorNormalizado.StartsWith("/uploads/grupos/backgrounds/", StringComparison.OrdinalIgnoreCase))
        {
            return $"url('{Url.Content(valorNormalizado)}')";
        }

        if (tipoNormalizado == "preset")
        {
            return valorNormalizado.ToLowerInvariant() switch
            {
                "aurora" => "radial-gradient(circle at 18% 18%, rgba(125, 211, 252, .95), transparent 28rem), linear-gradient(135deg, #1d4ed8 0%, #7c3aed 48%, #db2777 100%)",
                "oceano" => "radial-gradient(circle at 80% 14%, rgba(103, 232, 249, .9), transparent 24rem), linear-gradient(135deg, #083344 0%, #0f766e 48%, #38bdf8 100%)",
                "grafite" => "radial-gradient(circle at 22% 18%, rgba(148, 163, 184, .34), transparent 20rem), linear-gradient(135deg, #020617 0%, #334155 56%, #111827 100%)",
                "folha" => "radial-gradient(circle at 80% 18%, rgba(190, 242, 100, .72), transparent 22rem), linear-gradient(135deg, #14532d 0%, #16a34a 48%, #a3e635 100%)",
                "nevoa" => "radial-gradient(circle at 20% 12%, rgba(147, 197, 253, .7), transparent 23rem), linear-gradient(135deg, #e0f2fe 0%, #f8fafc 48%, #ddd6fe 100%)",
                "ameixa" => "radial-gradient(circle at 22% 22%, rgba(244, 114, 182, .72), transparent 22rem), linear-gradient(135deg, #581c87 0%, #be185d 50%, #fb7185 100%)",
                _ => null
            };
        }

        return null;
    }

    bool EhCorHex(string valor) =>
        valor.Length == 7 && valor[0] == '#' && valor.Skip(1).All(Uri.IsHexDigit);

    string CorTextoContraste(string cor)
    {
        if (!EhCorHex(cor))
            return "#fff";

        var r = Convert.ToInt32(cor.Substring(1, 2), 16);
        var g = Convert.ToInt32(cor.Substring(3, 2), 16);
        var b = Convert.ToInt32(cor.Substring(5, 2), 16);
        var luminancia = (0.299 * r + 0.587 * g + 0.114 * b) / 255;
        return luminancia > .62 ? "#111827" : "#fff";
    }
}

<script>
    (function () {
        try {
            const grupoId = "@grupoId";
            const sidebarOpacity = localStorage.getItem(`callstation.sidebar.backgroundOpacity.${grupoId}`);
            const chamadoModalOpacity = localStorage.getItem(`callstation.chamado.modalOpacity.${grupoId}`);

            if (sidebarOpacity !== null) {
                const value = Math.min(100, Math.max(0, Number(sidebarOpacity)));
                if (!Number.isNaN(value)) {
                    document.documentElement.style.setProperty("--grupo-sidebar-bg-opacity", String(value / 100));
                }
            }

            if (chamadoModalOpacity !== null) {
                const value = Math.min(100, Math.max(0, Number(chamadoModalOpacity)));
                if (!Number.isNaN(value)) {
                    const alpha = value / 100;
                    document.documentElement.style.setProperty("--grupo-chamado-modal-opacity", String(alpha));
                    document.documentElement.style.setProperty("--grupo-chamado-modal-bg", `rgba(255, 255, 255, ${alpha})`);
                }
            }

            if (localStorage.getItem("callstation.sidebar.recolhida") === "1") {
                document.body.classList.add("sidebar-collapsed");
            }
            if (@temFundoTela.ToString().ToLowerInvariant()) {
                document.body.classList.add("grupo-aparencia-tela");
            }
            if (@temFundoSidebar.ToString().ToLowerInvariant()) {
                document.body.classList.add("grupo-aparencia-sidebar");
            }
            if (@temFundoTextoSidebar.ToString().ToLowerInvariant()) {
                document.body.classList.add("grupo-aparencia-sidebar-texto-fundo");
            }
        } catch {
        }
    })();
</script>

<style>
    :root {
        @if (temFundoTela)
        {
            @:--grupo-page-background: @Html.Raw(fundoTelaCss);
        }
        @if (temFundoSidebar)
        {
            @:--grupo-sidebar-background: @Html.Raw(fundoSidebarCss);
        }
    }

    body.grupo-aparencia-tela {
        background: var(--grupo-page-background) !important;
        background-attachment: fixed !important;
        background-position: center !important;
        background-size: cover !important;
    }

    body.grupo-aparencia-tela .content-wrapper,
    body.grupo-aparencia-tela .tasks-content,
    body.grupo-aparencia-tela .board,
    body.grupo-aparencia-tela .tasks-header {
        background: transparent !important;
    }

    body.grupo-aparencia-sidebar .sidebar {
        background: transparent !important;
        isolation: isolate;
    }

    body.grupo-aparencia-sidebar .sidebar > * {
        position: relative;
        z-index: 1;
    }

    body.grupo-aparencia-sidebar .sidebar::before {
        background: var(--grupo-sidebar-background) center / cover no-repeat;
    }

    body.grupo-aparencia-sidebar .sidebar .nav-link,
    body.grupo-aparencia-sidebar .sidebar-profile-toggle,
    body.grupo-aparencia-sidebar .sidebar-collapse-button,
    body.grupo-aparencia-sidebar .sidebar-expand-button {
        color: #0f172a;
    }

    body.grupo-aparencia-sidebar .sidebar hr {
        opacity: .18;
    }

    body.grupo-aparencia-sidebar-texto-fundo .sidebar .nav-link:not(.active),
    body.grupo-aparencia-sidebar-texto-fundo .sidebar-profile-toggle,
    body.grupo-aparencia-sidebar-texto-fundo .sidebar-collapse-button,
    body.grupo-aparencia-sidebar-texto-fundo .sidebar-expand-button {
        border-radius: .85rem;
        background: var(--grupo-sidebar-text-bg);
    }

    body.grupo-aparencia-sidebar-texto-fundo .sidebar .nav-link:not(.active) {
        min-height: 2.35rem;
        margin: .12rem 0;
        padding-top: .32rem;
        padding-bottom: .32rem;
    }

    body.grupo-aparencia-sidebar-texto-fundo .sidebar-profile-toggle {
        min-height: 2.95rem;
        padding: .35rem .55rem;
    }

    body.sidebar-collapsed.grupo-aparencia-sidebar-texto-fundo .sidebar-profile-toggle {
        min-width: 3.15rem;
        min-height: 3.15rem;
        padding: .35rem;
    }

    :root {
        --sidebar-expanded-width: 17.5rem;
        --sidebar-collapsed-width: 5.25rem;
        --grupo-sidebar-active-bg: @corMenuAtivo;
        --grupo-sidebar-active-text: @corTextoMenuAtivo;
        --grupo-sidebar-bg-opacity: 1;
        --grupo-chamado-modal-opacity: 1;
        --grupo-chamado-modal-bg: rgba(255, 255, 255, var(--grupo-chamado-modal-opacity));
        --grupo-tarefa-modal-bg: #1f232a;
        @if (temFundoTextoSidebar)
        {
            @:--grupo-sidebar-text-bg: @corFundoTextoSidebar;
        }
    }

    .sidebar {
        width: var(--sidebar-expanded-width);
        isolation: isolate;
        transition: width .22s ease, padding .22s ease;
    }

    .sidebar::before {
        content: "";
        position: absolute;
        inset: 0;
        z-index: 0;
        background: #f8f9fa;
        opacity: var(--grupo-sidebar-bg-opacity);
        pointer-events: none;
        transition: opacity .16s ease, background .16s ease;
    }

    .sidebar > * {
        position: relative;
        z-index: 1;
    }

    .content-wrapper,
    .tasks-content {
        transition: margin-left .22s ease;
    }

    body.sidebar-collapsed .sidebar {
        width: var(--sidebar-collapsed-width) !important;
        padding-left: .75rem !important;
        padding-right: .75rem !important;
        overflow: visible;
    }

    body.sidebar-collapsed .content-wrapper {
        margin-left: var(--sidebar-collapsed-width) !important;
    }

    body.sidebar-collapsed .tasks-content {
        margin-left: var(--sidebar-collapsed-width) !important;
    }

    .sidebar-brand-row {
        display: flex;
        align-items: center;
        gap: .55rem;
        min-height: 3.25rem;
    }

    .sidebar-brand-link {
        min-width: 0;
        flex: 1 1 auto;
    }

    .sidebar-logo-full {
        display: block;
        width: 100%;
        height: auto;
    }

    .sidebar-logo-compact {
        display: none;
        width: 3.35rem;
        height: 3.35rem;
        object-fit: contain;
    }

    .sidebar-collapse-button,
    .sidebar-expand-button,
    .sidebar-options-button {
        border: 0;
        border-radius: .7rem;
        background: transparent;
        color: #64748b;
        width: 2.25rem;
        height: 2.25rem;
        font-size: 1.08rem;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        transition: background-color .18s ease, color .18s ease, transform .18s ease;
    }

    .sidebar-collapse-button:hover,
    .sidebar-expand-button:hover,
    .sidebar-options-button:hover,
    .sidebar-collapse-button:focus-visible,
    .sidebar-expand-button:focus-visible,
    .sidebar-options-button:focus-visible {
        background: #e9ecef;
        color: #0f172a;
        outline: none;
    }

    .sidebar-options-modal .modal-content {
        border: 0;
        border-radius: 1rem;
        box-shadow: 0 1.15rem 2.8rem rgba(15, 23, 42, .16);
    }

    .sidebar-options-control {
        display: grid;
        gap: .45rem;
    }

    .sidebar-options-label {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: .75rem;
        color: #334155;
        font-weight: 700;
    }

    .sidebar-options-label span:last-child {
        color: #64748b;
        font-size: .86rem;
        font-variant-numeric: tabular-nums;
    }

    .sidebar-options-scale {
        display: flex;
        align-items: center;
        justify-content: space-between;
        color: #64748b;
        font-size: .78rem;
        font-weight: 700;
    }

    .sidebar-expand-button {
        display: none;
        margin: 0 auto .65rem;
    }

    .sidebar .nav-link {
        display: flex;
        align-items: center;
        min-height: 2.65rem;
        font-size: .98rem;
        font-weight: 600;
        overflow: hidden;
        white-space: nowrap;
        transition: justify-content .22s ease, padding .22s ease;
    }

    .sidebar .nav-link.active {
