@using CallStationApp.Models
@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
@model dynamic
@{
    var activeMenu = ViewData["ActiveMenu"] as string ?? string.Empty;
    var grupoId = Model.GrupoId;
    var nomeUsuarioLogado = Model.NomeUsuarioLogado as string ?? "Usuario";
    var fotoUsuarioLogado = Model.FotoUsuarioLogado as string;
    var fotoSrc = string.IsNullOrWhiteSpace(fotoUsuarioLogado)
        ? Url.Content("~/images/default-user.png")
        : Url.Content(fotoUsuarioLogado);
    var usuarioLogadoEhAdministrador = Model.UsuarioLogadoEhAdministrador;
    var modelObject = (object)Model;
    var permissaoUsuarioLogadoObj = modelObject.GetType().GetProperty("UsuarioLogadoPermissao")?.GetValue(modelObject);
    var permissaoUsuarioLogado = permissaoUsuarioLogadoObj is PermissaoUsuario permissao
        ? permissao
        : usuarioLogadoEhAdministrador
            ? PermissaoUsuario.Administracao
            : PermissaoUsuario.Colaborador;
    var usuarioLogadoTemPermissaoOperacional = permissaoUsuarioLogado != PermissaoUsuario.Nenhuma;
    var grupoAtualObj = modelObject.GetType().GetProperty("GrupoAtual")?.GetValue(modelObject) as Grupo;
    var nomeGrupoAtual = grupoAtualObj?.Nome ?? "Grupo";
    var corGrupoAtual = grupoAtualObj is not null ? CorCss(grupoAtualObj.EtiquetaCor) : "#6c757d";
    var corTextoGrupoAtual = grupoAtualObj?.EtiquetaCor == EtiquetaCor.branco || grupoAtualObj is null ? "#212529" : "#fff";

    string ActiveClass(string menu) =>
        string.Equals(activeMenu, menu, StringComparison.OrdinalIgnoreCase)
            ? "nav-link active"
            : "nav-link link-body-emphasis";

    string CorCss(EtiquetaCor cor) => cor switch
    {
        EtiquetaCor.vermelho => "#ef4444",
        EtiquetaCor.laranja => "#f97316",
        EtiquetaCor.amarelo => "#eab308",
        EtiquetaCor.verde => "#22c55e",
        EtiquetaCor.azul => "#3b82f6",
        EtiquetaCor.roxo => "#a855f7",
        EtiquetaCor.rosa => "#ec4899",
        EtiquetaCor.preto => "#1f2937",
        _ => "#f8f9fa"
    };
}

<style>
    .sidebar .nav-link {
        display: flex;
        align-items: center;
    }

    .sidebar .icon-svg {
        width: 1rem;
        height: 1rem;
        font-size: 1rem;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        line-height: 1;
        flex-shrink: 0;
        color: currentColor;
        fill: currentColor;
    }

    .sidebar .nav-link.active .icon-svg {
        color: #111;
        fill: #111;
    }

    .sidebar .user-img {
        width: 2rem;
        height: 2rem;
        object-fit: cover;
        flex-shrink: 0;
    }

    .sidebar .notification-badge {
        min-width: 1.25rem;
        height: 1.25rem;
        padding: 0 .35rem;
        border-radius: 999px;
        font-size: .72rem;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }

    .sidebar-notification-list {
        display: grid;
        gap: .75rem;
        max-height: min(62vh, 32rem);
        overflow-y: auto;
        padding-right: .25rem;
    }

    .sidebar-notification-item {
        border: 1px solid #e5e7eb;
        border-radius: .75rem;
        padding: .85rem;
        background: #f8fafc;
    }

    .sidebar-notification-meta {
        display: flex;
        flex-wrap: wrap;
        gap: .4rem;
        align-items: center;
        color: #64748b;
        font-size: .78rem;
    }

    .sidebar-notification-group-label {
        display: inline-flex;
        align-items: center;
        max-width: 100%;
        border-radius: 999px;
        padding: .12rem .5rem;
        background: var(--sidebar-notification-group-color, #6c757d);
        color: var(--sidebar-notification-group-text, #fff);
        font-size: inherit;
        font-weight: 700;
        line-height: 1.15;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .sidebar-notification-title {
        color: #0f172a;
        font-weight: 700;
        line-height: 1.25;
    }

    .sidebar-notification-message {
        color: #475569;
        font-size: .88rem;
        line-height: 1.35;
        overflow-wrap: anywhere;
    }

    .sidebar-notification-action {
        border-radius: 999px;
        padding: .35rem .75rem;
        font-size: .78rem;
        font-weight: 700;
        line-height: 1;
    }

    .sidebar-notification-unread {
        border: 0;
        background: #dc3545;
        color: #fff;
    }

    .recent-group-button {
        --recent-group-color: #6c757d;
        --recent-group-text: #fff;

        position: relative;
        border: none;
        background: linear-gradient(
            135deg,
            color-mix(in srgb, var(--recent-group-color) 78%, #fff 22%) 0%,
            var(--recent-group-color) 50%,
            color-mix(in srgb, var(--recent-group-color) 82%, #000 18%) 100%
        );
        border-radius: 999px;
        padding: .5rem .95rem;
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: .85rem;
        color: var(--recent-group-text);
        text-align: left;
    }

    .recent-group-open-count {
        position: absolute;
        right: -.32rem;
        top: -.42rem;
        min-width: 1.18rem;
        height: 1.18rem;
        padding: 0 .28rem;
        border-radius: 999px;
        background: #22c55e;
        color: #fff;
        border: 2px solid var(--bs-body-bg);
        box-shadow: 0 .2rem .55rem rgba(15, 23, 42, .22);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: .66rem;
        font-weight: 800;
        line-height: 1;
        font-variant-numeric: tabular-nums;
    }

    .recent-group-main {
        min-width: 0;
        display: inline-flex;
        align-items: center;
        gap: .38rem;
    }

    .recent-group-actions {
        flex-shrink: 0;
        display: inline-flex;
        align-items: center;
        gap: .18rem;
    }

    .recent-group-icon-button {
        border: 0;
        background: transparent;
        color: var(--recent-group-text);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0;
        line-height: 1;
        opacity: .9;
    }

    .recent-group-icon-button:hover,
    .recent-group-icon-button:focus-visible {
        opacity: 1;
        outline: none;
    }

    .recent-group-icon-button.is-pinned {
        color: var(--recent-group-text);
    }

    .recent-group-button:hover {
        filter: brightness(.96);
    }

    .recent-group-button-name {
        min-width: 0;
        overflow: hidden;
        font-size: .86rem;
        font-weight: 700;
        line-height: 1.1;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .recent-group-button-access {
        flex-shrink: 0;
        font-size: .72rem;
        line-height: 1.1;
        opacity: .82;
        white-space: nowrap;
    }

    .sidebar-group-label {
        --sidebar-group-color: #6c757d;
        --sidebar-group-text: #fff;

        display: flex;
        align-items: center;
        justify-content: center;
        width: 100%;
        min-width: 0;
        min-height: 2.45rem;
        padding: .48rem 1rem;
        margin: 0 0 .9rem;

        border: none;
        border-radius: 999px;
        cursor: pointer;

        background: linear-gradient(
            135deg,
            color-mix(in srgb, var(--sidebar-group-color) 78%, #fff 22%) 0%,
            var(--sidebar-group-color) 48%,
            color-mix(in srgb, var(--sidebar-group-color) 82%, #000 18%) 100%
        );

        box-shadow: none;
    }

    .sidebar-group-label:hover {
        filter: brightness(.96);
    }

    .sidebar-group-label-dot {
        display: none;
    }

    .sidebar-group-label-content {
        min-width: 0;
        line-height: 1.15;
    }

    .sidebar-group-label-caption {
        display: none;
    }

    .sidebar-group-label-name {
        display: block;
        max-width: 100%;
        overflow: hidden;

        color: var(--sidebar-group-text);
        font-size: .86rem;
        font-weight: 700;
        line-height: 1.1;
        letter-spacing: .045em;
        text-align: center;
        text-overflow: ellipsis;
        text-transform: uppercase;
        white-space: nowrap;
    }

    @@media (prefers-reduced-motion: reduce) {
        .sidebar-group-label {
            transition: none;
        }

        .sidebar-group-label:hover {
            transform: none;
        }
    }
</style>

<div class="d-flex flex-column flex-shrink-0 p-3 bg-body-tertiary sidebar"
     data-sidebar-grupo-id="@grupoId"
     data-sidebar-contador-url="@Url.Page("/Menu/Notifications", "ContarNaoLidas", new { grupoId })"
     data-sidebar-notificacoes-url="@Url.Page("/Menu/Notifications", "NaoLidas", new { grupoId })"
     data-sidebar-abrir-notificacao-url="@Url.Page("/Menu/Notifications", "AbrirNotificacao", new { grupoId })"
     data-sidebar-marcar-lida-url="@Url.Page("/Menu/Notifications", "MarcarComoLida", new { grupoId })"
     data-sidebar-notificacoes-page-url="@Url.Page("/Menu/Notifications", new { grupoId })"
     data-sidebar-grupos-url="@Url.Page("/Menu/Menu", "ListarGruposRecentes")"
     data-sidebar-acessar-grupo-url="@Url.Page("/Menu/Menu", "AcessarGrupo")"
     data-sidebar-fixar-grupo-url="@Url.Page("/Menu/Menu", "AlternarGrupoFixado")">
    <a asp-page="/Menu/Menu" class="d-flex align-items-center mb-3 mb-md-0 me-md-auto link-body-emphasis text-decoration-none">
        <img src="~/images/logocompletopreto.png" alt="Logo" class="logo-img me-2" loading="lazy">
    </a>

    <hr />

    <ul class="nav nav-pills flex-column mb-auto">
        <li class="nav-item">
            <button type="button"
                    class="sidebar-group-label"
                    style="--sidebar-group-color: @corGrupoAtual; --sidebar-group-text: @corTextoGrupoAtual"
                    title="@nomeGrupoAtual"
                    aria-label="Selecionar organização. Grupo atual: @nomeGrupoAtual"
                    data-bs-toggle="modal"
                    data-bs-target="#modalOrganizacoesRecentes">
                <span class="sidebar-group-label-dot" aria-hidden="true"></span>
                <span class="sidebar-group-label-content">
                    <span class="sidebar-group-label-caption">Grupo atual</span>
                    <span class="sidebar-group-label-name">@nomeGrupoAtual</span>
                </span>
            </button>
        </li>
        <li class="nav-item">
            <a asp-page="/Menu/Home" asp-route-grupoId="@grupoId" class="@ActiveClass("Home")" aria-current="@(activeMenu == "Home" ? "page" : null)">
                <i class="bi bi-house-door me-2 icon-svg" aria-hidden="true"></i>
                Chamados
            </a>
        </li>
        @if (usuarioLogadoTemPermissaoOperacional)
        {
            <li>
                <a asp-page="/Menu/Tasks"
                   asp-route-grupoId="@grupoId"
                   class="@ActiveClass("Tasks")"
                   aria-current="@(activeMenu == "Tasks" ? "page" : null)"
                   id="navTarefasDrop"
                   data-tasks-url="@Url.Page("/Menu/Tasks", new { grupoId })">
                    <i class="bi bi-table me-2 icon-svg" aria-hidden="true"></i>
                    Tarefas
                </a>
            </li>
            <li>
                <a asp-page="/Menu/Dashboard" asp-route-grupoId="@grupoId" class="@ActiveClass("Dashboard")" aria-current="@(activeMenu == "Dashboard" ? "page" : null)">
                    <i class="bi bi-speedometer2 me-2 icon-svg" aria-hidden="true"></i>
                    Dashboard
                </a>
            </li>
            <li>
                <a asp-page="/Menu/History" asp-route-grupoId="@grupoId" class="@ActiveClass("History")" aria-current="@(activeMenu == "History" ? "page" : null)">
                    <i class="bi bi-grid me-2 icon-svg" aria-hidden="true"></i>
                    Histórico
                </a>
            </li>
        }
        <li>
            <a asp-page="/Menu/Members" asp-route-grupoId="@grupoId" class="@ActiveClass("Members")" aria-current="@(activeMenu == "Members" ? "page" : null)">
                <i class="bi bi-people me-2 icon-svg" aria-hidden="true"></i>
                Membros
            </a>
        </li>
        @if (usuarioLogadoEhAdministrador)
        {
            <li>
                <a asp-page="/Menu/Group" asp-route-grupoId="@grupoId" class="nav-link link-body-emphasis">
                    <i class="bi bi-sliders2-vertical me-2 icon-svg" aria-hidden="true"></i>
                    Grupo
                </a>
            </li>
        }
    </ul>

    <hr />

    <div class="dropdown">
        <a href="#" class="d-flex align-items-center link-body-emphasis text-decoration-none dropdown-toggle"
           data-bs-toggle="dropdown" aria-expanded="false">
            <img src="@fotoSrc" alt="" class="user-img rounded-circle me-2" loading="lazy">
            <strong>@nomeUsuarioLogado</strong>
            <i class="bi bi-bell-fill text-danger ms-2 d-none" id="sidebarPerfilNotificacaoIcone" aria-label="Nova notificação"></i>
        </a>
        <ul class="dropdown-menu text-small shadow">
            <li>
                <a asp-page="/Menu/Notifications"
                   asp-route-grupoId="@grupoId"
                   id="sidebarAbrirNotificacoes"
                   class="dropdown-item d-flex align-items-center gap-2">
                    <i class="bi bi-bell" aria-hidden="true"></i>
                    <span>Notificações</span>
                    <span class="badge text-bg-danger notification-badge d-none ms-auto" id="sidebarNotificacoesBadge">0</span>
                </a>
            </li>
            <li><hr class="dropdown-divider" /></li>
            <li><a class="dropdown-item" href="#">Configurações</a></li>
            <li><a class="dropdown-item" asp-page="/Account/Profile">Perfil</a></li>
            <li><hr class="dropdown-divider" /></li>
            <li><a class="dropdown-item text-danger" asp-page="/Logout">Sair</a></li>
        </ul>
    </div>
</div>

<div class="modal fade" id="modalSidebarNotificacoes" tabindex="-1" aria-labelledby="modalSidebarNotificacoesLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content border-0">
            <div class="modal-header">
                <h5 class="modal-title" id="modalSidebarNotificacoesLabel">Notificações não lidas</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fechar"></button>
            </div>
            <div class="modal-body">
                <div id="listaSidebarNotificacoes" class="sidebar-notification-list">
                    <div class="text-muted small">Carregando notificações...</div>
                </div>
            </div>
            <div class="modal-footer justify-content-between">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Fechar</button>
                <a class="btn btn-primary" id="btnAbrirTelaNotificacoesSidebar" href="@Url.Page("/Menu/Notifications", new { grupoId })">
                    Abrir tela de notificações
                </a>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="modalOrganizacoesRecentes" tabindex="-1" aria-labelledby="modalOrganizacoesRecentesLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content border-0">
            <div class="modal-header">
                <h5 class="modal-title" id="modalOrganizacoesRecentesLabel">Organização</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fechar"></button>
            </div>
            <div class="modal-body">
                <div id="listaOrganizacoesRecentes" class="d-grid gap-2">
                    <div class="text-muted small">Carregando organizações...</div>
                </div>
            </div>
        </div>
    </div>
</div>

<input type="hidden"
       id="requestVerificationTokenSidebar"
       value="@(Antiforgery.GetAndStoreTokens(Context).RequestToken)" />

<script>
    (function () {
        const sidebar = document.querySelector(".sidebar[data-sidebar-grupo-id]");
        if (!sidebar) {
            return;
        }

        const badge = document.getElementById("sidebarNotificacoesBadge");
        const perfilNotificacaoIcone = document.getElementById("sidebarPerfilNotificacaoIcone");
        const linkNotificacoes = document.getElementById("sidebarAbrirNotificacoes");
        const modalNotificacoesElement = document.getElementById("modalSidebarNotificacoes");
        const listaNotificacoes = document.getElementById("listaSidebarNotificacoes");
        const btnAbrirTelaNotificacoes = document.getElementById("btnAbrirTelaNotificacoesSidebar");
        const tokenSidebar = document.getElementById("requestVerificationTokenSidebar")?.value || "";
        const listaOrganizacoes = document.getElementById("listaOrganizacoesRecentes");
        const modalOrganizacoes = document.getElementById("modalOrganizacoesRecentes");
        let organizacoesCarregadas = false;
        let notificacoesAlteradas = false;

        function escapeSidebarHtml(value) {
            return String(value ?? "")
                .replace(/&/g, "&amp;")
                .replace(/</g, "&lt;")
                .replace(/>/g, "&gt;")
                .replace(/"/g, "&quot;")
                .replace(/'/g, "&#039;");
        }

        function formatSidebarDateTime(value) {
            if (!value) {
                return "Sem acesso recente";
            }

            const data = new Date(value);
            if (Number.isNaN(data.getTime())) {
                return "Sem acesso recente";
            }

            return data.toLocaleString("pt-BR", {
                day: "2-digit",
                month: "2-digit",
                year: "numeric",
                hour: "2-digit",
                minute: "2-digit"
            });
        }

        function getSidebarGroupColor(value) {
            const normalized = String(value ?? "").trim().toLowerCase();
            const colors = {
                "0": "#e5e7eb",
                "1": "#ef4444",
                "2": "#f97316",
                "3": "#eab308",
                "4": "#22c55e",
                "5": "#3b82f6",
                "6": "#a855f7",
                "7": "#ec4899",
                "8": "#1f2937",
                branco: "#e5e7eb",
                vermelho: "#ef4444",
                laranja: "#f97316",
                amarelo: "#eab308",
                verde: "#22c55e",
                azul: "#3b82f6",
                roxo: "#a855f7",
                rosa: "#ec4899",
                preto: "#1f2937"
            };

            return colors[normalized] || "#6c757d";
        }

        function getSidebarGroupTextColor(value) {
            const normalized = String(value ?? "").trim().toLowerCase();
            return normalized === "0" || normalized === "branco" ? "#212529" : "#fff";
        }

        async function carregarContadorNotificacoes() {
            const url = sidebar.dataset.sidebarContadorUrl;
            if (!url || !badge) {
                return;
            }

            try {
                const response = await fetch(url, { headers: { "Accept": "application/json" } });
                const data = await response.json();

                if (!response.ok || !data.success) {
                    return;
                }

                const total = Number(data.dados?.totalNaoLidas || 0);
                if (total > 0) {
                    badge.textContent = total > 9 ? "9+" : String(total);
                    badge.classList.remove("d-none");
                    perfilNotificacaoIcone?.classList.remove("d-none");
                } else {
                    badge.textContent = "0";
                    badge.classList.add("d-none");
                    perfilNotificacaoIcone?.classList.add("d-none");
                }
            } catch {
                badge.classList.add("d-none");
                perfilNotificacaoIcone?.classList.add("d-none");
            }
        }

        async function enviarSidebarJson(url, body) {
            const response = await fetch(url, {
                method: "POST",
                headers: {
                    "Accept": "application/json",
                    "Content-Type": "application/json",
                    "RequestVerificationToken": tokenSidebar
                },
                body: JSON.stringify(body || {})
            });
            const data = await response.json().catch(() => null);
            if (!response.ok || !data?.success) {
                throw new Error(data?.message || "Não foi possível concluir a ação.");
            }
            return data;
        }

        function atualizarIndicadorNotificacoes(total) {
            const valor = Number(total || 0);
            if (valor > 0) {
                if (badge) {
                    badge.textContent = valor > 9 ? "9+" : String(valor);
                    badge.classList.remove("d-none");
                }
                perfilNotificacaoIcone?.classList.remove("d-none");
                return;
            }

            if (badge) {
                badge.textContent = "0";
                badge.classList.add("d-none");
            }
            perfilNotificacaoIcone?.classList.add("d-none");
        }

        function renderizarNotificacoesSidebar(notificacoes) {
            if (!listaNotificacoes) {
                return;
            }

            if (!notificacoes.length) {
                listaNotificacoes.innerHTML = `
                    <div class="text-center text-muted p-4">
                        <i class="bi bi-bell-slash fs-2 d-block mb-2"></i>
                        Nenhuma notificação não lida.
                    </div>`;
                return;
            }

            listaNotificacoes.innerHTML = notificacoes.map(notificacao => {
                const corGrupo = getSidebarGroupColor(notificacao.etiquetaCor);
                const corTextoGrupo = getSidebarGroupTextColor(notificacao.etiquetaCor);

                return `
                <div class="sidebar-notification-item" data-sidebar-notificacao-id="${Number(notificacao.id || 0)}">
                    <div class="sidebar-notification-meta mb-1">
                        <span>${escapeSidebarHtml(notificacao.tipo || "Notificação")}</span>
                        ${notificacao.nomeGrupo ? `<span>Grupo:</span><span class="sidebar-notification-group-label" style="--sidebar-notification-group-color: ${escapeSidebarHtml(corGrupo)}; --sidebar-notification-group-text: ${escapeSidebarHtml(corTextoGrupo)};">${escapeSidebarHtml(notificacao.nomeGrupo)}</span>` : ""}
                        <span>${escapeSidebarHtml(notificacao.dataCriacaoTexto || "")}</span>
                    </div>
                    <div class="sidebar-notification-title mb-1">${escapeSidebarHtml(notificacao.titulo || "Notificação")}</div>
                    <div class="sidebar-notification-message mb-3">${escapeSidebarHtml(notificacao.mensagem || "")}</div>
                    <div class="d-flex flex-wrap gap-2">
                        <button type="button" class="btn btn-sm btn-primary sidebar-notification-action" data-sidebar-ir-notificacao="${Number(notificacao.id || 0)}">
                            Ir até
                        </button>
                        <button type="button" class="btn btn-sm sidebar-notification-action sidebar-notification-unread" data-sidebar-marcar-lida="${Number(notificacao.id || 0)}">
                            Não lida
                        </button>
                    </div>
                </div>
            `;
            }).join("");

            listaNotificacoes.querySelectorAll("[data-sidebar-ir-notificacao]").forEach(botao => {
                botao.addEventListener("click", () => abrirNotificacaoSidebar(Number(botao.dataset.sidebarIrNotificacao || 0)));
            });

            listaNotificacoes.querySelectorAll("[data-sidebar-marcar-lida]").forEach(botao => {
                botao.addEventListener("click", () => marcarNotificacaoSidebarComoLida(Number(botao.dataset.sidebarMarcarLida || 0)));
            });
        }

        async function carregarNotificacoesSidebar() {
            const url = sidebar.dataset.sidebarNotificacoesUrl;
            if (!url || !listaNotificacoes) {
                return;
            }

            listaNotificacoes.innerHTML = '<div class="text-muted small">Carregando notificações...</div>';

            try {
                const response = await fetch(url, { headers: { "Accept": "application/json" } });
                const data = await response.json();
                if (!response.ok || !data.success) {
                    throw new Error(data.message || "Não foi possível carregar as notificações.");
                }

                const notificacoes = data.dados?.notificacoes || [];
                renderizarNotificacoesSidebar(notificacoes);
                atualizarIndicadorNotificacoes(data.dados?.totalNaoLidas || notificacoes.length);
            } catch (error) {
                listaNotificacoes.innerHTML = `<div class="text-danger small">${escapeSidebarHtml(error.message || "Não foi possível carregar as notificações.")}</div>`;
            }
        }

        function abrirModalNotificacoesSidebar() {
            const modalNotificacoes = modalNotificacoesElement && window.bootstrap
                ? bootstrap.Modal.getOrCreateInstance(modalNotificacoesElement)
                : null;

            if (!modalNotificacoes) {
                window.location.href = sidebar.dataset.sidebarNotificacoesPageUrl || linkNotificacoes?.href || "/Menu/Notifications";
                return;
            }

            carregarNotificacoesSidebar();
            modalNotificacoes.show();
        }

        async function abrirNotificacaoSidebar(notificacaoId) {
            const url = sidebar.dataset.sidebarAbrirNotificacaoUrl;
            if (!url || !notificacaoId) {
                return;
            }

            try {
                const data = await enviarSidebarJson(url, { notificacaoId });
                window.location.href = data.destino || sidebar.dataset.sidebarNotificacoesPageUrl || linkNotificacoes?.href || "/Menu/Notifications";
            } catch (error) {
                alert(error.message || "Não foi possível abrir a notificação.");
            }
        }

        async function marcarNotificacaoSidebarComoLida(notificacaoId) {
            const url = sidebar.dataset.sidebarMarcarLidaUrl;
            if (!url || !notificacaoId) {
                return;
            }

            try {
                const data = await enviarSidebarJson(url, { notificacaoId });
                notificacoesAlteradas = true;
                listaNotificacoes?.querySelector(`[data-sidebar-notificacao-id="${notificacaoId}"]`)?.remove();
                atualizarIndicadorNotificacoes(data.totalNaoLidas || 0);

                if (!listaNotificacoes?.querySelector("[data-sidebar-notificacao-id]")) {
                    renderizarNotificacoesSidebar([]);
                }
            } catch (error) {
                alert(error.message || "Não foi possível marcar a notificação como lida.");
            }
        }

        async function carregarOrganizacoesRecentes() {
            if (!listaOrganizacoes || organizacoesCarregadas) {
                return;
            }

            const url = sidebar.dataset.sidebarGruposUrl;
            if (!url) {
                return;
            }

            listaOrganizacoes.innerHTML = '<div class="text-muted small">Carregando organizações...</div>';

            try {
                const response = await fetch(url, { headers: { "Accept": "application/json" } });
                const data = await response.json();

                if (!response.ok || !data.success) {
                    listaOrganizacoes.innerHTML = `<div class="text-danger small">${escapeSidebarHtml(data.message || "Não foi possível carregar as organizações.")}</div>`;
                    return;
                }

                const grupos = data.dados?.grupos || [];
                if (!grupos.length) {
                    listaOrganizacoes.innerHTML = '<div class="text-muted small">Você ainda não acessou organizações recentemente.</div>';
                    organizacoesCarregadas = true;
                    return;
                }

                listaOrganizacoes.innerHTML = grupos.map(grupo => `
                    <button type="button"
                            class="recent-group-button"
                            data-grupo-id="${escapeSidebarHtml(grupo.id)}"
                            style="--recent-group-color: ${escapeSidebarHtml(getSidebarGroupColor(grupo.etiquetaCor))}; --recent-group-text: ${escapeSidebarHtml(getSidebarGroupTextColor(grupo.etiquetaCor))}">
                        <span class="recent-group-main">
                            <span class="recent-group-button-name">${escapeSidebarHtml(grupo.nome)}</span>
                        </span>
                        <span class="recent-group-actions">
                            <span class="recent-group-button-access">Último acesso: ${escapeSidebarHtml(formatSidebarDateTime(grupo.dataUltimoAcesso))}</span>
                            <span role="button" tabindex="0" class="recent-group-icon-button ${grupo.fixado ? "is-pinned" : ""}" data-fixar-grupo="${escapeSidebarHtml(grupo.id)}" title="${grupo.fixado ? "Desafixar organização" : "Fixar organização"}" aria-label="${grupo.fixado ? "Desafixar organização" : "Fixar organização"}">
                                <i class="bi ${grupo.fixado ? "bi-pin-angle-fill" : "bi-pin-angle"}"></i>
                            </span>
                        </span>
                        ${Number(grupo.chamadosAtivos || 0) > 0 ? `<span class="recent-group-open-count" title="${Number(grupo.chamadosAtivos || 0)} chamados ativos">${Number(grupo.chamadosAtivos || 0) > 99 ? "99+" : Number(grupo.chamadosAtivos || 0)}</span>` : ""}
                    </button>
                `).join("");

                listaOrganizacoes.querySelectorAll("[data-grupo-id]").forEach(botao => {
                    botao.addEventListener("click", function () {
                        const grupoId = this.dataset.grupoId;
                        const acessarUrl = sidebar.dataset.sidebarAcessarGrupoUrl;
                        if (!grupoId || !acessarUrl) {
                            return;
                        }

                        window.location.href = `${acessarUrl}&grupoId=${encodeURIComponent(grupoId)}`;
                    });
                });

                listaOrganizacoes.querySelectorAll("[data-fixar-grupo]").forEach(botao => {
                    botao.addEventListener("click", event => {
                        event.preventDefault();
                        event.stopPropagation();
                        alternarGrupoFixado(Number(botao.dataset.fixarGrupo || 0));
                    });
                    botao.addEventListener("keydown", event => {
                        if (event.key !== "Enter" && event.key !== " ") return;
                        event.preventDefault();
                        event.stopPropagation();
                        alternarGrupoFixado(Number(botao.dataset.fixarGrupo || 0));
                    });
                });

                organizacoesCarregadas = true;
            } catch {
                listaOrganizacoes.innerHTML = '<div class="text-danger small">Não foi possível carregar as organizações.</div>';
            }
        }

        async function recarregarOrganizacoesRecentes() {
            organizacoesCarregadas = false;
            await carregarOrganizacoesRecentes();
        }

        async function alternarGrupoFixado(grupoId) {
            const url = sidebar.dataset.sidebarFixarGrupoUrl;
            if (!url || !grupoId) return;

            try {
                await enviarSidebarJson(url, { grupoId });
                await recarregarOrganizacoesRecentes();
            } catch (error) {
                alert(error.message || "Não foi possível atualizar a organização fixada.");
            }
        }

        carregarContadorNotificacoes();
        setInterval(() => {
            if (!document.hidden) {
                carregarContadorNotificacoes();
            }
        }, 30000);

        if (modalOrganizacoes) {
            modalOrganizacoes.addEventListener("show.bs.modal", carregarOrganizacoesRecentes);
        }

        if (btnAbrirTelaNotificacoes && sidebar.dataset.sidebarNotificacoesPageUrl) {
            btnAbrirTelaNotificacoes.href = sidebar.dataset.sidebarNotificacoesPageUrl;
        }

        if (linkNotificacoes) {
            linkNotificacoes.addEventListener("click", event => {
                event.preventDefault();
                abrirModalNotificacoesSidebar();
            });
        }

        perfilNotificacaoIcone?.addEventListener("click", event => {
            event.preventDefault();
            event.stopPropagation();
            abrirModalNotificacoesSidebar();
        });

        if (modalNotificacoesElement) {
            modalNotificacoesElement.addEventListener("hidden.bs.modal", () => {
                if (notificacoesAlteradas) {
                    window.location.reload();
                }
            });
        }
    })();
</script>
