<div class="modal fade" id="modalSidebarNotificacoes" tabindex="-1" aria-labelledby="modalSidebarNotificacoesLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content border-0">
            <div class="modal-header">
                <h5 class="modal-title" id="modalSidebarNotificacoesLabel">Notificações não lidas</h5>
