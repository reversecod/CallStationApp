<input type="hidden"
       id="requestVerificationTokenSidebar"
       value="@(Antiforgery.GetAndStoreTokens(Context).RequestToken)" />

<script>
    (function () {
        const sidebar = document.querySelector(".sidebar[data-sidebar-grupo-id]");
        if (!sidebar) {
            return;
        }

        const badge = document.getElementById("sidebarNotificacoesBadge");
        const perfilNotificacaoIcone = document.getElementById("sidebarPerfilNotificacaoIcone");
        const linkNotificacoes = document.getElementById("sidebarAbrirNotificacoes");
        const modalNotificacoesElement = document.getElementById("modalSidebarNotificacoes");
        const listaNotificacoes = document.getElementById("listaSidebarNotificacoes");
        const btnAbrirTelaNotificacoes = document.getElementById("btnAbrirTelaNotificacoesSidebar");
        const tokenSidebar = document.getElementById("requestVerificationTokenSidebar")?.value || "";
        const listaOrganizacoes = document.getElementById("listaOrganizacoesRecentes");
        const modalOrganizacoes = document.getElementById("modalOrganizacoesRecentes");
        const sidebarToggleButton = document.getElementById("sidebarToggleButton");
        const sidebarExpandButton = document.getElementById("sidebarExpandButton");
        const sidebarCollapsedKey = "callstation.sidebar.recolhida";
        const sidebarBackgroundOpacityRange = document.getElementById("sidebarBackgroundOpacityRange");
        const sidebarBackgroundOpacityValue = document.getElementById("sidebarBackgroundOpacityValue");
        const chamadoModalOpacityRange = document.getElementById("chamadoModalOpacityRange");
        const chamadoModalOpacityValue = document.getElementById("chamadoModalOpacityValue");
        const sidebarBackgroundOpacityKey = `callstation.sidebar.backgroundOpacity.${sidebar.dataset.sidebarGrupoId}`;
        const chamadoModalOpacityKey = `callstation.chamado.modalOpacity.${sidebar.dataset.sidebarGrupoId}`;
        let organizacoesCarregadas = false;
        let notificacoesAlteradas = false;

        function limitarPercentual(value, fallback) {
            const numeric = Number(value);
            if (Number.isNaN(numeric)) {
                return fallback;
            }

            return Math.min(100, Math.max(0, numeric));
        }

        function obterPercentualSalvo(key, fallback) {
            try {
                const value = localStorage.getItem(key);
                return value === null ? fallback : limitarPercentual(value, fallback);
            } catch {
                return fallback;
            }
        }

        function salvarPercentual(key, value) {
            try {
                localStorage.setItem(key, String(value));
            } catch {
                // Preferencia visual local: se o navegador bloquear storage, segue apenas na pagina atual.
            }
        }

        function aplicarOpacidadeSidebar(value, salvar) {
            const percentual = limitarPercentual(value, 100);
            document.documentElement.style.setProperty("--grupo-sidebar-bg-opacity", String(percentual / 100));
            if (sidebarBackgroundOpacityRange) {
                sidebarBackgroundOpacityRange.value = String(percentual);
            }
            if (sidebarBackgroundOpacityValue) {
                sidebarBackgroundOpacityValue.textContent = `${percentual}%`;
            }
            if (salvar) {
                salvarPercentual(sidebarBackgroundOpacityKey, percentual);
            }
        }

        function aplicarOpacidadeModalChamado(value, salvar) {
            const percentual = limitarPercentual(value, limitarPercentual(chamadoModalOpacityRange?.dataset.defaultValue, 100));
            const alpha = percentual / 100;
            document.documentElement.style.setProperty("--grupo-chamado-modal-opacity", String(alpha));
            document.documentElement.style.setProperty("--grupo-chamado-modal-bg", `rgba(255, 255, 255, ${alpha})`);
            if (chamadoModalOpacityRange) {
                chamadoModalOpacityRange.value = String(percentual);
            }
            if (chamadoModalOpacityValue) {
                chamadoModalOpacityValue.textContent = `${percentual}%`;
            }
            if (salvar) {
                salvarPercentual(chamadoModalOpacityKey, percentual);
            }
        }

        function obterSidebarRecolhidaSalva() {
            try {
                return localStorage.getItem(sidebarCollapsedKey) === "1";
            } catch {
                return false;
            }
        }

        function salvarSidebarRecolhida(recolhida) {
            try {
                localStorage.setItem(sidebarCollapsedKey, recolhida ? "1" : "0");
            } catch {
                // Preferencia visual local: se o navegador bloquear storage, segue apenas na pagina atual.
            }
        }

        function aplicarEstadoSidebar(recolhida) {
            document.body.classList.toggle("sidebar-collapsed", recolhida);
            sidebar.classList.toggle("sidebar-collapsed", recolhida);
            sidebarToggleButton?.setAttribute("aria-expanded", String(!recolhida));
            sidebarToggleButton?.setAttribute("aria-label", recolhida ? "Expandir barra lateral" : "Recolher barra lateral");
        }

        function alternarSidebar() {
            const recolhida = !document.body.classList.contains("sidebar-collapsed");
            aplicarEstadoSidebar(recolhida);
            salvarSidebarRecolhida(recolhida);
        }

        aplicarEstadoSidebar(obterSidebarRecolhidaSalva());
        sidebarToggleButton?.addEventListener("click", alternarSidebar);
        sidebarExpandButton?.addEventListener("click", alternarSidebar);
        aplicarOpacidadeSidebar(obterPercentualSalvo(sidebarBackgroundOpacityKey, 100), false);
        aplicarOpacidadeModalChamado(
            obterPercentualSalvo(chamadoModalOpacityKey, limitarPercentual(chamadoModalOpacityRange?.dataset.defaultValue, 100)),
            false
        );
        sidebarBackgroundOpacityRange?.addEventListener("input", event => aplicarOpacidadeSidebar(event.target.value, true));
        chamadoModalOpacityRange?.addEventListener("input", event => aplicarOpacidadeModalChamado(event.target.value, true));

        function escapeSidebarHtml(value) {
            return String(value ?? "")
                .replace(/&/g, "&amp;")
                .replace(/</g, "&lt;")
                .replace(/>/g, "&gt;")
                .replace(/"/g, "&quot;")
                .replace(/'/g, "&#039;");
        }

        function formatSidebarDateTime(value) {
            if (!value) {
                return "Sem acesso recente";
            }

            const data = new Date(value);
            if (Number.isNaN(data.getTime())) {
                return "Sem acesso recente";
            }

            return data.toLocaleString("pt-BR", {
                day: "2-digit",
                month: "2-digit",
                year: "numeric",
                hour: "2-digit",
                minute: "2-digit"
            });
        }

        function getSidebarGroupColor(value) {
            const normalized = String(value ?? "").trim().toLowerCase();
            const colors = {
                "0": "#e5e7eb",
                "1": "#ef4444",
                "2": "#f97316",
                "3": "#eab308",
                "4": "#22c55e",
                "5": "#3b82f6",
                "6": "#a855f7",
                "7": "#ec4899",
                "8": "#1f2937",
                branco: "#e5e7eb",
                vermelho: "#ef4444",
                laranja: "#f97316",
                amarelo: "#eab308",
                verde: "#22c55e",
                azul: "#3b82f6",
                roxo: "#a855f7",
                rosa: "#ec4899",
                preto: "#1f2937"
            };

            return colors[normalized] || "#6c757d";
        }

        function getSidebarGroupTextColor(value) {
            const normalized = String(value ?? "").trim().toLowerCase();
            return normalized === "0" || normalized === "branco" ? "#212529" : "#fff";
        }

        async function carregarContadorNotificacoes() {
            const url = sidebar.dataset.sidebarContadorUrl;
            if (!url || !badge) {
                return;
            }

            try {
                const response = await fetch(url, { headers: { "Accept": "application/json" } });
                const data = await response.json();

                if (!response.ok || !data.success) {
                    return;
                }

                const total = Number(data.dados?.totalNaoLidas || 0);
                if (total > 0) {
                    badge.textContent = total > 9 ? "9+" : String(total);
                    badge.classList.remove("d-none");
                    perfilNotificacaoIcone?.classList.remove("d-none");
                } else {
                    badge.textContent = "0";
                    badge.classList.add("d-none");
                    perfilNotificacaoIcone?.classList.add("d-none");
                }
            } catch {
                badge.classList.add("d-none");
                perfilNotificacaoIcone?.classList.add("d-none");
            }
        }

        async function enviarSidebarJson(url, body) {
            const response = await fetch(url, {
                method: "POST",
                headers: {
                    "Accept": "application/json",
                    "Content-Type": "application/json",
                    "RequestVerificationToken": tokenSidebar
                },
                body: JSON.stringify(body || {})
            });
            const data = await response.json().catch(() => null);
            if (!response.ok || !data?.success) {
                throw new Error(data?.message || "Não foi possível concluir a ação.");
            }
            return data;
        }

        function atualizarIndicadorNotificacoes(total) {
            const valor = Number(total || 0);
            if (valor > 0) {
                if (badge) {
                    badge.textContent = valor > 9 ? "9+" : String(valor);
                    badge.classList.remove("d-none");
                }
                perfilNotificacaoIcone?.classList.remove("d-none");
                return;
            }

            if (badge) {
                badge.textContent = "0";
                badge.classList.add("d-none");
            }
            perfilNotificacaoIcone?.classList.add("d-none");
        }

        function renderizarNotificacoesSidebar(notificacoes) {
            if (!listaNotificacoes) {
                return;
            }

            if (!notificacoes.length) {
                listaNotificacoes.innerHTML = `
                    <div class="text-center text-muted p-4">
                        <i class="bi bi-bell-slash fs-2 d-block mb-2"></i>
                        Nenhuma notificação não lida.
                    </div>`;
                return;
            }

            listaNotificacoes.innerHTML = notificacoes.map(notificacao => {
                const corGrupo = getSidebarGroupColor(notificacao.etiquetaCor);
                const corTextoGrupo = getSidebarGroupTextColor(notificacao.etiquetaCor);

                return `
                <div class="sidebar-notification-item" data-sidebar-notificacao-id="${Number(notificacao.id || 0)}">
                    <div class="sidebar-notification-meta mb-1">
                        <span>${escapeSidebarHtml(notificacao.tipo || "Notificação")}</span>
                        ${notificacao.nomeGrupo ? `<span>Grupo:</span><span class="sidebar-notification-group-label" style="--sidebar-notification-group-color: ${escapeSidebarHtml(corGrupo)}; --sidebar-notification-group-text: ${escapeSidebarHtml(corTextoGrupo)};">${escapeSidebarHtml(notificacao.nomeGrupo)}</span>` : ""}
                        <span>${escapeSidebarHtml(notificacao.dataCriacaoTexto || "")}</span>
                    </div>
                    <div class="sidebar-notification-title mb-1">${escapeSidebarHtml(notificacao.titulo || "Notificação")}</div>
                    <div class="sidebar-notification-message mb-3">${escapeSidebarHtml(notificacao.mensagem || "")}</div>
                    <div class="d-flex flex-wrap gap-2">
                        <button type="button" class="btn btn-sm btn-primary sidebar-notification-action" data-sidebar-ir-notificacao="${Number(notificacao.id || 0)}">
                            Ir até
                        </button>
                        <button type="button" class="btn btn-sm sidebar-notification-action sidebar-notification-unread" data-sidebar-marcar-lida="${Number(notificacao.id || 0)}">
                            Não lida
                        </button>
                    </div>
                </div>
            `;
            }).join("");

            listaNotificacoes.querySelectorAll("[data-sidebar-ir-notificacao]").forEach(botao => {
                botao.addEventListener("click", () => abrirNotificacaoSidebar(Number(botao.dataset.sidebarIrNotificacao || 0)));
            });

            listaNotificacoes.querySelectorAll("[data-sidebar-marcar-lida]").forEach(botao => {
                botao.addEventListener("click", () => marcarNotificacaoSidebarComoLida(Number(botao.dataset.sidebarMarcarLida || 0)));
            });
        }

        async function carregarNotificacoesSidebar() {
            const url = sidebar.dataset.sidebarNotificacoesUrl;
            if (!url || !listaNotificacoes) {
                return;
            }

            listaNotificacoes.innerHTML = '<div class="text-muted small">Carregando notificações...</div>';

            try {
                const response = await fetch(url, { headers: { "Accept": "application/json" } });
                const data = await response.json();
                if (!response.ok || !data.success) {
                    throw new Error(data.message || "Não foi possível carregar as notificações.");
                }

                const notificacoes = data.dados?.notificacoes || [];
                renderizarNotificacoesSidebar(notificacoes);
                atualizarIndicadorNotificacoes(data.dados?.totalNaoLidas || notificacoes.length);
            } catch (error) {
                listaNotificacoes.innerHTML = `<div class="text-danger small">${escapeSidebarHtml(error.message || "Não foi possível carregar as notificações.")}</div>`;
            }
        }

        function abrirModalNotificacoesSidebar() {
            const modalNotificacoes = modalNotificacoesElement && window.bootstrap
                ? bootstrap.Modal.getOrCreateInstance(modalNotificacoesElement)
                : null;

            if (!modalNotificacoes) {
                window.location.href = sidebar.dataset.sidebarNotificacoesPageUrl || linkNotificacoes?.href || "/Menu/Notifications";
                return;
            }

            carregarNotificacoesSidebar();
            modalNotificacoes.show();
        }

        async function abrirNotificacaoSidebar(notificacaoId) {
            const url = sidebar.dataset.sidebarAbrirNotificacaoUrl;
            if (!url || !notificacaoId) {
                return;
            }

            try {
                const data = await enviarSidebarJson(url, { notificacaoId });
                window.location.href = data.destino || sidebar.dataset.sidebarNotificacoesPageUrl || linkNotificacoes?.href || "/Menu/Notifications";
            } catch (error) {
                alert(error.message || "Não foi possível abrir a notificação.");
            }
        }

        async function marcarNotificacaoSidebarComoLida(notificacaoId) {
            const url = sidebar.dataset.sidebarMarcarLidaUrl;
            if (!url || !notificacaoId) {
                return;
            }

            try {
                const data = await enviarSidebarJson(url, { notificacaoId });
                notificacoesAlteradas = true;
                listaNotificacoes?.querySelector(`[data-sidebar-notificacao-id="${notificacaoId}"]`)?.remove();
                atualizarIndicadorNotificacoes(data.totalNaoLidas || 0);

                if (!listaNotificacoes?.querySelector("[data-sidebar-notificacao-id]")) {
                    renderizarNotificacoesSidebar([]);
                }
            } catch (error) {
                alert(error.message || "Não foi possível marcar a notificação como lida.");
            }
        }

        async function carregarOrganizacoesRecentes() {
            if (!listaOrganizacoes || organizacoesCarregadas) {
                return;
            }

            const url = sidebar.dataset.sidebarGruposUrl;
            if (!url) {
                return;
            }

            listaOrganizacoes.innerHTML = '<div class="text-muted small">Carregando organizações...</div>';

            try {
                const response = await fetch(url, { headers: { "Accept": "application/json" } });
                const data = await response.json();

                if (!response.ok || !data.success) {
                    listaOrganizacoes.innerHTML = `<div class="text-danger small">${escapeSidebarHtml(data.message || "Não foi possível carregar as organizações.")}</div>`;
                    return;
                }

                const grupos = data.dados?.grupos || [];
                if (!grupos.length) {
                    listaOrganizacoes.innerHTML = '<div class="text-muted small">Você ainda não acessou organizações recentemente.</div>';
                    organizacoesCarregadas = true;
                    return;
                }

                listaOrganizacoes.innerHTML = grupos.map(grupo => `
                    <button type="button"
                            class="recent-group-button"
                            data-grupo-id="${escapeSidebarHtml(grupo.id)}"
                            style="--recent-group-color: ${escapeSidebarHtml(getSidebarGroupColor(grupo.etiquetaCor))}; --recent-group-text: ${escapeSidebarHtml(getSidebarGroupTextColor(grupo.etiquetaCor))}">
                        <span class="recent-group-main">
                            <span class="recent-group-button-name">${escapeSidebarHtml(grupo.nome)}</span>
                        </span>
                        <span class="recent-group-actions">
                            <span class="recent-group-button-access">Último acesso: ${escapeSidebarHtml(formatSidebarDateTime(grupo.dataUltimoAcesso))}</span>
                            <span role="button" tabindex="0" class="recent-group-icon-button ${grupo.fixado ? "is-pinned" : ""}" data-fixar-grupo="${escapeSidebarHtml(grupo.id)}" title="${grupo.fixado ? "Desafixar organização" : "Fixar organização"}" aria-label="${grupo.fixado ? "Desafixar organização" : "Fixar organização"}">
                                <i class="bi ${grupo.fixado ? "bi-pin-angle-fill" : "bi-pin-angle"}"></i>
                            </span>
                        </span>
                        ${Number(grupo.chamadosAtivos || 0) > 0 ? `<span class="recent-group-open-count" title="${Number(grupo.chamadosAtivos || 0)} chamados ativos">${Number(grupo.chamadosAtivos || 0) > 99 ? "99+" : Number(grupo.chamadosAtivos || 0)}</span>` : ""}
                    </button>
                `).join("");

                listaOrganizacoes.querySelectorAll("[data-grupo-id]").forEach(botao => {
                    botao.addEventListener("click", function () {
                        const grupoId = this.dataset.grupoId;
                        const acessarUrl = sidebar.dataset.sidebarAcessarGrupoUrl;
                        if (!grupoId || !acessarUrl) {
                            return;
                        }

                        window.location.href = `${acessarUrl}&grupoId=${encodeURIComponent(grupoId)}`;
                    });
                });

                listaOrganizacoes.querySelectorAll("[data-fixar-grupo]").forEach(botao => {
                    botao.addEventListener("click", event => {
                        event.preventDefault();
                        event.stopPropagation();
                        alternarGrupoFixado(Number(botao.dataset.fixarGrupo || 0));
                    });
                    botao.addEventListener("keydown", event => {
                        if (event.key !== "Enter" && event.key !== " ") return;
                        event.preventDefault();
                        event.stopPropagation();
                        alternarGrupoFixado(Number(botao.dataset.fixarGrupo || 0));
                    });
                });

                organizacoesCarregadas = true;
            } catch {
                listaOrganizacoes.innerHTML = '<div class="text-danger small">Não foi possível carregar as organizações.</div>';
            }
        }

        async function recarregarOrganizacoesRecentes() {
            organizacoesCarregadas = false;
            await carregarOrganizacoesRecentes();
        }

        async function alternarGrupoFixado(grupoId) {
            const url = sidebar.dataset.sidebarFixarGrupoUrl;
            if (!url || !grupoId) return;

            try {
                await enviarSidebarJson(url, { grupoId });
                await recarregarOrganizacoesRecentes();
            } catch (error) {
                alert(error.message || "Não foi possível atualizar a organização fixada.");
            }
        }

        carregarContadorNotificacoes();
        setInterval(() => {
            if (!document.hidden) {
                carregarContadorNotificacoes();
            }
        }, 30000);

        if (modalOrganizacoes) {
            modalOrganizacoes.addEventListener("show.bs.modal", carregarOrganizacoesRecentes);
        }

        if (btnAbrirTelaNotificacoes && sidebar.dataset.sidebarNotificacoesPageUrl) {
            btnAbrirTelaNotificacoes.href = sidebar.dataset.sidebarNotificacoesPageUrl;
        }

        if (linkNotificacoes) {
            linkNotificacoes.addEventListener("click", event => {
                event.preventDefault();
                abrirModalNotificacoesSidebar();
            });
        }

        perfilNotificacaoIcone?.addEventListener("click", event => {
            event.preventDefault();
            event.stopPropagation();
            abrirModalNotificacoesSidebar();
        });

        if (modalNotificacoesElement) {
            modalNotificacoesElement.addEventListener("hidden.bs.modal", () => {
                if (notificacoesAlteradas) {
                    window.location.reload();
                }
            });
        }
    })();
</script>
